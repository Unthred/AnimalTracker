# Copy this file to .env before first deploy.
# The .env file is ignored by git so secrets stay local.

# Environment
ASPNETCORE_ENVIRONMENT=Production

# Logging levels (set LOG_LEVEL_EF_SQL=Information to debug SQL)
LOG_LEVEL_DEFAULT=Information
LOG_LEVEL_ASPNETCORE=Warning
LOG_LEVEL_EF_SQL=Warning
LOG_LEVEL_EF_MIGRATIONS=Information

# Host port exposed on UnRaid (container listens on 8080)
APP_PORT=8085

# Container image to deploy (GHCR by default).
# Set to a pinned tag (for example, ghcr.io/unthred/animaltracker:sha-abcdef1) for deterministic rollouts.
ANIMALTRACKER_IMAGE=ghcr.io/unthred/animaltracker:main

# Persistent app data root on host
# Relative path example:
DATA_ROOT=./data
# Absolute UnRaid path example:
# DATA_ROOT=/mnt/user/appdata/animaltracker

# Optional one-time admin bootstrap at startup.
# Leave blank to skip automatic admin creation.
ANIMALTRACKER_ADMIN_EMAIL=
ANIMALTRACKER_ADMIN_PASSWORD=
