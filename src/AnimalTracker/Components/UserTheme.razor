@using AnimalTracker.Services
@using Microsoft.AspNetCore.Components.Authorization
@rendermode InteractiveServer
@implements IDisposable

@inject UserSettingsService Settings
@inject AuthenticationStateProvider AuthStateProvider
@inject AnimalTracker.State.UserPreferencesState Prefs
@inject IJSRuntime JS

@if (!string.IsNullOrWhiteSpace(accent))
{
    <style>
        :root { --accent: @accent; }
    </style>
}

@code
{
    private string? accent;
    private string? lastAppliedThemeMode;

    protected override async Task OnInitializedAsync()
    {
        Prefs.Changed += OnPrefsChanged;

        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        if (auth.User.Identity?.IsAuthenticated == true)
        {
            var s = await Settings.GetOrCreateAsync();
            Prefs.Apply(s);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // JS interop is only valid after interactive render begins (not during prerender).
        // Re-apply theme on navigation/rerenders if needed.
        if (lastAppliedThemeMode != Prefs.ThemeMode)
        {
            await ApplyThemeAsync();
            lastAppliedThemeMode = Prefs.ThemeMode;
        }
    }

    private void OnPrefsChanged()
    {
        accent = Prefs.AccentColorHex;
        _ = InvokeAsync(StateHasChanged);
    }

    private ValueTask ApplyThemeAsync() =>
        JS.InvokeVoidAsync("animalTrackerSetTheme", Prefs.ThemeMode);

    public void Dispose()
    {
        Prefs.Changed -= OnPrefsChanged;
    }
}

