@using AnimalTracker.Services
@using Microsoft.AspNetCore.Components.Authorization
@rendermode InteractiveServer
@implements IDisposable

@inject UserSettingsService Settings
@inject AppSettingsService AppSettings
@inject AuthenticationStateProvider AuthStateProvider
@inject AnimalTracker.State.UserPreferencesState Prefs
@inject IJSRuntime JS

@if (!string.IsNullOrWhiteSpace(accent))
{
    <style>
        :root { --accent: @accent; }
    </style>
}

@code
{
    private string? accent;
    private string? lastAppliedThemeMode;
    private string? lastAppliedUserId;
    private string themeModeOverride = "system";

    protected override async Task OnInitializedAsync()
    {
        Prefs.Changed += OnPrefsChanged;
        AuthStateProvider.AuthenticationStateChanged += OnAuthenticationStateChanged;
        await RefreshFromAuthenticationStateAsync(await AuthStateProvider.GetAuthenticationStateAsync());
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // JS interop is only valid after interactive render begins (not during prerender).
        // Re-apply theme on navigation/rerenders if needed.
        var desiredThemeMode = string.IsNullOrWhiteSpace(themeModeOverride) ? Prefs.ThemeMode : themeModeOverride;
        if (lastAppliedThemeMode != desiredThemeMode)
        {
            await ApplyThemeAsync(desiredThemeMode);
            lastAppliedThemeMode = desiredThemeMode;
        }
    }

    private void OnPrefsChanged()
    {
        accent = Prefs.AccentColorHex;
        _ = InvokeAsync(StateHasChanged);
    }

    private void OnAuthenticationStateChanged(Task<AuthenticationState> authTask) =>
        _ = InvokeAsync(async () =>
        {
            var auth = await authTask;
            await RefreshFromAuthenticationStateAsync(auth);
            StateHasChanged();
        });

    private async Task RefreshFromAuthenticationStateAsync(AuthenticationState auth)
    {
        if (auth.User.Identity?.IsAuthenticated != true)
        {
            lastAppliedUserId = null;
            var appDefaults = await AppSettings.GetOrCreateAsync();
            themeModeOverride = string.IsNullOrWhiteSpace(appDefaults.DefaultThemeMode) ? "system" : appDefaults.DefaultThemeMode;
            return;
        }

        var userId = auth.User.FindFirst("sub")?.Value
            ?? auth.User.FindFirst("http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier")?.Value
            ?? auth.User.Identity?.Name
            ?? "__authenticated__";

        if (string.Equals(lastAppliedUserId, userId, StringComparison.Ordinal))
            return;

        var s = await Settings.GetOrCreateAsync();
        Prefs.Apply(s);
        accent = Prefs.AccentColorHex;
        lastAppliedUserId = userId;
        themeModeOverride = "";
    }

    private ValueTask ApplyThemeAsync(string themeMode) =>
        JS.InvokeVoidAsync("animalTrackerSetTheme", themeMode);

    public void Dispose()
    {
        Prefs.Changed -= OnPrefsChanged;
        AuthStateProvider.AuthenticationStateChanged -= OnAuthenticationStateChanged;
    }
}

