@using AnimalTracker.Data.Entities

<SearchableCombobox TValue="string"
                    Id="@Id"
                    Items="@NameOptions"
                    Value="@(Value ?? "")"
                    ValueChanged="OnInnerValueChanged"
                    Placeholder="@EffectivePlaceholder"
                    AllowCustomValue="true"
                    AllowClear="true"
                    NoResultsText="No locations found"
                    ChevronAriaLabel="Show location suggestions"
                    Class="@Class"
                    AdditionalAttributes="@AdditionalAttributes" />

@code {
    [Parameter] public string? Id { get; set; }
    [Parameter] public IReadOnlyList<Location> Items { get; set; } = [];
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string EffectivePlaceholder => string.IsNullOrWhiteSpace(Placeholder)
        ? "Select or type location..."
        : Placeholder!;

    private IReadOnlyList<ComboboxOption<string>> NameOptions =>
        Items.Select(s => new ComboboxOption<string>(s.Name, s.Name)).ToArray();

    private Task OnInnerValueChanged(string v)
    {
        var nv = string.IsNullOrWhiteSpace(v) ? null : v;
        return ValueChanged.InvokeAsync(nv);
    }
}
