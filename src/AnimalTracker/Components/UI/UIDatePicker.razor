@using System.Globalization
@inherits InputBase<DateTime>

<div class="relative" @onkeydown="OnKeyDown">
    <div class="relative">
        <button type="button"
                class="@InputClass"
                aria-haspopup="dialog"
                aria-expanded="@(open ? "true" : "false")"
                @onclick="Toggle">
            <span class="min-w-0 truncate text-left">@DisplayText</span>

            <span class="ml-2 flex shrink-0 items-center text-slate-400 dark:text-slate-500">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3M5 11h14M6 21h12a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2Z" />
                </svg>
            </span>
        </button>
    </div>

    @if (open)
    {
        <div class="fixed inset-0 z-40" @onclick="Close">
            <div class="absolute inset-0 bg-black/20"></div>
        </div>

        <div class="absolute z-50 mt-2 w-[20rem] overflow-hidden rounded-2xl border border-slate-200/80 bg-white shadow-xl dark:border-slate-800/80 dark:bg-slate-900"
             role="dialog"
             aria-label="Choose date">
            <div class="flex items-center justify-between gap-2 border-b border-slate-200/80 px-4 py-3 dark:border-slate-800/80">
                <button type="button" class="@NavButtonClass" aria-label="Previous month" @onclick="PrevMonth">‹</button>
                <div class="min-w-0 text-sm font-semibold text-slate-900 dark:text-slate-50">
                    @cursorMonth.ToString("MMMM yyyy", CultureInfo.CurrentCulture)
                </div>
                <button type="button" class="@NavButtonClass" aria-label="Next month" @onclick="NextMonth">›</button>
            </div>

            <div class="p-4">
                <div class="mb-3 flex items-center gap-2">
                    <input class="@TextInputClass"
                           inputmode="numeric"
                           placeholder="@Placeholder"
                           value="@textValue"
                           @oninput="OnTextInput" />
                    <button type="button" class="@SmallButtonClass" @onclick="Today">Today</button>
                </div>

                <div class="grid grid-cols-7 gap-1 text-center text-[0.7rem] font-semibold text-slate-500 dark:text-slate-400">
                    @foreach (var d in WeekdayHeaders)
                    {
                        <div class="py-1">@d</div>
                    }
                </div>

                <div class="mt-1 grid grid-cols-7 gap-1">
                    @foreach (var cell in Cells)
                    {
                        if (cell is null)
                        {
                            <div class="h-9"></div>
                        }
                        else
                        {
                            <button type="button"
                                    class="@GetDayClass(cell.Value)"
                                    aria-label="@cell.Value.ToString("D", CultureInfo.CurrentCulture)"
                                    @onclick="() => Select(cell.Value)">
                                @cell.Value.Day
                            </button>
                        }
                    }
                </div>

                @if (showValidationMessage)
                {
                    <div class="mt-3 text-xs text-red-700">@validationMessage</div>
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public string Placeholder { get; set; } = "DD/MM/YYYY";
    [Parameter] public string? Class { get; set; }

    private bool open;
    private DateTime cursorMonth;
    private string textValue = "";
    private bool showValidationMessage;
    private string? validationMessage;

    private static readonly string[] WeekdayHeaders = ["Mo", "Tu", "We", "Th", "Fr", "Sa", "Su"];

    protected override void OnInitialized()
    {
        cursorMonth = new DateTime(CurrentValue.Year, CurrentValue.Month, 1);
        textValue = Format(CurrentValue);
    }

    protected override void OnParametersSet()
    {
        // Keep the displayed text in sync when the model changes externally.
        var formatted = Format(CurrentValue);
        if (!string.Equals(textValue, formatted, StringComparison.Ordinal))
            textValue = formatted;
        cursorMonth = new DateTime(CurrentValue.Year, CurrentValue.Month, 1);
    }

    private string DisplayText => string.IsNullOrWhiteSpace(Format(CurrentValue)) ? Placeholder : Format(CurrentValue);

    private string InputClass => string.Join(' ', new[]
    {
        "flex w-full min-w-0 items-center justify-between rounded-xl border px-3 py-2.5 text-sm shadow-sm transition duration-200 ease-in-out",
        "border-slate-200/90 bg-white text-slate-900 hover:border-slate-300 hover:shadow-sm",
        "focus:outline-none focus-visible:ring-4 focus-visible:ring-slate-200/70",
        "dark:border-slate-700 dark:bg-slate-900 dark:text-slate-50 dark:hover:border-slate-600 dark:focus-visible:ring-slate-800/80",
        "text-left",
        Class
    }.Where(s => !string.IsNullOrWhiteSpace(s)));

    private const string NavButtonClass =
        "inline-flex h-8 w-8 items-center justify-center rounded-lg text-slate-600 hover:bg-slate-100/90 focus:outline-none focus-visible:ring-4 focus-visible:ring-slate-200/70 dark:text-slate-200 dark:hover:bg-slate-800/60 dark:focus-visible:ring-slate-700/80";

    private const string SmallButtonClass =
        "inline-flex items-center justify-center rounded-lg border border-slate-200/90 bg-white px-3 py-2 text-xs font-semibold text-slate-800 shadow-sm transition duration-200 hover:bg-slate-50 focus:outline-none focus-visible:ring-4 focus-visible:ring-slate-200/70 dark:border-slate-700 dark:bg-slate-900/80 dark:text-slate-100 dark:hover:bg-slate-800/80 dark:focus-visible:ring-slate-700/80";

    private const string TextInputClass =
        "w-full min-w-0 rounded-lg border border-slate-200/90 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm outline-none transition duration-200 ease-in-out hover:border-slate-300 focus:border-slate-300 focus:ring-4 focus:ring-slate-200/70 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-50 dark:hover:border-slate-600 dark:focus:ring-slate-800/80";

    private IReadOnlyList<DateTime?> Cells
    {
        get
        {
            var first = new DateTime(cursorMonth.Year, cursorMonth.Month, 1);
            var daysInMonth = DateTime.DaysInMonth(cursorMonth.Year, cursorMonth.Month);

            // Monday = 0, Sunday = 6
            var offset = ((int)first.DayOfWeek + 6) % 7;

            var list = new List<DateTime?>(42);
            for (var i = 0; i < offset; i++) list.Add(null);
            for (var d = 1; d <= daysInMonth; d++) list.Add(new DateTime(cursorMonth.Year, cursorMonth.Month, d));
            while (list.Count % 7 != 0) list.Add(null);
            return list;
        }
    }

    private void Toggle()
    {
        open = !open;
        showValidationMessage = false;
    }

    private void Close()
    {
        open = false;
        showValidationMessage = false;
    }

    private void PrevMonth()
    {
        cursorMonth = cursorMonth.AddMonths(-1);
    }

    private void NextMonth()
    {
        cursorMonth = cursorMonth.AddMonths(1);
    }

    private void Today()
    {
        Select(DateTime.Today);
    }

    private void Select(DateTime date)
    {
        var v = date.Date;
        CurrentValue = v;
        textValue = Format(v);
        cursorMonth = new DateTime(v.Year, v.Month, 1);
        Close();
    }

    private void OnTextInput(ChangeEventArgs e)
    {
        textValue = e.Value?.ToString() ?? "";
        showValidationMessage = false;

        if (TryParseDate(textValue, out var dt))
        {
            CurrentValue = dt.Date;
            cursorMonth = new DateTime(CurrentValue.Year, CurrentValue.Month, 1);
        }
        else if (!string.IsNullOrWhiteSpace(textValue))
        {
            showValidationMessage = true;
            validationMessage = "Invalid date.";
        }
    }

    private void OnKeyDown(KeyboardEventArgs e)
    {
        if (!open)
            return;

        if (e.Key is "Escape")
        {
            Close();
            return;
        }

        // Minimal keyboard support: arrows move by day, PgUp/PgDn month, Home/End week.
        var baseDate = CurrentValue.Date;
        DateTime? next = e.Key switch
        {
            "ArrowLeft" => baseDate.AddDays(-1),
            "ArrowRight" => baseDate.AddDays(1),
            "ArrowUp" => baseDate.AddDays(-7),
            "ArrowDown" => baseDate.AddDays(7),
            "PageUp" => baseDate.AddMonths(-1),
            "PageDown" => baseDate.AddMonths(1),
            _ => null
        };

        if (next is not null)
        {
            CurrentValue = next.Value.Date;
            textValue = Format(CurrentValue);
            cursorMonth = new DateTime(CurrentValue.Year, CurrentValue.Month, 1);
        }
    }

    private string GetDayClass(DateTime date)
    {
        var isSelected = date.Date == CurrentValue.Date;
        var isToday = date.Date == DateTime.Today;

        var baseClass = "h-9 w-full rounded-lg text-sm font-medium transition duration-150 focus:outline-none focus-visible:ring-4 focus-visible:ring-slate-200/70 dark:focus-visible:ring-slate-700/80";
        var normal = "text-slate-700 hover:bg-slate-100/90 dark:text-slate-200 dark:hover:bg-slate-800/60";
        var today = "ring-1 ring-slate-300 dark:ring-slate-700";
        var selected = "bg-[var(--accent)] text-white hover:brightness-[0.96]";

        return string.Join(' ', new[] { baseClass, isSelected ? selected : normal, !isSelected && isToday ? today : "" }.Where(s => !string.IsNullOrWhiteSpace(s)));
    }

    protected override bool TryParseValueFromString(string? value, out DateTime result, out string validationErrorMessage)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            result = default;
            validationErrorMessage = "";
            return true;
        }

        if (TryParseDate(value, out var dt))
        {
            result = dt.Date;
            validationErrorMessage = "";
            return true;
        }

        result = default;
        validationErrorMessage = "Invalid date.";
        return false;
    }

    private static bool TryParseDate(string value, out DateTime dt)
    {
        // Prefer current culture, but accept ISO-like inputs too.
        var styles = DateTimeStyles.AllowWhiteSpaces;
        return DateTime.TryParse(value, CultureInfo.CurrentCulture, styles, out dt)
            || DateTime.TryParseExact(value, "yyyy-MM-dd", CultureInfo.InvariantCulture, styles, out dt)
            || DateTime.TryParseExact(value, "dd/MM/yyyy", CultureInfo.InvariantCulture, styles, out dt);
    }

    private static string Format(DateTime value) =>
        value == default ? "" : value.ToString("d", CultureInfo.CurrentCulture);
}

