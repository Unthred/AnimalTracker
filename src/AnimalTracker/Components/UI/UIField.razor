<div class="@OuterClass">
    @if (Label is not null)
    {
        <label class="@LabelClassCombined" for="@For">@Label</label>
    }
    <div class="@(Label is not null ? "mt-2" : "")">
        @ChildContent
    </div>
    @if (Hint is not null)
    {
        <p class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-400 sm:text-xs">@Hint</p>
    }
</div>

@code {
    [Parameter] public string? Label { get; set; }
    /// <summary>Optional extra label classes (e.g. font-semibold). When set, replaces default font-medium.</summary>
    [Parameter] public string? LabelClass { get; set; }
    [Parameter] public string? For { get; set; }
    [Parameter] public string? Hint { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }

    private string OuterClass => string.Join(' ', new[] { Class }.Where(s => !string.IsNullOrWhiteSpace(s)));

    private string LabelClassCombined => string.IsNullOrWhiteSpace(LabelClass)
        ? "block text-base font-medium text-slate-700 dark:text-slate-200 sm:text-sm"
        : $"block text-base text-slate-700 dark:text-slate-200 sm:text-sm {LabelClass}";
}
