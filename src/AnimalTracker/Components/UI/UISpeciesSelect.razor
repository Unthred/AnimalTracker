@using AnimalTracker.Data.Entities

<SearchableCombobox TValue="int?"
                    WrapperClass="min-w-0 space-y-2"
                    Id="@Id"
                    Items="@SpeciesOptions"
                    EmptyRowWhenUnfiltered="@EmptyRow"
                    Value="Value"
                    ValueChanged="ValueChanged"
                    Placeholder="@EmptyLabel"
                    Disabled="@(Items.Count == 0)"
                    NoResultsText="No species found"
                    AllowClear="true"
                    ChevronAriaLabel="Show species options"
                    Class="@Class"
                    AdditionalAttributes="@AdditionalAttributes">
    <Footer>
        @if (ShowEmptyItemsHint && Items.Count == 0)
        {
            <p class="text-xs text-slate-500 dark:text-slate-400">Select a species region in Settings to load this list.</p>
        }
        @if (ShowLookupLink)
        {
            <p class="text-xs">
                <a href="/species"
                   target="_blank"
                   rel="noreferrer noopener"
                   class="font-semibold text-sky-600 underline-offset-2 hover:text-sky-500 hover:underline dark:text-sky-400 dark:hover:text-sky-300">
                    Lookup species
                </a>
            </p>
        }
    </Footer>
</SearchableCombobox>

@code {
    [Parameter] public string? Id { get; set; }
    [Parameter] public IReadOnlyList<Species> Items { get; set; } = [];
    [Parameter] public int? Value { get; set; }
    [Parameter] public EventCallback<int?> ValueChanged { get; set; }
    [Parameter] public string EmptyLabel { get; set; } = "Select species...";
    [Parameter] public bool ShowEmptyItemsHint { get; set; }
    [Parameter] public bool ShowLookupLink { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private ComboboxOption<int?> EmptyRow => new(null, EmptyLabel);

    private IReadOnlyList<ComboboxOption<int?>> SpeciesOptions =>
        Items.Select(s => new ComboboxOption<int?>(s.Id, s.Name)).ToArray();
}
