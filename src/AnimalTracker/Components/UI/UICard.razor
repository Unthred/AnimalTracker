<div class="@ComputedClass" @attributes="AdditionalAttributes">
    @if (Title is not null || HeaderActions is not null)
    {
        <div class="@HeaderClass">
            @if (Title is not null)
            {
                <h2 class="text-base font-semibold text-slate-900 dark:text-slate-50">@Title</h2>
            }
            @if (HeaderActions is not null)
            {
                <div class="flex flex-wrap items-center gap-2">@HeaderActions</div>
            }
        </div>
    }
    <div class="@BodyClass">
        @ChildContent
    </div>
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public RenderFragment? HeaderActions { get; set; }
    /// <summary>When false, body has no padding (e.g. full-width lists).</summary>
    [Parameter] public bool BodyPadding { get; set; } = true;
    [Parameter] public string? Class { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    [CascadingParameter(Name = "CompactUi")]
    public bool CompactUi { get; set; }

    private string HeaderClass => string.Join(' ', new[]
    {
        "flex flex-col gap-3 border-b border-slate-200/80 dark:border-slate-800/80 sm:flex-row sm:items-center sm:justify-between",
        CompactUi ? "px-4 py-3 sm:px-5" : "px-4 py-4 sm:px-6"
    });

    private string BodyClass => !BodyPadding ? "p-0" : CompactUi ? "p-4 sm:p-5" : "p-4 sm:p-6";

    private string ComputedClass => string.Join(' ', new[]
    {
        // overflow-visible so popovers (date picker, combobox lists) are not clipped by the card.
        "app-surface overflow-visible rounded-2xl border shadow-card dark:shadow-none",
        Class
    }.Where(s => !string.IsNullOrWhiteSpace(s)));
}
