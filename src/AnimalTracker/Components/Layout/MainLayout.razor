@inherits LayoutComponentBase

<div class="min-h-dvh bg-slate-50 dark:bg-slate-950">
    <div class="mx-auto grid max-w-7xl grid-cols-1 gap-4 px-4 py-4 md:grid-cols-[16rem_1fr]">
        <aside class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm dark:border-slate-800 dark:bg-slate-900">
            <NavMenu />
        </aside>

        <main class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm dark:border-slate-800 dark:bg-slate-900">
            <div class="border-b border-slate-200 px-4 py-3 dark:border-slate-800">
                <h1 class="text-base font-semibold text-slate-900 dark:text-slate-50">AnimalTracker</h1>
            </div>

            <div class="px-4 py-4">
                @Body
            </div>
        </main>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
