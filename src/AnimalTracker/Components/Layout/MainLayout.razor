@inherits LayoutComponentBase
@implements IDisposable
@inject AnimalTracker.State.UserPreferencesState Prefs
@inject AnimalTracker.State.UiProgressState UiProgress
@inject IJSRuntime JS

<div class="relative min-h-dvh w-full overflow-x-hidden bg-transparent">
    @if (UiProgress.IsActive)
    {
        <div class="pointer-events-none fixed inset-x-0 top-0 z-[70] h-0.5">
            <div class="app-progress-indeterminate h-full bg-[var(--accent)]"></div>
        </div>
    }

    <div class="mx-auto grid min-h-0 min-w-0 max-w-7xl grid-cols-1 gap-4 px-3 pb-20 pt-4 sm:gap-6 sm:px-4 sm:py-6 md:grid-cols-[minmax(0,17rem)_minmax(0,1fr)] lg:gap-8 lg:px-6 lg:py-8">
        <aside class="app-surface h-fit min-w-0 overflow-hidden rounded-2xl border shadow-card dark:shadow-none md:sticky md:top-4 md:self-start">
            <NavMenu />
        </aside>

        <main class="app-surface min-h-[50vh] min-w-0 overflow-hidden rounded-2xl border shadow-card dark:shadow-none">
            <CascadingValue Name="CompactUi" Value="Prefs.CompactMode">
                <div class="@MainInnerClass">
                    @Body
                </div>
            </CascadingValue>
        </main>
    </div>

    <footer class="fixed inset-x-0 bottom-0 z-50 border-t border-slate-200/80 bg-white/75 text-xs text-slate-500 backdrop-blur-md dark:border-slate-700/80 dark:bg-slate-950/65 dark:text-slate-400" style="position:fixed;left:0;right:0;bottom:0;">
        <div class="mx-auto flex w-full max-w-7xl flex-col gap-2 px-3 py-2 sm:flex-row sm:items-center sm:justify-between sm:px-4 md:px-6">
            <p class="truncate">© @DateTime.Now.Year Squiggley.</p>
            <div class="flex flex-wrap items-center justify-end gap-2">
                <p class="font-mono">Version @versionLabel · Started @startedAtLabel · Runtime @runtimeStamp</p>
                <button type="button"
                        class="inline-flex items-center justify-center gap-2 rounded-lg border border-slate-200/90 bg-white px-3 py-1.5 text-xs font-semibold text-slate-800 shadow-sm transition duration-200 ease-in-out hover:bg-slate-50 focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-slate-200/80 dark:border-slate-700 dark:bg-slate-900/80 dark:text-slate-100 dark:hover:bg-slate-800/80 dark:focus-visible:ring-slate-700/80"
                        @onclick="CopyDiagnosticsAsync">
                    Copy diagnostics
                </button>
                @if (!string.IsNullOrWhiteSpace(copyDiagnosticsMessage))
                {
                    <span class="rounded-md border border-slate-300/80 bg-slate-100/70 px-2 py-1 text-[11px] font-medium text-slate-700 dark:border-slate-600/80 dark:bg-slate-800/70 dark:text-slate-200">
                        @copyDiagnosticsMessage
                    </span>
                }
            </div>
        </div>
    </footer>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private string MainInnerClass => Prefs.CompactMode
        ? "min-w-0 px-4 py-6 sm:px-5 sm:py-7 md:px-6 md:py-8"
        : "min-w-0 px-4 py-7 sm:px-6 sm:py-8 md:px-8 md:py-10";

    private string versionLabel = "dev";
    private string startedAtLabel = "unknown";
    private string runtimeStamp = "unknown";
    private string? copyDiagnosticsMessage;

    protected override void OnInitialized()
    {
        var assembly = typeof(MainLayout).Assembly;
        var informationalVersion = assembly
            .GetCustomAttributes(typeof(System.Reflection.AssemblyInformationalVersionAttribute), inherit: false)
            .OfType<System.Reflection.AssemblyInformationalVersionAttribute>()
            .FirstOrDefault()
            ?.InformationalVersion;
        versionLabel = string.IsNullOrWhiteSpace(informationalVersion)
            ? assembly.GetName().Version?.ToString(3) ?? "dev"
            : informationalVersion;

        startedAtLabel = DateTime.UtcNow.ToString("yyyy-MM-dd HH:mm:ss 'UTC'");

        var moduleId = assembly.ManifestModule.ModuleVersionId.ToString("N");
        runtimeStamp = moduleId.Length >= 8 ? moduleId[..8] : moduleId;

        Prefs.Changed += OnPrefsChanged;
        UiProgress.Changed += OnProgressChanged;
    }

    private void OnPrefsChanged() =>
        _ = InvokeAsync(StateHasChanged);

    private void OnProgressChanged() =>
        _ = InvokeAsync(StateHasChanged);

    private async Task CopyDiagnosticsAsync()
    {
        copyDiagnosticsMessage = null;
        var diagnostics = $"AnimalTracker | Version {versionLabel} | Started {startedAtLabel} | Runtime {runtimeStamp}";
        try
        {
            var copied = await JS.InvokeAsync<bool>("animalTrackerCopyText", diagnostics);
            copyDiagnosticsMessage = copied
                ? "Diagnostics copied to clipboard."
                : "Copy failed (clipboard permission blocked).";
        }
        catch
        {
            copyDiagnosticsMessage = "Copy failed (clipboard permission blocked).";
        }
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Prefs.Changed -= OnPrefsChanged;
        UiProgress.Changed -= OnProgressChanged;
    }
}
