@inherits LayoutComponentBase
@implements IDisposable
@inject AnimalTracker.State.UserPreferencesState Prefs

<div class="relative min-h-dvh w-full overflow-x-hidden bg-transparent">
    <UiProgressBar />

    <div class="app-layout-shell">
        <aside class="app-layout-sidebar app-surface">
            <NavMenu />
        </aside>

        @* overflow-y visible so position:fixed popovers anchor to the viewport; overflow-x hidden keeps horizontal clip *@
        <main class="app-layout-main app-surface">
            <CascadingValue Name="CompactUi" Value="Prefs.CompactMode">
                <div class="@MainInnerClass">
                    @Body
                </div>
            </CascadingValue>
        </main>
    </div>

    <div class="app-layout-mobile-nav">
        <NavMenu />
    </div>

    <MainLayoutFooter />
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private string MainInnerClass => Prefs.CompactMode
        ? "min-w-0 px-4 py-6 sm:px-5 sm:py-7 md:px-5 md:py-7 lg:px-6 lg:py-8 xl:px-7 xl:py-9"
        : "min-w-0 px-4 py-7 sm:px-6 sm:py-8 md:px-5 md:py-7 lg:px-8 lg:py-10";

    protected override void OnInitialized()
    {
        Prefs.Changed += OnPrefsChanged;
    }

    private void OnPrefsChanged() =>
        _ = InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Prefs.Changed -= OnPrefsChanged;
    }
}
