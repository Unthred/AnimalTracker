@inherits LayoutComponentBase
@implements IDisposable
@inject AnimalTracker.State.UserPreferencesState Prefs

<div class="relative min-h-dvh w-full overflow-x-hidden bg-transparent">
    <div class="mx-auto grid min-h-0 min-w-0 max-w-7xl grid-cols-1 gap-4 px-3 py-4 sm:gap-6 sm:px-4 sm:py-6 md:grid-cols-[minmax(0,17rem)_minmax(0,1fr)] lg:gap-8 lg:px-6 lg:py-8">
        <aside class="h-fit min-w-0 overflow-hidden rounded-2xl border border-slate-200/70 bg-white shadow-card dark:border-slate-800/80 dark:bg-slate-900/50 dark:shadow-none md:sticky md:top-4 md:self-start">
            <NavMenu />
        </aside>

        <main class="min-h-[50vh] min-w-0 overflow-hidden rounded-2xl border border-slate-200/70 bg-white shadow-card dark:border-slate-800/80 dark:bg-slate-900/50 dark:shadow-none">
            <CascadingValue Name="CompactUi" Value="Prefs.CompactMode">
                <div class="@MainInnerClass">
                    @Body
                </div>
            </CascadingValue>
        </main>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private string MainInnerClass => Prefs.CompactMode
        ? "min-w-0 px-4 py-6 sm:px-5 sm:py-7 md:px-6 md:py-8"
        : "min-w-0 px-4 py-7 sm:px-6 sm:py-8 md:px-8 md:py-10";

    protected override void OnInitialized() =>
        Prefs.Changed += OnPrefsChanged;

    private void OnPrefsChanged() =>
        _ = InvokeAsync(StateHasChanged);

    public void Dispose() =>
        Prefs.Changed -= OnPrefsChanged;
}
