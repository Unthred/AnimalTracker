@implements IDisposable
@rendermode InteractiveServer

@inject NavigationManager NavigationManager
@inject AnimalTracker.Services.AdminUserService AdminUsers

<div class="border-b border-slate-300/90 bg-transparent px-5 py-5 dark:border-slate-700/90">
    <a class="text-lg font-bold tracking-tight accent-text transition duration-200 hover:opacity-90" href="">AnimalTracker</a>
    <p class="mt-1 text-xs leading-relaxed text-slate-800 dark:text-slate-400">Sightings &amp; wildlife log</p>
</div>

<div class="px-3 py-4">
    <nav class="flex flex-col gap-1">
        <NavLink class="app-nav-link"
                 href="" Match="NavLinkMatch.All">
            Timeline
        </NavLink>

        <NavLink class="app-nav-link"
                 href="sightings/new">
            Add sighting
        </NavLink>

        <NavLink class="app-nav-link"
                 href="sightings/import">
            Import photos
        </NavLink>

        <NavLink class="app-nav-link"
                 href="animals">
            Animals
        </NavLink>

        <NavLink class="app-nav-link"
                 href="species">
            Species lookup
        </NavLink>

        <NavLink class="app-nav-link"
                 href="stats">
            Stats
        </NavLink>

        <NavLink class="app-nav-link"
                 href="map">
            Map
        </NavLink>

        <NavLink class="app-nav-link"
                 href="settings">
            Settings
        </NavLink>

        <!-- User settings merged into Settings -->

        <AuthorizeView>
            <Authorized Context="auth">
                <div class="mt-4 border-t border-slate-300/90 pt-4 dark:border-slate-700/90">
                    <button type="button"
                            class="app-nav-link flex w-full items-center justify-between text-left"
                            aria-expanded="@(ShowAccountMenu ? "true" : "false")"
                            @onclick="ToggleAccountMenu">
                        <span class="min-w-0 truncate">@auth.User.Identity?.Name</span>
                        <span class="ml-2 text-xs text-slate-400 dark:text-slate-500">@(ShowAccountMenu ? "▾" : "▸")</span>
                    </button>

                    @if (ShowAccountMenu)
                    {
                        <div class="mt-1 ml-2 flex flex-col gap-1">
                            <NavLink class="app-nav-sublink"
                                     href="Account/Manage" Match="NavLinkMatch.All">
                                Profile
                            </NavLink>
                            <NavLink class="app-nav-sublink"
                                     href="Account/Manage/Email">
                                Email
                            </NavLink>
                            <NavLink class="app-nav-sublink"
                                     href="Account/Manage/ChangePassword">
                                Password
                            </NavLink>
                            <NavLink class="app-nav-sublink"
                                     href="Account/Manage/TwoFactorAuthentication">
                                Two-factor authentication
                            </NavLink>
                            <NavLink class="app-nav-sublink"
                                     href="Account/Manage/Passkeys">
                                Passkeys
                            </NavLink>
                            <NavLink class="app-nav-sublink"
                                     href="Account/Manage/PersonalData">
                                Personal data
                            </NavLink>
                            @if (isCurrentUserAdmin)
                            {
                                <NavLink class="app-nav-sublink"
                                         href="admin">
                                    Admin
                                </NavLink>
                            }
                        </div>
                    }

                    <form action="Account/Logout" method="post">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                        <button type="submit" class="app-nav-link w-full text-left">Log out</button>
                    </form>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="mt-4 border-t border-slate-300/90 pt-4 dark:border-slate-700/90">
                    <NavLink class="app-nav-link" href="Account/Register">
                        Register
                    </NavLink>
                    <NavLink class="app-nav-link" href="Account/Login">
                        Login
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    private string? currentUrl;
    private bool accountMenuExpanded;
    private bool isCurrentUserAdmin;

    protected override async Task OnInitializedAsync()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
        await RefreshAdminFlagAsync();
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _ = InvokeAsync(async () =>
        {
            currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
            if (!IsOnAccountPage)
                accountMenuExpanded = false;
            await RefreshAdminFlagAsync();
            StateHasChanged();
        });
    }

    // Keep the email submenu open on account pages and admin (same UX as Manage/* links).
    private bool IsOnAccountPage =>
        !string.IsNullOrWhiteSpace(currentUrl) &&
        (currentUrl.StartsWith("Account/Manage", StringComparison.OrdinalIgnoreCase)
         || currentUrl.Equals("admin", StringComparison.OrdinalIgnoreCase)
         || currentUrl.StartsWith("admin/", StringComparison.OrdinalIgnoreCase));

    private bool ShowAccountMenu => accountMenuExpanded || IsOnAccountPage;

    private void ToggleAccountMenu() =>
        accountMenuExpanded = !accountMenuExpanded;

    private async Task RefreshAdminFlagAsync()
    {
        try
        {
            isCurrentUserAdmin = await AdminUsers.IsCurrentUserAdminAsync();
        }
        catch
        {
            isCurrentUserAdmin = false;
        }
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}

