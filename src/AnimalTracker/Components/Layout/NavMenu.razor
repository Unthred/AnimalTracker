@implements IDisposable
@rendermode InteractiveServer

@inject NavigationManager NavigationManager

<div class="border-b border-slate-200/80 bg-white px-5 py-5 dark:border-slate-800/80 dark:bg-slate-900/0">
    <a class="text-lg font-bold tracking-tight accent-text transition duration-200 hover:opacity-90" href="">AnimalTracker</a>
    <p class="mt-1 text-xs leading-relaxed text-slate-500 dark:text-slate-400">Sightings &amp; wildlife log</p>
</div>

<div class="px-3 py-4">
    <nav class="flex flex-col gap-1">
        <NavLink class="app-nav-link"
                 href="" Match="NavLinkMatch.All">
            Timeline
        </NavLink>

        <NavLink class="app-nav-link"
                 href="sightings/new">
            Add sighting
        </NavLink>

        <NavLink class="app-nav-link"
                 href="animals">
            Animals
        </NavLink>

        <NavLink class="app-nav-link"
                 href="stats">
            Stats
        </NavLink>

        <NavLink class="app-nav-link"
                 href="settings">
            Settings
        </NavLink>

        <!-- User settings merged into Settings -->

        <AuthorizeView>
            <Authorized Context="auth">
                <div class="mt-4 border-t border-slate-200/80 pt-4 dark:border-slate-800/80">
                    <button type="button"
                            class="app-nav-link flex w-full items-center justify-between text-left"
                            aria-expanded="@(ShowAccountMenu ? "true" : "false")"
                            @onclick="ToggleAccountMenu">
                        <span class="min-w-0 truncate">@auth.User.Identity?.Name</span>
                        <span class="ml-2 text-xs text-slate-400 dark:text-slate-500">@(ShowAccountMenu ? "▾" : "▸")</span>
                    </button>

                    @if (ShowAccountMenu)
                    {
                        <div class="mt-1 ml-2 flex flex-col gap-1">
                            <NavLink class="app-nav-sublink"
                                     href="Account/Manage" Match="NavLinkMatch.All">
                                Profile
                            </NavLink>
                            <NavLink class="app-nav-sublink"
                                     href="Account/Manage/Email">
                                Email
                            </NavLink>
                            <NavLink class="app-nav-sublink"
                                     href="Account/Manage/ChangePassword">
                                Password
                            </NavLink>
                            <NavLink class="app-nav-sublink"
                                     href="Account/Manage/TwoFactorAuthentication">
                                Two-factor authentication
                            </NavLink>
                            <NavLink class="app-nav-sublink"
                                     href="Account/Manage/Passkeys">
                                Passkeys
                            </NavLink>
                            <NavLink class="app-nav-sublink"
                                     href="Account/Manage/PersonalData">
                                Personal data
                            </NavLink>
                        </div>
                    }

                    <AuthorizeView Roles="AnimalTracker.Services.AdminUserService.AdminRoleName" Context="adminAuth">
                        <div class="mt-3 border-t border-slate-200/80 pt-3 dark:border-slate-800/80">
                            <NavLink class="app-nav-link"
                                     href="admin">
                                Admin
                            </NavLink>
                        </div>
                    </AuthorizeView>

                    <form action="Account/Logout" method="post">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                        <UIButton Type="submit" Variant="UiButtonVariant.Ghost" Class="w-full justify-start font-medium">
                            Log out
                        </UIButton>
                    </form>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="mt-4 border-t border-slate-200/80 pt-4 dark:border-slate-800/80">
                    <NavLink class="app-nav-link" href="Account/Register">
                        Register
                    </NavLink>
                    <NavLink class="app-nav-link" href="Account/Login">
                        Login
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    private string? currentUrl;
    private bool accountMenuExpanded;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        if (!IsOnAccountPage)
            accountMenuExpanded = false;
        StateHasChanged();
    }

    private bool IsOnAccountPage =>
        !string.IsNullOrWhiteSpace(currentUrl) &&
        currentUrl.StartsWith("Account/Manage", StringComparison.OrdinalIgnoreCase);

    private bool ShowAccountMenu => accountMenuExpanded || IsOnAccountPage;

    private void ToggleAccountMenu() =>
        accountMenuExpanded = !accountMenuExpanded;

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}

