@code {
    private string? currentUrl;
    private bool accountMenuExpanded;
    private bool isCurrentUserAdmin;
    private bool mobileMoreOpen;

    protected override async Task OnInitializedAsync()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
        await RefreshAdminFlagAsync();
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _ = InvokeAsync(async () =>
        {
            currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
            mobileMoreOpen = false;
            if (!IsOnAccountPage)
                accountMenuExpanded = false;
            await RefreshAdminFlagAsync();
            StateHasChanged();
        });
    }

    // Keep the email submenu open on account pages and admin (same UX as Manage/* links).
    private bool IsOnAccountPage =>
        !string.IsNullOrWhiteSpace(currentUrl) &&
        (currentUrl.StartsWith("Account/Manage", StringComparison.OrdinalIgnoreCase)
         || currentUrl.Equals("admin", StringComparison.OrdinalIgnoreCase)
         || currentUrl.StartsWith("admin/", StringComparison.OrdinalIgnoreCase));

    private bool ShowAccountMenu => accountMenuExpanded || IsOnAccountPage;

    private bool IsMobileMoreActive =>
        IsRouteOrChild("stats") ||
        IsRouteOrChild("sightings/import") ||
        IsRouteOrChild("species") ||
        IsRouteOrChild("settings") ||
        IsRouteOrChild("Account/Manage") ||
        IsRouteOrChild("admin");

    private void ToggleAccountMenu() =>
        accountMenuExpanded = !accountMenuExpanded;

    private void ToggleMobileMore() =>
        mobileMoreOpen = !mobileMoreOpen;

    private void CloseMobileMore() =>
        mobileMoreOpen = false;

    private bool IsRouteOrChild(string route)
    {
        var current = NormalizeRoute(currentUrl);
        var target = NormalizeRoute(route);

        return current.Equals(target, StringComparison.OrdinalIgnoreCase)
            || current.StartsWith($"{target}/", StringComparison.OrdinalIgnoreCase);
    }

    private static string NormalizeRoute(string? route) =>
        (route ?? string.Empty).Trim().Trim('/');

    private async Task RefreshAdminFlagAsync()
    {
        try
        {
            isCurrentUserAdmin = await AdminUsers.IsCurrentUserAdminAsync();
        }
        catch
        {
            isCurrentUserAdmin = false;
        }
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}

