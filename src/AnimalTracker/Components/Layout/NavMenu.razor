            <NavLink class="app-nav-link"
                     href="" Match="NavLinkMatch.All">
                Timeline
            </NavLink>

            <NavLink class="app-nav-link"
                     href="sightings/new">
                Add sighting
            </NavLink>

            <NavLink class="app-nav-link"
                     href="sightings/import">
                Import photos
            </NavLink>

            <NavLink class="app-nav-link"
                     href="animals">
                Animals
            </NavLink>

            <NavLink class="app-nav-link"
                     href="species">
                Species lookup
            </NavLink>

            <NavLink class="app-nav-link"
                     href="stats">
                Stats
            </NavLink>

            <NavLink class="app-nav-link"
                     href="map">
                Map
            </NavLink>

            <NavLink class="app-nav-link"
                     href="settings">
                Settings
            </NavLink>

            <AuthorizeView>
                <Authorized Context="auth">
                    <div class="mt-4 border-t border-slate-300/90 pt-4 dark:border-slate-700/90">
                        <button type="button"
                                class="app-nav-link flex w-full items-center justify-between text-left"
                                aria-expanded="@(ShowAccountMenu ? "true" : "false")"
                                @onclick="ToggleAccountMenu">
                            <span class="min-w-0 truncate">@auth.User.Identity?.Name</span>
                            <span class="ml-2 text-xs text-slate-400 dark:text-slate-500">@(ShowAccountMenu ? "▾" : "▸")</span>
