@implements IDisposable

@inject NavigationManager NavigationManager

<div class="border-b border-slate-200/80 bg-white px-5 py-5 dark:border-slate-800/80 dark:bg-slate-900/0">
    <a class="text-lg font-bold tracking-tight accent-text transition duration-200 hover:opacity-90" href="">AnimalTracker</a>
    <p class="mt-1 text-xs leading-relaxed text-slate-500 dark:text-slate-400">Sightings &amp; wildlife log</p>
</div>

<div class="px-3 py-4">
    <nav class="flex flex-col gap-1">
        <NavLink class="app-nav-link"
                 href="" Match="NavLinkMatch.All">
            Timeline
        </NavLink>

        <NavLink class="app-nav-link"
                 href="sightings/new">
            Add sighting
        </NavLink>

        <NavLink class="app-nav-link"
                 href="animals">
            Animals
        </NavLink>

        <NavLink class="app-nav-link"
                 href="stats">
            Stats
        </NavLink>

        <NavLink class="app-nav-link"
                 href="settings">
            Settings
        </NavLink>

        <!-- User settings merged into Settings -->

        <AuthorizeView>
            <Authorized>
                <div class="mt-4 border-t border-slate-200/80 pt-4 dark:border-slate-800/80">
                    <NavLink class="app-nav-link"
                             href="Account/Manage">
                        @context.User.Identity?.Name
                    </NavLink>

                    <form action="Account/Logout" method="post">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                        <UIButton Type="submit" Variant="UiButtonVariant.Ghost" Class="w-full justify-start font-medium">
                            Log out
                        </UIButton>
                    </form>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="mt-4 border-t border-slate-200/80 pt-4 dark:border-slate-800/80">
                    <NavLink class="app-nav-link" href="Account/Register">
                        Register
                    </NavLink>
                    <NavLink class="app-nav-link" href="Account/Login">
                        Login
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    private string? currentUrl;

    protected override void OnInitialized()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}

