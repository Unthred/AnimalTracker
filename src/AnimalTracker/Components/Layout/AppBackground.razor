@rendermode InteractiveServer
@implements IDisposable

@inject AnimalTracker.State.UserPreferencesState Prefs

@if (HasAnyBackground)
{
    <div class="pointer-events-none fixed inset-0 -z-30 bg-cover bg-center bg-no-repeat"
         style="@BackgroundImageStyle"></div>
    <div class="pointer-events-none fixed inset-0 -z-20 bg-slate-50/88 dark:bg-slate-950/86"></div>
}
else
{
    <div class="pointer-events-none fixed inset-0 -z-30 bg-slate-50 dark:bg-slate-950"></div>
}

@code {
    private bool HasAnyBackground =>
        !string.IsNullOrWhiteSpace(Prefs.TemporaryBackgroundUrl) ||
        !string.IsNullOrWhiteSpace(Prefs.BackgroundImageRelativePath);

    private string BackgroundImageStyle =>
        !string.IsNullOrWhiteSpace(Prefs.TemporaryBackgroundUrl)
            ? $"background-image: url('{Prefs.TemporaryBackgroundUrl}');"
            : $"background-image: url('/user/background-image?t={Prefs.UiStamp}');";

    // Background layers intentionally use NEGATIVE z-index:
    // - html/body are transparent (see app.css), so fixed layers can paint behind the app.
    // - this avoids fragile "always keep content above" stacking across layouts/pages.

    protected override void OnInitialized() =>
        Prefs.Changed += OnPrefsChanged;

    private void OnPrefsChanged() =>
        _ = InvokeAsync(StateHasChanged);

    public void Dispose() =>
        Prefs.Changed -= OnPrefsChanged;
}

