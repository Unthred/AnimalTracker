@page "/Account/Login"

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Identity
@using AnimalTracker.Data
@using Microsoft.EntityFrameworkCore

@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject ILogger<Login> Logger
@inject NavigationManager NavigationManager
@inject IdentityRedirectManager RedirectManager
@inject AnimalTracker.Services.AppSettingsService AppSettings
@inject AnimalTracker.Services.LoginAuditService LoginAudit
@inject ApplicationDbContext Db

<PageTitle>Log in</PageTitle>

@if (hasDefaultAuthImage)
{
    <div class="pointer-events-none fixed inset-0 -z-20 bg-cover bg-center bg-no-repeat" style="@DefaultAuthBackgroundStyle"></div>
    <div class="pointer-events-none fixed inset-0 -z-10 bg-slate-50/84 dark:bg-slate-950/82"></div>
}
else
{
    <div class="pointer-events-none fixed inset-0 -z-20 bg-gradient-to-br from-slate-50 via-white to-slate-100 dark:from-slate-950 dark:via-slate-950 dark:to-slate-900"></div>
}
<div class="pointer-events-none fixed inset-0 -z-10 opacity-60 [background:radial-gradient(600px_circle_at_20%_10%,color-mix(in_srgb,var(--accent)_18%,transparent),transparent_55%),radial-gradient(600px_circle_at_80%_20%,rgba(99,102,241,0.18),transparent_55%)]"></div>

<div class="mx-auto w-full max-w-xl py-8 sm:py-14">
    <UIPageHeader Title="Log in" Description="Welcome back. Sign in to continue." />

    <UICard>
        <StatusMessage Message="@errorMessage" />

        @if (!string.IsNullOrWhiteSpace(resendConfirmationEmail))
        {
            <UIAlert Variant="UiAlertVariant.Warning" Class="mb-6">
                <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                    <div>
                        This account has not confirmed its email yet. Request a new confirmation email for
                        <span class="font-semibold">@resendConfirmationEmail</span>.
                    </div>
                    <UIButton Href="@(NavigationManager.GetUriWithQueryParameters("Account/ResendEmailConfirmation", new Dictionary<string, object?> { ["email"] = resendConfirmationEmail }))"
                              Variant="UiButtonVariant.Outline"
                              Size="UiButtonSize.Sm"
                              Class="w-full shrink-0 sm:w-auto">
                        Resend confirmation
                    </UIButton>
                </div>
            </UIAlert>
        }

        <EditForm EditContext="editContext" method="post" OnSubmit="LoginUser" FormName="login" class="space-y-6">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" role="alert" />

            <UIField Label="Email" For="Input.Email">
                <InputText @bind-Value="Input.Email" id="Input.Email"
                           class="w-full min-w-0 rounded-xl border border-slate-200/90 bg-white px-3 py-2.5 text-sm shadow-sm transition duration-200 ease-in-out hover:border-slate-300 hover:shadow-sm focus:border-slate-300 focus:outline-none focus:ring-4 focus:ring-slate-200/70 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-50 dark:hover:border-slate-600 dark:focus:ring-slate-800/80"
                           autocomplete="username webauthn" aria-required="true" placeholder="name@example.com" />
                <ValidationMessage For="() => Input.Email" class="text-danger" />
            </UIField>

            <UIField Label="Password" For="Input.Password">
                <InputText type="password" @bind-Value="Input.Password" id="Input.Password"
                           class="w-full min-w-0 rounded-xl border border-slate-200/90 bg-white px-3 py-2.5 text-sm shadow-sm transition duration-200 ease-in-out hover:border-slate-300 hover:shadow-sm focus:border-slate-300 focus:outline-none focus:ring-4 focus:ring-slate-200/70 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-50 dark:hover:border-slate-600 dark:focus:ring-slate-800/80"
                           autocomplete="current-password" aria-required="true" placeholder="••••••••" />
                <ValidationMessage For="() => Input.Password" class="text-danger" />
            </UIField>

            <label class="inline-flex cursor-pointer items-center gap-3 text-base text-slate-700 dark:text-slate-200 sm:text-sm">
                <InputCheckbox @bind-Value="Input.RememberMe" class="checkbox-soft size-[1.125rem]" />
                Remember me
            </label>

            <UIButton Type="submit" Variant="UiButtonVariant.Primary" Class="w-full">Log in</UIButton>

            <div class="flex items-center gap-3">
                <div class="h-px flex-1 bg-slate-200/80 dark:bg-slate-800/80"></div>
                <div class="text-sm font-medium text-slate-500 dark:text-slate-400 sm:text-xs">OR</div>
                <div class="h-px flex-1 bg-slate-200/80 dark:bg-slate-800/80"></div>
            </div>

            <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
                <PasskeySubmit Operation="PasskeyOperation.Request" Name="Input.Passkey" EmailName="Input.Email"
                              class="btn w-full text-base sm:w-auto sm:text-sm">Log in with a passkey</PasskeySubmit>
                <a class="btn w-full text-center text-base sm:w-auto sm:text-sm" href="Account/ForgotPassword">Forgot password</a>
            </div>

            <div class="text-base text-slate-600 dark:text-slate-300 sm:text-sm">
                <a class="font-medium text-slate-900 hover:underline dark:text-slate-50"
                   href="@(NavigationManager.GetUriWithQueryParameters("Account/Register", new Dictionary<string, object?> { ["ReturnUrl"] = ReturnUrl }))">Create an account</a>
                <span class="mx-2 text-slate-400">·</span>
                <a class="hover:underline" href="Account/ResendEmailConfirmation">Resend confirmation</a>
            </div>
        </EditForm>
    </UICard>

    @* External providers not used for this app *@
</div>

@code {
    private string? errorMessage;
    private string? resendConfirmationEmail;
    private EditContext editContext = default!;
    private bool hasDefaultAuthImage;
    private long defaultAuthImageStamp;
    private string DefaultAuthBackgroundStyle => $"""background-image: url('/app/default-auth-image?t={defaultAuthImageStamp}');""";

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = default!;

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Input ??= new();

        editContext = new EditContext(Input);

        var appDefaults = await AppSettings.GetOrCreateAsync();
        hasDefaultAuthImage = !string.IsNullOrWhiteSpace(appDefaults.DefaultAuthImageRelativePath);
        defaultAuthImageStamp = appDefaults.UpdatedAtUtc.Ticks;

        if (HttpMethods.IsGet(HttpContext.Request.Method))
        {
            // Clear the existing external cookie to ensure a clean login process
            await HttpContext.SignOutAsync(IdentityConstants.ExternalScheme);
        }
    }

    public async Task LoginUser()
    {
        resendConfirmationEmail = null;

        if (!string.IsNullOrEmpty(Input.Passkey?.Error))
        {
            errorMessage = $"Error: {Input.Passkey.Error}";
            return;
        }

        SignInResult result;
        if (!string.IsNullOrEmpty(Input.Passkey?.CredentialJson))
        {
            // When performing passkey sign-in, don't perform form validation.
            result = await SignInManager.PasskeySignInAsync(Input.Passkey.CredentialJson);
        }
        else
        {
            // If doing a password sign-in, validate the form.
            if (!editContext.Validate())
            {
                return;
            }

            result = await SignInManager.PasswordSignInAsync(Input.Email, Input.Password, Input.RememberMe, lockoutOnFailure: true);
        }

        if (result.Succeeded)
        {
            Logger.LogInformation("User logged in.");
            var user = await SignInManager.UserManager.GetUserAsync(HttpContext.User);
            if (user is null && !string.IsNullOrWhiteSpace(Input.Email))
                user = await UserManager.FindByEmailAsync(Input.Email);
            if (user is not null)
                await LoginAudit.RecordSuccessfulLoginAsync(user);
            await SetThemeCookieForSignedInUserAsync();
            RedirectManager.RedirectTo(ReturnUrl);
        }
        else if (result.RequiresTwoFactor)
        {
            RedirectManager.RedirectTo(
                "Account/LoginWith2fa",
                new() { ["returnUrl"] = ReturnUrl, ["rememberMe"] = Input.RememberMe });
        }
        else if (result.IsLockedOut)
        {
            Logger.LogWarning("User account locked out.");
            RedirectManager.RedirectTo("Account/Lockout");
        }
        else
        {
            var user = await UserManager.FindByEmailAsync(Input.Email);
            if (result.IsNotAllowed && user is not null && !await UserManager.IsEmailConfirmedAsync(user))
            {
                resendConfirmationEmail = user.Email;
                errorMessage = "Error: You must confirm your email before you can log in.";
            }
            else
            // Provide a more actionable message in Development without leaking details in production.
            {
                if (HttpContext.RequestServices.GetRequiredService<IHostEnvironment>().IsDevelopment())
                {
                    errorMessage = user is null
                        ? "Error: Invalid login attempt. (No user found for that email.)"
                        : result.IsNotAllowed
                            ? "Error: Sign-in not allowed for this account."
                            : result.RequiresTwoFactor
                                ? "Error: Two-factor authentication is required."
                                : result.IsLockedOut
                                    ? "Error: Account is locked out."
                                    : "Error: Invalid login attempt. (Wrong password?)";
                }
                else
                {
                    errorMessage = "Error: Invalid login attempt.";
                }
            }

            Logger.LogWarning("Login failed for email {Email}. Succeeded={Succeeded} NotAllowed={NotAllowed} LockedOut={LockedOut} Requires2FA={RequiresTwoFactor}",
                Input.Email, result.Succeeded, result.IsNotAllowed, result.IsLockedOut, result.RequiresTwoFactor);
        }
    }

    private sealed class InputModel
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = "";

        [Required]
        [DataType(DataType.Password)]
        public string Password { get; set; } = "";

        [Display(Name = "Remember me?")]
        public bool RememberMe { get; set; }

        public PasskeyInputModel? Passkey { get; set; }
    }

    private async Task SetThemeCookieForSignedInUserAsync()
    {
        var fallback = (await AppSettings.GetOrCreateAsync()).DefaultThemeMode;
        var themeMode = NormalizeThemeMode(fallback);

        var user = await UserManager.FindByEmailAsync(Input.Email);
        if (user is not null)
        {
            var userTheme = await Db.UserSettings.AsNoTracking()
                .Where(x => x.OwnerUserId == user.Id)
                .Select(x => x.ThemeMode)
                .FirstOrDefaultAsync();

            if (!string.IsNullOrWhiteSpace(userTheme))
                themeMode = NormalizeThemeMode(userTheme);
        }

        HttpContext.Response.Cookies.Append("animaltracker_theme", themeMode, new CookieOptions
        {
            Path = "/",
            SameSite = SameSiteMode.Lax,
            HttpOnly = false,
            IsEssential = true,
            MaxAge = TimeSpan.FromDays(180),
            Secure = HttpContext.Request.IsHttps
        });
    }

    private static string NormalizeThemeMode(string? mode)
    {
        var normalized = (mode ?? "").Trim().ToLowerInvariant();
        return normalized is "light" or "dark" ? normalized : "system";
    }
}
