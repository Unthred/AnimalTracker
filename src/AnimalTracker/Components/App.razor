<!DOCTYPE html>
@inject IHttpContextAccessor HttpContextAccessor
@{
    var resolvedTheme = HttpContextAccessor.HttpContext?.Items["animaltracker_resolved_theme"]?.ToString();
    var themeCookie = HttpContextAccessor.HttpContext?.Request.Cookies["animaltracker_theme"];
    var rawInitialTheme = !string.IsNullOrWhiteSpace(resolvedTheme) ? resolvedTheme : themeCookie;
    var initialTheme = string.Equals(rawInitialTheme, "dark", StringComparison.OrdinalIgnoreCase)
        ? "dark"
        : string.Equals(rawInitialTheme, "light", StringComparison.OrdinalIgnoreCase)
            ? "light"
            : "system";
    var initialHtmlClass = string.Equals(initialTheme, "dark", StringComparison.OrdinalIgnoreCase) ? "dark" : "";
}
<html lang="en" class="@initialHtmlClass" data-initial-theme="@initialTheme">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <script>
        // First-paint theme bootstrap: run before CSS so full page loads
        // (including /Account pages) start in the correct palette.
        (() => {
            try {
                const serverTheme = (document.documentElement?.dataset?.initialTheme || '').toLowerCase();
                const readCookie = (name) => {
                    const prefix = name + '=';
                    const parts = document.cookie.split(';');
                    for (const p of parts) {
                        const s = p.trim();
                        if (s.startsWith(prefix)) return decodeURIComponent(s.substring(prefix.length));
                    }
                    return null;
                };
                const mode = (serverTheme || readCookie('animaltracker_theme') || 'system').toLowerCase();
                const prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
                const dark = mode === 'dark' || (mode === 'system' && prefersDark);
                document.documentElement.classList.toggle('dark', !!dark);
            } catch { /* ignore */ }
        })();
    </script>
    <ResourcePreloader />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <link rel="stylesheet" href="/css/app.generated.css" />
    <link rel="stylesheet" href="@Assets["AnimalTracker.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet />
</head>

<body>
    <AppBackground />
    <UserTheme />
    <Routes />
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]"
            onerror="this.onerror=null;this.src='@Assets["_framework/blazor.server.js"]'"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js" crossorigin="anonymous"></script>
    <script src="/js/stats-charts.js"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script src="/js/sightings-map.js"></script>
    <script src="@Assets["Components/Account/Shared/PasskeySubmit.razor.js"]" type="module"></script>
    <script>
        // Theme mode: "system" | "light" | "dark"
        // Tailwind uses darkMode: 'class', so we toggle documentElement.classList.
        const animalTrackerThemeCookieName = 'animaltracker_theme';
        const animalTrackerReadCookie = (name) => {
            try {
                const prefix = name + '=';
                const parts = document.cookie.split(';');
                for (const p of parts) {
                    const s = p.trim();
                    if (s.startsWith(prefix)) return decodeURIComponent(s.substring(prefix.length));
                }
            } catch { /* ignore */ }
            return null;
        };
        const animalTrackerWriteCookie = (name, value) => {
            try {
                // 180 days
                document.cookie = `${name}=${encodeURIComponent(value)}; Path=/; Max-Age=${180 * 24 * 60 * 60}; SameSite=Lax`;
            } catch { /* ignore */ }
        };
        window.animalTrackerResolveDark = (mode) => {
            try {
                const m = (mode || 'system').toLowerCase();
                const prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
                return (m === 'dark') || (m === 'system' && prefersDark);
            } catch {
                return false;
            }
        };
        window.animalTrackerIsDarkActive = () => {
            try {
                return !!document.documentElement.classList.contains('dark');
            } catch {
                return false;
            }
        };
        window.animalTrackerSetTheme = (mode) => {
            try {
                const root = document.documentElement;
                const m = (mode || 'system').toLowerCase();
                const dark = window.animalTrackerResolveDark(m);
                root.classList.toggle('dark', !!dark);
                // Persist so full-page navigations keep the same theme.
                animalTrackerWriteCookie(animalTrackerThemeCookieName, m);
            } catch { /* ignore */ }
        };
        window.animalTrackerGetThemeCookie = () => {
            try {
                return animalTrackerReadCookie(animalTrackerThemeCookieName);
            } catch {
                return null;
            }
        };
        window.animalTrackerGetDebugDrawerOpen = () => {
            try {
                return localStorage.getItem('animaltracker_theme_debug_open') === '1';
            } catch {
                return false;
            }
        };
        window.animalTrackerSetDebugDrawerOpen = (open) => {
            try {
                localStorage.setItem('animaltracker_theme_debug_open', open ? '1' : '0');
            } catch { /* ignore */ }
        };
        window.animalTrackerEnsureTheme = () => {
            try {
                const mode = (window.animalTrackerGetThemeCookie() || 'system').toLowerCase();
                const shouldBeDark = window.animalTrackerResolveDark(mode);
                const root = document.documentElement;
                if (!!root.classList.contains('dark') !== !!shouldBeDark) {
                    root.classList.toggle('dark', !!shouldBeDark);
                }
            } catch { /* ignore */ }
        };
        window.animalTrackerGetCurrentPosition = (timeoutMs) => {
            return new Promise((resolve, reject) => {
                try {
                    if (!navigator.geolocation) {
                        reject("Geolocation is not supported by this browser.");
                        return;
                    }

                    navigator.geolocation.getCurrentPosition(
                        (position) => {
                            resolve({
                                latitude: position.coords.latitude,
                                longitude: position.coords.longitude,
                                accuracy: position.coords.accuracy ?? null
                            });
                        },
                        (error) => {
                            reject(error?.message || "Unable to get current position.");
                        },
                        {
                            enableHighAccuracy: true,
                            timeout: typeof timeoutMs === 'number' ? timeoutMs : 10000,
                            maximumAge: 30000
                        }
                    );
                } catch (e) {
                    reject(e?.message || "Unable to get current position.");
                }
            });
        };
        window.animalTrackerGetLocalTimestamp = () => {
            try {
                const d = new Date();
                let s = d.toLocaleString(undefined, { dateStyle: 'medium', timeStyle: 'medium', timeZoneName: 'long' });
                s = s
                    .replace(/\bBritish Summer Time\b/gi, 'BST')
                    .replace(/\bGreenwich Mean Time\b/gi, 'GMT')
                    .replace(/\bCoordinated Universal Time\b/gi, 'UTC');
                return s;
            } catch {
                try {
                    return new Date().toString();
                } catch {
                    return '';
                }
            }
        };
        window.animalTrackerCopyText = async (value) => {
            try {
                if (navigator.clipboard && navigator.clipboard.writeText) {
                    await navigator.clipboard.writeText(value ?? '');
                    return true;
                }
            } catch {
                // Fall through to legacy method.
            }

            try {
                const input = document.createElement('textarea');
                input.value = value ?? '';
                input.setAttribute('readonly', '');
                input.style.position = 'fixed';
                input.style.left = '-9999px';
                document.body.appendChild(input);
                input.focus();
                input.select();
                const ok = document.execCommand('copy');
                document.body.removeChild(input);
                return !!ok;
            } catch {
                return false;
            }
        };

        // Keep theme stable across enhanced navigation DOM swaps.
        try {
            document.addEventListener('enhancedload', () => {
                window.animalTrackerEnsureTheme();
            });
        } catch { /* ignore */ }

        try {
            const root = document.documentElement;
            const classObserver = new MutationObserver(() => {
                window.animalTrackerEnsureTheme();
            });
            classObserver.observe(root, { attributes: true, attributeFilter: ['class'] });
        } catch { /* ignore */ }

        // Apply immediately from cookie to avoid a flash of wrong theme on full reloads.
        window.animalTrackerSetTheme(animalTrackerReadCookie(animalTrackerThemeCookieName) || 'system');
    </script>
</body>

</html>
