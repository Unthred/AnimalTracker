@page "/Error"
@using System.Diagnostics

<PageTitle>Error</PageTitle>

<div class="min-h-dvh bg-slate-50 px-6 py-12 font-sans leading-relaxed dark:bg-slate-950">
<div class="mx-auto max-w-2xl space-y-6">
    <h1 class="text-2xl font-bold tracking-tight text-red-800 dark:text-red-200">Something went wrong</h1>
    <p class="text-sm text-slate-700 dark:text-slate-300">An error occurred while processing your request.</p>

    @if (ShowRequestId)
    {
        <div class="rounded-xl border border-slate-200/80 bg-slate-50 px-4 py-3 text-sm dark:border-slate-800 dark:bg-slate-900/60">
            <span class="font-medium text-slate-900 dark:text-slate-50">Request ID:</span>
            <code class="ml-2 text-slate-700 dark:text-slate-200">@RequestId</code>
        </div>
    }

    <div class="rounded-xl border border-slate-200/80 bg-white p-6 text-sm text-slate-700 shadow-card dark:border-slate-800 dark:bg-slate-900/50 dark:text-slate-300 dark:shadow-none">
        <h2 class="text-base font-semibold text-slate-900 dark:text-slate-50">Development mode</h2>
        <p class="mt-2">
            Swapping to the <strong>Development</strong> environment displays more detailed information about the error.
        </p>
        <p class="mt-3 font-medium text-slate-900 dark:text-slate-100">
            The Development environment should not be enabled for deployed applications.
        </p>
        <p class="mt-2 text-slate-600 dark:text-slate-400">
            For local debugging, set the <strong>ASPNETCORE_ENVIRONMENT</strong> environment variable to <strong>Development</strong> and restart the app.
        </p>
    </div>
</div>
</div>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
