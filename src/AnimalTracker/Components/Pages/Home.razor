@page "/"
@rendermode InteractiveServer
@implements IDisposable

@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

@using AnimalTracker.Services
@using AnimalTracker.Data.Entities
@inject SightingService Sightings
@inject SpeciesService Species
@inject LocationService Locations
@inject AnimalService Animals
@inject AnimalTracker.State.UserPreferencesState Prefs

<PageTitle>Timeline</PageTitle>

<UIPageHeader Title="Timeline" Description="Recent sightings, newest first.">
    <Actions>
        <UIButton Href="sightings/new" Variant="UiButtonVariant.Primary">Add sighting</UIButton>
    </Actions>
</UIPageHeader>

<UICard Class="mt-2">
    <div class="min-w-0 space-y-6">
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 sm:gap-8 lg:grid-cols-3">
            <UIField Label="Species" For="species">
                <input id="species"
                       list="species-options"
                       class="w-full min-w-0 rounded-xl border border-slate-200/90 bg-white px-3 py-2.5 text-sm shadow-sm transition duration-200 ease-in-out hover:border-slate-300 hover:shadow-sm focus:border-slate-300 focus:outline-none focus:ring-4 focus:ring-slate-200/70 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-50 dark:hover:border-slate-600 dark:focus:ring-slate-800/80"
                       placeholder="All or type to filter"
                       autocomplete="off"
                       value="@selectedSpeciesName"
                       @oninput="OnSpeciesInputAsync" />
                <datalist id="species-options">
                    @foreach (var s in species)
                    {
                        <option value="@s.Name"></option>
                    }
                </datalist>
            </UIField>

            <UIField Label="Location" For="location">
                <input id="location"
                       list="location-options"
                       class="w-full min-w-0 rounded-xl border border-slate-200/90 bg-white px-3 py-2.5 text-sm shadow-sm transition duration-200 ease-in-out hover:border-slate-300 hover:shadow-sm focus:border-slate-300 focus:outline-none focus:ring-4 focus:ring-slate-200/70 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-50 dark:hover:border-slate-600 dark:focus:ring-slate-800/80"
                       placeholder="All or type to filter"
                       autocomplete="off"
                       value="@selectedLocationName"
                       @oninput="OnLocationInputAsync" />
                <datalist id="location-options">
                    @foreach (var l in locations)
                    {
                        <option value="@l.Name"></option>
                    }
                </datalist>
            </UIField>

            <UIField Label="Animal" For="animal">
                <input id="animal"
                       list="animal-options"
                       class="w-full min-w-0 rounded-xl border border-slate-200/90 bg-white px-3 py-2.5 text-sm shadow-sm transition duration-200 ease-in-out hover:border-slate-300 hover:shadow-sm focus:border-slate-300 focus:outline-none focus:ring-4 focus:ring-slate-200/70 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-50 dark:hover:border-slate-600 dark:focus:ring-slate-800/80"
                       placeholder="All or type to filter"
                       autocomplete="off"
                       value="@selectedAnimalLabel"
                       @oninput="OnAnimalInputAsync" />
                <datalist id="animal-options">
                    @foreach (var a in animals)
                    {
                        <option value="@GetAnimalFilterLabel(a)"></option>
                    }
                </datalist>
            </UIField>
        </div>

        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4 sm:items-end sm:gap-8">
            <UIField Label="From date" For="fromDate">
                <UIDatePicker id="fromDate"
                              @bind-NullableValue="fromLocalDate"
                              @bind-NullableValue:after="OnFiltersChangedAsync" />
            </UIField>
            <UIField Label="To date" For="toDate">
                <UIDatePicker id="toDate"
                              @bind-NullableValue="toLocalDate"
                              @bind-NullableValue:after="OnFiltersChangedAsync" />
            </UIField>
            <UIField Label="Max GPS accuracy (m)" For="maxAccuracy">
                <InputNumber id="maxAccuracy"
                             class="w-full min-w-0 rounded-xl border border-slate-200/90 bg-white px-3 py-2.5 text-sm shadow-sm transition duration-200 ease-in-out hover:border-slate-300 hover:shadow-sm focus:border-slate-300 focus:outline-none focus:ring-4 focus:ring-slate-200/70 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-50 dark:hover:border-slate-600 dark:focus:ring-slate-800/80"
                             @bind-Value="maxLocationAccuracyMeters"
                             @bind-Value:after="OnFiltersChangedAsync" />
            </UIField>
            <div class="flex flex-col justify-end">
                <label for="unknownOnly" class="inline-flex cursor-pointer items-center gap-3 text-sm font-medium text-slate-700 dark:text-slate-200">
                    <input id="unknownOnly" type="checkbox"
                           class="checkbox-soft size-[1.125rem] shrink-0"
                           @bind="unknownOnly"
                           @bind:after="OnFiltersChangedAsync" />
                    Unknown only
                </label>
                <p class="mt-2 text-xs leading-relaxed text-slate-500 dark:text-slate-400">Only sightings without a linked animal.</p>
            </div>
        </div>

        <div class="flex flex-col justify-end">
            <label for="coordinatesOnly" class="inline-flex cursor-pointer items-center gap-3 text-sm font-medium text-slate-700 dark:text-slate-200">
                <input id="coordinatesOnly" type="checkbox"
                       class="checkbox-soft size-[1.125rem] shrink-0"
                       @bind="coordinatesOnly"
                       @bind:after="OnFiltersChangedAsync" />
                Coordinates only
            </label>
            <p class="mt-2 text-xs leading-relaxed text-slate-500 dark:text-slate-400">Show only sightings with latitude/longitude for map and territory analysis.</p>
        </div>
    </div>
</UICard>

<div class="mt-6 sm:mt-8">
    @if (loading)
    {
        <p class="text-sm text-slate-600 dark:text-slate-400">Loading…</p>
    }
    else if (sightings.Count == 0)
    {
        <UICard>
            <p class="font-medium text-slate-900 dark:text-slate-50">No sightings yet.</p>
            <p class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-300">Add your first sighting to start tracking.</p>
            <div class="mt-6">
                <UIButton Href="sightings/new" Variant="UiButtonVariant.Primary">Add sighting</UIButton>
            </div>
        </UICard>
    }
    else
    {
        <UICard Title="Sightings" BodyPadding="false">
            <ul class="divide-y divide-slate-200/80 dark:divide-slate-800/80">
                @foreach (var s in sightings)
                {
                    <li class="transition duration-200 ease-in-out hover:bg-slate-50/80 dark:hover:bg-slate-800/40 @(Prefs.CompactMode ? "px-4 py-3" : "px-4 py-4 sm:px-6 sm:py-5")">
                        <div class="flex flex-col gap-3 min-[400px]:flex-row min-[400px]:items-start min-[400px]:justify-between min-[400px]:gap-4">
                            <div class="min-w-0 flex-1">
                                <div class="text-sm font-semibold text-slate-900 dark:text-slate-50">
                                    @s.Species.Name
                                    @if (s.Animal is not null && !string.IsNullOrWhiteSpace(s.Animal.DisplayName))
                                    {
                                        <span class="font-normal text-slate-600 dark:text-slate-300">(@s.Animal.DisplayName)</span>
                                    }
                                </div>
                                <div class="mt-1 text-sm leading-relaxed text-slate-600 dark:text-slate-300">
                                    @s.OccurredAtUtc.ToLocalTime().ToString("g") · @s.Location.Name
                                </div>
                                @if (s.Behavior is not null || (s.Latitude is not null && s.Longitude is not null))
                                {
                                    <div class="mt-2 text-xs text-slate-500 dark:text-slate-400">
                                        @if (s.Behavior is not null)
                                        {
                                            <span>Behavior: @s.Behavior</span>
                                        }
                                        @if (s.Latitude is not null && s.Longitude is not null)
                                        {
                                            <span class="ml-2">GPS: @s.Latitude.Value.ToString("0.00000"), @s.Longitude.Value.ToString("0.00000")</span>
                                        }
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(s.Notes))
                                {
                                    <div class="mt-2 text-sm leading-relaxed text-slate-700 dark:text-slate-200">@s.Notes</div>
                                }
                            </div>

                            <UIButton Href="@($"sightings/{s.Id}")" Variant="UiButtonVariant.Outline" Size="UiButtonSize.Sm"
                                      Class="w-full shrink-0 min-[400px]:w-auto">
                                Details
                            </UIButton>
                        </div>
                    </li>
                }
            </ul>
        </UICard>
    }
</div>

@code {
    private static readonly TimeSpan FilterDebounceDelay = TimeSpan.FromMilliseconds(200);

    private bool loading = true;
    private List<Species> species = [];
    private List<Location> locations = [];
    private List<Animal> animals = [];
    private List<Sighting> sightings = [];
    private CancellationTokenSource? filterDebounceCts;

    private string? selectedSpeciesName;
    private string? selectedLocationName;
    private string? selectedAnimalLabel;
    private int? selectedSpeciesId;
    private int? selectedLocationId;
    private int? selectedAnimalId;
    private DateTime? fromLocalDate;
    private DateTime? toLocalDate;
    private bool coordinatesOnly;
    private double? maxLocationAccuracyMeters;
    private bool unknownOnly;

    protected override void OnInitialized() =>
        Prefs.Changed += OnPrefsChanged;

    public void Dispose()
    {
        Prefs.Changed -= OnPrefsChanged;
        filterDebounceCts?.Cancel();
        filterDebounceCts?.Dispose();
    }

    private void OnPrefsChanged() =>
        _ = InvokeAsync(StateHasChanged);

    protected override async Task OnInitializedAsync()
    {
        species = await Species.GetAllAsync();
        locations = await Locations.GetAllAsync();
        animals = await Animals.SearchAsync(query: null, speciesId: null);
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        loading = true;
        selectedSpeciesId = ResolveSpeciesId(selectedSpeciesName);
        selectedLocationId = ResolveLocationId(selectedLocationName);
        selectedAnimalId = ResolveAnimalId(selectedAnimalLabel);

        DateTime? fromUtc = fromLocalDate.HasValue
            ? DateTime.SpecifyKind(fromLocalDate.Value.Date, DateTimeKind.Local).ToUniversalTime()
            : null;
        DateTime? toUtc = toLocalDate.HasValue
            ? DateTime.SpecifyKind(toLocalDate.Value.Date.AddDays(1).AddTicks(-1), DateTimeKind.Local).ToUniversalTime()
            : null;
        var filters = new SightingFilters(
            FromUtc: fromUtc,
            ToUtc: toUtc,
            SpeciesId: selectedSpeciesId,
            LocationId: selectedLocationId,
            AnimalId: selectedAnimalId,
            UnknownOnly: unknownOnly,
            WithCoordinatesOnly: coordinatesOnly,
            MaxLocationAccuracyMeters: maxLocationAccuracyMeters);

        var take = Prefs.TimelinePageSize is > 0 and <= 200 ? Prefs.TimelinePageSize : 50;
        sightings = await Sightings.GetRecentAsync(take, filters);
        loading = false;
    }

    private int? ResolveSpeciesId(string? speciesName)
    {
        var name = (speciesName ?? "").Trim();
        if (string.IsNullOrWhiteSpace(name))
            return null;

        return species.FirstOrDefault(x => string.Equals(x.Name, name, StringComparison.OrdinalIgnoreCase))?.Id;
    }

    private int? ResolveLocationId(string? locationName)
    {
        var name = (locationName ?? "").Trim();
        if (string.IsNullOrWhiteSpace(name))
            return null;

        return locations.FirstOrDefault(x => string.Equals(x.Name, name, StringComparison.OrdinalIgnoreCase))?.Id;
    }

    private int? ResolveAnimalId(string? animalLabel)
    {
        var label = (animalLabel ?? "").Trim();
        if (string.IsNullOrWhiteSpace(label))
            return null;

        var byDisplay = animals.FirstOrDefault(x =>
            string.Equals(GetAnimalFilterLabel(x), label, StringComparison.OrdinalIgnoreCase));
        if (byDisplay is not null)
            return byDisplay.Id;

        return null;
    }

    private async Task OnSpeciesInputAsync(ChangeEventArgs e)
    {
        selectedSpeciesName = e.Value?.ToString();
        await ScheduleReloadAsync();
    }

    private async Task OnLocationInputAsync(ChangeEventArgs e)
    {
        selectedLocationName = e.Value?.ToString();
        await ScheduleReloadAsync();
    }

    private async Task OnAnimalInputAsync(ChangeEventArgs e)
    {
        selectedAnimalLabel = e.Value?.ToString();
        await ScheduleReloadAsync();
    }

    private Task OnFiltersChangedAsync() => ScheduleReloadAsync();

    private static string GetAnimalFilterLabel(Animal a) =>
        !string.IsNullOrWhiteSpace(a.DisplayName) ? a.DisplayName : $"Animal #{a.Id} · {a.Species.Name}";

    private async Task ScheduleReloadAsync()
    {
        filterDebounceCts?.Cancel();
        filterDebounceCts?.Dispose();

        var cts = new CancellationTokenSource();
        filterDebounceCts = cts;
        try
        {
            await Task.Delay(FilterDebounceDelay, cts.Token);
            if (!cts.IsCancellationRequested)
                await ReloadAsync();
        }
        catch (OperationCanceledException)
        {
            // Expected when new input supersedes a pending filter refresh.
        }
        finally
        {
            if (ReferenceEquals(filterDebounceCts, cts))
            {
                filterDebounceCts = null;
                cts.Dispose();
            }
        }
    }
}
