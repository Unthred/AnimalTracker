@page "/"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

@using AnimalTracker.Services
@using AnimalTracker.Data.Entities
@inject SightingService Sightings
@inject SpeciesService Species
@inject LocationService Locations
@inject AnimalTracker.State.UserPreferencesState Prefs

<PageTitle>Timeline</PageTitle>

<div class="flex items-center justify-between gap-3">
    <div>
        <h2 class="text-lg font-semibold text-slate-900">Timeline</h2>
        <p class="text-sm text-slate-600">Recent sightings (newest first).</p>
    </div>

    <a class="btn btn-primary"
       href="sightings/new">
        Add sighting
    </a>
</div>

<div class="mt-4 grid grid-cols-1 gap-3 md:grid-cols-3">
    <div>
        <label class="block text-sm font-medium text-slate-700" for="species">Species</label>
        <select id="species" class="mt-1 w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm"
                @bind="selectedSpeciesId">
            <option value="">All</option>
            @foreach (var s in species)
            {
                <option value="@s.Id">@s.Name</option>
            }
        </select>
    </div>

    <div>
        <label class="block text-sm font-medium text-slate-700" for="location">Location</label>
        <select id="location" class="mt-1 w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-sm"
                @bind="selectedLocationId">
            <option value="">All</option>
            @foreach (var l in locations)
            {
                <option value="@l.Id">@l.Name</option>
            }
        </select>
    </div>

    <div class="flex items-end gap-3">
        <label class="inline-flex items-center gap-2 text-sm text-slate-700">
            <input type="checkbox" class="h-4 w-4 rounded border-slate-300" @bind="unknownOnly" />
            Unknown only
        </label>
        <button class="ml-auto inline-flex items-center rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100 dark:hover:bg-slate-800"
                @onclick="ReloadAsync">
            Apply
        </button>
    </div>
</div>

<div class="mt-6">
    @if (loading)
    {
        <p class="text-sm text-slate-600">Loading…</p>
    }
    else if (sightings.Count == 0)
    {
        <div class="rounded-lg border border-slate-200 bg-slate-50 p-4">
            <p class="text-sm text-slate-700">No sightings yet.</p>
            <p class="mt-1 text-sm text-slate-600">Add your first sighting to start tracking.</p>
        </div>
    }
    else
    {
        <ul class="divide-y divide-slate-200 rounded-lg border border-slate-200 dark:divide-slate-800 dark:border-slate-800">
            @foreach (var s in sightings)
            {
                <li class="hover:bg-slate-50 dark:hover:bg-slate-800/50 @(Prefs.CompactMode ? "p-2" : "p-4")">
                    <div class="flex items-start justify-between gap-4">
                        <div>
                            <div class="text-sm font-semibold text-slate-900 dark:text-slate-50">
                                @s.Species.Name
                                @if (s.Animal is not null && !string.IsNullOrWhiteSpace(s.Animal.DisplayName))
                                {
                                    <span class="text-slate-600 dark:text-slate-300">(@s.Animal.DisplayName)</span>
                                }
                            </div>
                            <div class="mt-1 text-sm text-slate-600 dark:text-slate-300">
                                @s.OccurredAtUtc.ToLocalTime().ToString("g") · @s.Location.Name
                            </div>
                            @if (!string.IsNullOrWhiteSpace(s.Notes))
                            {
                                <div class="mt-2 text-sm text-slate-700 dark:text-slate-200">@s.Notes</div>
                            }
                        </div>

                        <a class="text-sm font-medium text-slate-700 hover:text-slate-900 dark:text-slate-200 dark:hover:text-slate-50"
                           href="@($"sightings/{s.Id}")">
                            Details
                        </a>
                    </div>
                </li>
            }
        </ul>
    }
</div>

@code
{
    private bool loading = true;
    private List<Species> species = [];
    private List<Location> locations = [];
    private List<Sighting> sightings = [];

    private int? selectedSpeciesId;
    private int? selectedLocationId;
    private bool unknownOnly;

    protected override async Task OnInitializedAsync()
    {
        species = await Species.GetAllAsync();
        locations = await Locations.GetAllAsync();
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        loading = true;
        var filters = new SightingFilters(
            FromUtc: null,
            ToUtc: null,
            SpeciesId: selectedSpeciesId,
            LocationId: selectedLocationId,
            AnimalId: null,
            UnknownOnly: unknownOnly);

        var take = Prefs.TimelinePageSize is > 0 and <= 200 ? Prefs.TimelinePageSize : 50;
        sightings = await Sightings.GetRecentAsync(take, filters);
        loading = false;
    }
}
