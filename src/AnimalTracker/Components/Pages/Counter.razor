@page "/stats"
@rendermode InteractiveServer
@implements IAsyncDisposable

@using System.Globalization
@using Microsoft.AspNetCore.Authorization
@using Microsoft.JSInterop
@attribute [Authorize]

@using AnimalTracker.Services
@using AnimalTracker.Data.Entities
@inject TerritoryInsightsService Insights
@inject StatsService Stats
@inject IJSRuntime JS

<PageTitle>Stats</PageTitle>

<UIPageHeader Title="Stats" Description="Charts, mix breakdowns, and an activity heat map for your sightings.">
    <Actions>
        <UIButton Href="/map" Variant="UiButtonVariant.Outline">Open map</UIButton>
    </Actions>
</UIPageHeader>

<UICard Class="relative z-20 mt-2">
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
        <UIField Label="From date" For="fromDate">
            <UIDatePicker id="fromDate"
                          @bind-NullableValue="fromLocalDate"
                          @bind-NullableValue:after="ReloadAsync" />
        </UIField>
        <UIField Label="To date" For="toDate">
            <UIDatePicker id="toDate"
                          @bind-NullableValue="toLocalDate"
                          @bind-NullableValue:after="ReloadAsync" />
        </UIField>
    </div>
</UICard>

@if (loading)
{
    <p class="mt-6 text-sm text-slate-600 dark:text-slate-400">Loading…</p>
}
else
{
    <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <StatHighlightCard Title="Sightings"
                           Value="@summary.TotalSightings.ToString("N0")"
                           Subtitle="@($"{summary.DistinctSpeciesCount} species")"
                           AccentBorder="border-l-4 border-sky-500" />
        <StatHighlightCard Title="Photos"
                           Value="@summary.TotalPhotos.ToString("N0")"
                           Subtitle="In selected range"
                           AccentBorder="border-l-4 border-violet-500" />
        <StatHighlightCard Title="Geotagged"
                           Value="@summary.GeotaggedSightings.ToString("N0")"
                           Subtitle="@GeotaggedSubtitle"
                           AccentBorder="border-l-4 border-emerald-500" />
        <StatHighlightCard Title="Linked animals"
                           Value="@summary.LinkedAnimalSightings.ToString("N0")"
                           Subtitle="Tied to a profile"
                           AccentBorder="border-l-4 border-amber-500" />
        <StatHighlightCard Title="Hunting"
                           Value="@summary.HuntingSightings.ToString("N0")"
                           Subtitle="Behavior = hunting"
                           AccentBorder="border-l-4 border-rose-500" />
    </div>

    @if (summary.TotalSightings > 0)
    {
        <UICard Title="Coverage" Class="mt-6">
            <div class="max-w-xl space-y-5">
                <div>
                    <div class="mb-2 flex items-center justify-between text-xs font-medium text-slate-600 dark:text-slate-400">
                        <span>Geotagged share</span>
                        <span class="tabular-nums text-slate-900 dark:text-slate-100">@PercentOf(summary.GeotaggedSightings, summary.TotalSightings)%</span>
                    </div>
                    <div class="h-3 overflow-hidden rounded-full bg-slate-200/90 dark:bg-slate-700/90">
                        <div class="h-full rounded-full bg-gradient-to-r from-emerald-500 to-teal-500 transition-[width] duration-500"
                             style="width: @(PercentOf(summary.GeotaggedSightings, summary.TotalSightings))%"></div>
                    </div>
                </div>
                <div>
                    <div class="mb-2 flex items-center justify-between text-xs font-medium text-slate-600 dark:text-slate-400">
                        <span>Linked to animals</span>
                        <span class="tabular-nums text-slate-900 dark:text-slate-100">@PercentOf(summary.LinkedAnimalSightings, summary.TotalSightings)%</span>
                    </div>
                    <div class="h-3 overflow-hidden rounded-full bg-slate-200/90 dark:bg-slate-700/90">
                        <div class="h-full rounded-full bg-gradient-to-r from-amber-500 to-orange-500 transition-[width] duration-500"
                             style="width: @(PercentOf(summary.LinkedAnimalSightings, summary.TotalSightings))%"></div>
                    </div>
                </div>
            </div>
        </UICard>
    }

    <div class="mt-6 grid gap-4 lg:grid-cols-2">
        @if (summary.SpeciesCounts.Count > 0)
        {
            <UICard Title="Species mix">
                <p class="mb-2 text-xs text-slate-600 dark:text-slate-400">Share of sightings by species (top set).</p>
                <div class="relative mx-auto h-64 w-full max-w-lg">
                    <canvas id="@IdSpecies"></canvas>
                </div>
            </UICard>
        }
        @if (summary.BehaviorCounts.Count > 0)
        {
            <UICard Title="Behavior mix">
                <p class="mb-2 text-xs text-slate-600 dark:text-slate-400">Recorded behaviors in range.</p>
                <div class="relative h-64 w-full">
                    <canvas id="@IdBehavior"></canvas>
                </div>
            </UICard>
        }
    </div>

    @if (summary.DailyCounts.Count > 0)
    {
        <UICard Title="Sightings by day (UTC)" Class="mt-6">
            <p class="mb-2 text-xs text-slate-600 dark:text-slate-400">Daily totals across the selected window.</p>
            <div class="relative h-72 w-full">
                <canvas id="@IdDaily"></canvas>
            </div>
        </UICard>
    }

    @if (HeatmapRows.Count > 0)
    {
        <UICard Title="Activity heat map (UTC)" Class="mt-6">
            <p class="mb-3 text-xs text-slate-600 dark:text-slate-400">Calendar grid: stronger cyan = more sightings that day. Weeks start on Monday.</p>
            <div class="overflow-x-auto">
                <div class="inline-block w-fit max-w-full">
                    <div class="mb-0.5 grid grid-cols-7 gap-0.5 text-center text-[10px] font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">
                        <span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span><span>Sun</span>
                    </div>
                    @foreach (var row in HeatmapRows)
                    {
                        <div class="mb-0.5 grid grid-cols-7 gap-0.5">
                            @foreach (var cell in row)
                            {
                                @if (cell.IsPadding)
                                {
                                    <div class="size-3 shrink-0 rounded-sm bg-transparent dark:bg-transparent"></div>
                                }
                                else
                                {
                                    <div class="size-3 shrink-0 rounded-sm border border-slate-200/40 dark:border-slate-600/40"
                                         style="@HeatmapCellStyle(cell)"
                                         title="@HeatmapTitle(cell)"></div>
                                }
                            }
                        </div>
                    }
                </div>
            </div>
            <div class="mt-3 flex flex-wrap items-center gap-3 text-[10px] text-slate-500 dark:text-slate-400">
                <span>Less</span>
                <div class="flex gap-0.5">
                    @foreach (var step in new[] { 0.0, 0.25, 0.5, 0.75, 1.0 })
                    {
                        <div class="h-3 w-5 rounded-sm border border-slate-300/30 dark:border-slate-600/30"
                             style="@($"background-color: rgb(6 182 212 / {(0.12 + 0.78 * step).ToString("0.##", CultureInfo.InvariantCulture)});")"></div>
                    }
                </div>
                <span>More</span>
            </div>
        </UICard>
    }

    <UICard Title="Tracked animals" Class="mt-6">
        @if (dashboard.Territories.Count == 0)
        {
            <p class="text-sm leading-relaxed text-slate-600 dark:text-slate-400">No territory data yet. Add coordinates and link sightings to animal profiles.</p>
        }
        else
        {
            <div class="grid gap-4 sm:grid-cols-2">
                @foreach (var territory in dashboard.Territories)
                {
                    <div class="rounded-xl border border-slate-200/90 bg-gradient-to-br from-slate-50/80 to-white p-4 shadow-sm dark:border-slate-700/80 dark:from-slate-900/40 dark:to-slate-950/40">
                        <div class="flex items-start justify-between gap-2">
                            <div class="min-w-0">
                                <p class="font-semibold text-slate-900 dark:text-slate-50">@territory.AnimalLabel</p>
                                <p class="text-xs text-slate-600 dark:text-slate-400">@territory.SpeciesName</p>
                            </div>
                            <span class="shrink-0 rounded-full bg-sky-500/15 px-2 py-0.5 text-xs font-semibold text-sky-800 dark:bg-sky-500/20 dark:text-sky-200">@territory.CoordinateSightings</span>
                        </div>
                        <div class="mt-3 flex flex-wrap gap-2">
                            <span class="inline-flex items-center rounded-lg bg-slate-200/70 px-2 py-1 text-[11px] font-medium text-slate-800 dark:bg-slate-800/80 dark:text-slate-200">Core @FormatCoordinates(territory.CoreLatitude, territory.CoreLongitude)</span>
                            <span class="inline-flex items-center rounded-lg bg-slate-200/70 px-2 py-1 text-[11px] font-medium text-slate-800 dark:bg-slate-800/80 dark:text-slate-200">~@Math.Round(territory.RadiusMeters)m</span>
                            <span class="inline-flex items-center rounded-lg bg-slate-200/70 px-2 py-1 text-[11px] font-medium text-slate-800 dark:bg-slate-800/80 dark:text-slate-200">@territory.HuntingSightings hunting</span>
                        </div>
                        <p class="mt-2 text-xs text-slate-600 dark:text-slate-400">@territory.BestActivityWindowLocal</p>
                    </div>
                }
            </div>
        }
    </UICard>

    <UICard Title="Species hotspots" Class="mt-6">
        @if (dashboard.SpeciesHotspots.Count == 0)
        {
            <p class="text-sm leading-relaxed text-slate-600 dark:text-slate-400">No geotagged sightings in this range.</p>
        }
        else
        {
            <div class="grid gap-4 sm:grid-cols-2">
                @foreach (var hotspot in dashboard.SpeciesHotspots)
                {
                    <div class="rounded-xl border border-slate-200/90 bg-gradient-to-br from-emerald-50/50 to-white p-4 shadow-sm dark:border-slate-700/80 dark:from-emerald-950/20 dark:to-slate-950/40">
                        <div class="flex items-start justify-between gap-2">
                            <p class="font-semibold text-slate-900 dark:text-slate-50">@hotspot.SpeciesName</p>
                            <span class="shrink-0 rounded-full bg-emerald-500/15 px-2 py-0.5 text-xs font-semibold text-emerald-900 dark:bg-emerald-500/20 dark:text-emerald-200">@hotspot.CoordinateSightings</span>
                        </div>
                        <div class="mt-3 flex flex-wrap gap-2">
                            <span class="inline-flex items-center rounded-lg bg-slate-200/70 px-2 py-1 text-[11px] font-medium text-slate-800 dark:bg-slate-800/80 dark:text-slate-200">Hunting @hotspot.HuntingSightings</span>
                            <span class="inline-flex items-center rounded-lg bg-slate-200/70 px-2 py-1 text-[11px] font-medium text-slate-800 dark:bg-slate-800/80 dark:text-slate-200">@FormatCoordinates(hotspot.CoreLatitude, hotspot.CoreLongitude)</span>
                        </div>
                    </div>
                }
            </div>
        }
    </UICard>
}

@code {
    private readonly string _chartUid = Guid.NewGuid().ToString("n")[..8];
    private string IdSpecies => $"stats-sp-{_chartUid}";
    private string IdDaily => $"stats-daily-{_chartUid}";
    private string IdBehavior => $"stats-beh-{_chartUid}";

    private bool loading = true;
    private bool chartsDirty;
    private DateTime? fromLocalDate;
    private DateTime? toLocalDate;
    private TerritoryDashboardData dashboard = new([], []);
    private SightingStatsSummary summary = new(0, 0, 0, 0, 0, 0, [], [], []);

    private int MaxDailyCount => summary.DailyCounts.Count == 0 ? 0 : summary.DailyCounts.Max(x => x.Count);

    private IReadOnlyList<IReadOnlyList<HeatmapCell>> HeatmapRows
    {
        get
        {
            if (summary.DailyCounts.Count == 0)
                return [];

            var byDay = summary.DailyCounts.ToDictionary(d => DateOnly.FromDateTime(d.DayUtc), d => d.Count);
            var minD = byDay.Keys.Min();
            var maxD = byDay.Keys.Max();
            var cells = new List<HeatmapCell>();
            var pad = MondayOffset(minD);
            for (var i = 0; i < pad; i++)
                cells.Add(new HeatmapCell(IsPadding: true, Day: null, Count: 0));

            for (var d = minD; d <= maxD; d = d.AddDays(1))
                cells.Add(new HeatmapCell(IsPadding: false, Day: d, Count: byDay.GetValueOrDefault(d, 0)));

            var rows = new List<IReadOnlyList<HeatmapCell>>();
            for (var i = 0; i < cells.Count; i += 7)
                rows.Add(cells.Skip(i).Take(7).ToList());

            var last = rows[^1].ToList();
            while (last.Count < 7)
                last.Add(new HeatmapCell(IsPadding: true, Day: null, Count: 0));
            rows[^1] = last;

            return rows;
        }
    }

    private string GeotaggedSubtitle =>
        summary.TotalSightings > 0
            ? $"{PercentOf(summary.GeotaggedSightings, summary.TotalSightings)}% of sightings"
            : "With coordinates";

    protected override async Task OnInitializedAsync() =>
        await ReloadAsync();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (loading || !chartsDirty)
            return;

        try
        {
            await SyncChartsAsync();
            chartsDirty = false;
        }
        catch (InvalidOperationException)
        {
            /* Interactive runtime not ready yet */
        }
        catch (JSException)
        {
            chartsDirty = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        await DestroyChartsAsync();
    }

    private async Task ReloadAsync()
    {
        await DestroyChartsAsync();
        loading = true;
        chartsDirty = false;
        await InvokeAsync(StateHasChanged);

        DateTime? fromUtc = fromLocalDate.HasValue
            ? DateTime.SpecifyKind(fromLocalDate.Value.Date, DateTimeKind.Local).ToUniversalTime()
            : null;
        DateTime? toUtc = toLocalDate.HasValue
            ? DateTime.SpecifyKind(toLocalDate.Value.Date.AddDays(1).AddTicks(-1), DateTimeKind.Local).ToUniversalTime()
            : null;

        dashboard = await Insights.GetDashboardAsync(fromUtc, toUtc);
        summary = await Stats.GetSummaryAsync(fromUtc, toUtc);
        loading = false;
        chartsDirty = true;
    }

    private async Task DestroyChartsAsync()
    {
        try
        {
            foreach (var id in new[] { IdSpecies, IdDaily, IdBehavior })
                await JS.InvokeVoidAsync("animalTrackerStatsChartsDestroy", id);
        }
        catch
        {
            /* circuit gone or SSR */
        }
    }

    private async Task SyncChartsAsync()
    {
        await DestroyChartsAsync();

        if (summary.SpeciesCounts.Count > 0)
        {
            await JS.InvokeVoidAsync(
                "animalTrackerStatsChartsDoughnut",
                IdSpecies,
                summary.SpeciesCounts.Select(s => s.SpeciesName).ToArray(),
                summary.SpeciesCounts.Select(s => s.Count).ToArray());
        }

        if (summary.DailyCounts.Count > 0)
        {
            await JS.InvokeVoidAsync(
                "animalTrackerStatsChartsBar",
                IdDaily,
                summary.DailyCounts.Select(d => d.DayUtc.ToString("MMM d", CultureInfo.InvariantCulture)).ToArray(),
                summary.DailyCounts.Select(d => d.Count).ToArray(),
                "Sightings");
        }

        if (summary.BehaviorCounts.Count > 0)
        {
            await JS.InvokeVoidAsync(
                "animalTrackerStatsChartsHorizontalBar",
                IdBehavior,
                summary.BehaviorCounts.Select(b => b.Behavior.ToString()).ToArray(),
                summary.BehaviorCounts.Select(b => b.Count).ToArray());
        }
    }

    private static int PercentOf(int part, int whole) =>
        whole <= 0 ? 0 : (int)Math.Round(100.0 * part / whole);

    private static int MondayOffset(DateOnly d)
    {
        var dow = (int)d.DayOfWeek;
        return dow == 0 ? 6 : dow - 1;
    }

    private string HeatmapCellStyle(HeatmapCell cell)
    {
        var max = MaxDailyCount;
        if (max <= 0)
            return "background-color: rgb(51 65 85 / 0.15);";

        var t = cell.Count <= 0 ? 0 : Math.Pow(Math.Clamp(cell.Count / (double)max, 0, 1), 0.55);
        var a = 0.12 + 0.78 * t;
        return $"background-color: rgb(6 182 212 / {a.ToString("0.##", CultureInfo.InvariantCulture)});";
    }

    private static string HeatmapTitle(HeatmapCell cell) =>
        cell.Day is { } d ? $"{d:yyyy-MM-dd}: {cell.Count} sighting(s)" : "";

    private static string FormatCoordinates(double? lat, double? lng)
    {
        if (lat is null || lng is null)
            return "—";

        return $"{lat.Value:0.000}, {lng.Value:0.000}";
    }

    private sealed record HeatmapCell(bool IsPadding, DateOnly? Day, int Count);
}
