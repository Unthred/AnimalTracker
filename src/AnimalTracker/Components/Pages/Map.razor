@page "/map"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

@using AnimalTracker.Data.Entities
@using AnimalTracker.Services
@inject SightingService Sightings
@inject SpeciesService Species
@inject AnimalService Animals
@inject IJSRuntime JS

<PageTitle>Map</PageTitle>

<UIPageHeader Title="Sightings map" Description="Explore sightings and territory overlays from geotagged observations." />

<UICard Class="relative z-20 mt-2">
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <UIField Label="Species" For="species">
            <UISpeciesSelect id="species"
                             Items="species"
                             EmptyLabel="All"
                             @bind-Value="selectedSpeciesId"
                             @bind-Value:after="ReloadAsync" />
        </UIField>
        <UIField Label="Animal" For="animal">
            <SearchableCombobox TValue="int?"
                                id="animal"
                                Items="@AnimalFilterOptions"
                                EmptyRowWhenUnfiltered="@AnimalEmptyOption"
                                @bind-Value="selectedAnimalId"
                                @bind-Value:after="ReloadAsync"
                                Placeholder="All animals"
                                NoResultsText="No animals found"
                                AllowClear="true"
                                ChevronAriaLabel="Show animals" />
        </UIField>
        <UIField Label="From date" For="fromDate">
            <UIDatePicker id="fromDate"
                          @bind-NullableValue="fromLocalDate"
                          @bind-NullableValue:after="ReloadAsync" />
        </UIField>
        <UIField Label="To date" For="toDate">
            <UIDatePicker id="toDate"
                          @bind-NullableValue="toLocalDate"
                          @bind-NullableValue:after="ReloadAsync" />
        </UIField>
    </div>
</UICard>

<UICard Class="relative z-0 mt-6">
    <div class="mb-4 flex flex-wrap items-center gap-4 text-sm text-slate-600 dark:text-slate-300">
        <span>@points.Count geotagged sightings</span>
        <span>@territories.Count inferred territories</span>
    </div>
    <div id="@mapContainerId" style="height: 560px; border-radius: 0.9rem; overflow: hidden;"></div>
</UICard>

@if (territories.Count > 0)
{
    <UICard Title="Territory summaries" Class="mt-6">
        <ul class="divide-y divide-slate-200/80 dark:divide-slate-800/80">
            @foreach (var t in territories)
            {
                <li class="py-3 text-sm">
                    <div class="font-semibold text-slate-900 dark:text-slate-50">@t.AnimalLabel · @t.SpeciesName</div>
                    <div class="mt-1 text-slate-600 dark:text-slate-300">
                        @t.CoordinateSightings sightings · radius ~@Math.Round(t.RadiusMeters)m · active @t.BestActivityWindowLocal · hunting @t.HuntingSightings
                    </div>
                </li>
            }
        </ul>
    </UICard>
}

@code {
    private readonly string mapContainerId = $"sightings-map-{Guid.NewGuid():N}";
    private List<Species> species = [];
    private List<Animal> animals = [];
    private List<SightingMapPoint> points = [];
    private List<AnimalTerritorySummary> territories = [];
    private int? selectedSpeciesId;
    private int? selectedAnimalId;
    private DateTime? fromLocalDate;
    private DateTime? toLocalDate;
    private bool shouldRenderMap;

    protected override async Task OnInitializedAsync()
    {
        species = await Species.GetAllAsync();
        animals = await Animals.SearchAsync(query: null, speciesId: null);
        await ReloadAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender && !shouldRenderMap)
            return;

        shouldRenderMap = false;
        await JS.InvokeVoidAsync("animalTrackerMap.render", mapContainerId, points, territories);
    }

    private async Task ReloadAsync()
    {
        DateTime? fromUtc = fromLocalDate.HasValue
            ? DateTime.SpecifyKind(fromLocalDate.Value.Date, DateTimeKind.Local).ToUniversalTime()
            : null;
        DateTime? toUtc = toLocalDate.HasValue
            ? DateTime.SpecifyKind(toLocalDate.Value.Date.AddDays(1).AddTicks(-1), DateTimeKind.Local).ToUniversalTime()
            : null;

        var filters = new SightingFilters(
            FromUtc: fromUtc,
            ToUtc: toUtc,
            SpeciesId: selectedSpeciesId,
            LocationId: null,
            AnimalId: selectedAnimalId,
            UnknownOnly: false,
            WithCoordinatesOnly: true,
            MaxLocationAccuracyMeters: null);

        points = await Sightings.GetMapPointsAsync(take: 2500, filters);
        territories = await Sightings.GetTerritorySummariesAsync(fromUtc, toUtc, take: 24);
        shouldRenderMap = true;
        await InvokeAsync(StateHasChanged);
    }

    private ComboboxOption<int?> AnimalEmptyOption => new(null, "All animals");

    private IReadOnlyList<ComboboxOption<int?>> AnimalFilterOptions =>
        animals
            .Select(a => new ComboboxOption<int?>(a.Id, GetAnimalFilterLabel(a)))
            .ToArray();

    private static string GetAnimalFilterLabel(Animal a) =>
        !string.IsNullOrWhiteSpace(a.DisplayName) ? a.DisplayName : $"Animal #{a.Id} · {a.Species.Name}";
}
