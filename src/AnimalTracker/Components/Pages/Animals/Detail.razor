@page "/animals/{Id:int}"
@rendermode InteractiveServer
@implements IDisposable

@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

@using AnimalTracker.Services
@using AnimalTracker.Data.Entities
@inject AnimalService Animals
@inject NavigationManager Nav
@inject AnimalTracker.Services.SightingService Sightings
@inject TerritoryInsightsService Insights
@inject AnimalTracker.State.UserPreferencesState Prefs

<PageTitle>Animal</PageTitle>

@if (loading)
{
    <p class="text-sm text-slate-600 dark:text-slate-400">Loading…</p>
}
else if (animal is null)
{
    <UIAlert Variant="UiAlertVariant.Neutral">Animal not found.</UIAlert>
}
else
{
    <UIPageHeader Title="@(!string.IsNullOrWhiteSpace(animal.DisplayName) ? animal.DisplayName : $"Animal #{animal.Id}")"
                  Description="@animal.Species.Name">
        <Actions>
            <UIButton Href="/animals" Variant="UiButtonVariant.Outline">Back to list</UIButton>
            <UIButton Href="@($"/animals/{Id}/edit")" Variant="UiButtonVariant.Outline">Edit</UIButton>
        </Actions>
    </UIPageHeader>

    @if (!string.IsNullOrWhiteSpace(deleteError))
    {
        <UIAlert Variant="UiAlertVariant.Danger" Class="mb-6">@deleteError</UIAlert>
    }

    @if (!string.IsNullOrWhiteSpace(animal.IdentifyingFeatures))
    {
        <UICard Class="mt-2">
            <h2 class="text-sm font-semibold text-slate-900 dark:text-slate-50">Identifying features</h2>
            <p class="mt-2 text-sm leading-relaxed text-slate-700 dark:text-slate-200">@animal.IdentifyingFeatures</p>
        </UICard>
    }

    @if (!string.IsNullOrWhiteSpace(animal.Notes))
    {
        <UICard Class="mt-6">
            <h2 class="text-sm font-semibold text-slate-900 dark:text-slate-50">Notes</h2>
            <p class="mt-2 text-sm leading-relaxed text-slate-700 dark:text-slate-200">@animal.Notes</p>
        </UICard>
    }

    <UICard Title="Territory profile" Class="mt-6">
        @if (territory is null)
        {
            <p class="text-sm leading-relaxed text-slate-700 dark:text-slate-200">Not enough geotagged sightings for this animal yet.</p>
        }
        else
        {
            <dl class="grid grid-cols-1 gap-4 text-sm sm:grid-cols-2">
                <div>
                    <dt class="text-slate-500 dark:text-slate-400">Total sightings</dt>
                    <dd class="mt-1 text-slate-900 dark:text-slate-50">@territory.TotalSightings</dd>
                </div>
                <div>
                    <dt class="text-slate-500 dark:text-slate-400">Geotagged sightings</dt>
                    <dd class="mt-1 text-slate-900 dark:text-slate-50">@territory.CoordinateSightings</dd>
                </div>
                <div>
                    <dt class="text-slate-500 dark:text-slate-400">Core area center</dt>
                    <dd class="mt-1 text-slate-900 dark:text-slate-50">@FormatCoordinates(territory.CoreLatitude, territory.CoreLongitude)</dd>
                </div>
                <div>
                    <dt class="text-slate-500 dark:text-slate-400">Average patrol radius</dt>
                    <dd class="mt-1 text-slate-900 dark:text-slate-50">~@Math.Round(territory.RadiusMeters) m</dd>
                </div>
                <div>
                    <dt class="text-slate-500 dark:text-slate-400">Best activity window</dt>
                    <dd class="mt-1 text-slate-900 dark:text-slate-50">@territory.BestActivityWindowLocal</dd>
                </div>
                <div>
                    <dt class="text-slate-500 dark:text-slate-400">Hunting sightings</dt>
                    <dd class="mt-1 text-slate-900 dark:text-slate-50">@territory.HuntingSightings</dd>
                </div>
            </dl>
        }
    </UICard>

    <UICard Title="Delete animal" Class="mt-8">
        <p class="text-sm leading-relaxed text-slate-600 dark:text-slate-300">Removes this profile. Your sightings stay on the timeline; any links to this animal are cleared.</p>
        @if (showDeleteConfirm)
        {
            <div class="mt-4 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
                <UIButton Variant="UiButtonVariant.Outline" Class="w-full sm:w-auto" @onclick="CancelDelete">Cancel</UIButton>
                <UIButton Variant="UiButtonVariant.Danger" Class="w-full sm:w-auto" @onclick="ConfirmDeleteAsync">Delete permanently</UIButton>
            </div>
        }
        else
        {
            <div class="mt-4">
                <UIButton Variant="UiButtonVariant.Outline" Class="border-red-200 text-red-800 hover:bg-red-50 dark:border-red-900/60 dark:text-red-200 dark:hover:bg-red-950/40" @onclick="() => showDeleteConfirm = true">Delete animal…</UIButton>
            </div>
        }
    </UICard>
}

@code {
    [Parameter] public int Id { get; set; }
    private bool loading = true;
    private Animal? animal;
    private bool showDeleteConfirm;
    private string? deleteError;
    private int? animalPhotoId;
    private AnimalTerritoryInsights? territory;
    private IDisposable? backgroundScope;

    protected override async Task OnParametersSetAsync()
    {
        loading = true;
        showDeleteConfirm = false;
        deleteError = null;
        animalPhotoId = null;
        territory = null;
        animal = await Animals.GetAsync(Id);
        if (animal is not null)
        {
            animalPhotoId = await Sightings.GetLatestPhotoIdForAnimalAsync(Id);
            territory = await Insights.GetAnimalInsightsAsync(Id);
        }

        backgroundScope?.Dispose();
        backgroundScope = null;
        if (animalPhotoId is not null)
            backgroundScope = Prefs.UseTemporaryBackground($"/photos/{animalPhotoId}");
        loading = false;
    }

    public void Dispose()
    {
        backgroundScope?.Dispose();
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        deleteError = null;
    }

    private async Task ConfirmDeleteAsync()
    {
        deleteError = null;
        try
        {
            await Animals.DeleteAsync(Id);
            Nav.NavigateTo("/animals");
        }
        catch (Exception ex)
        {
            deleteError = ex.Message;
            showDeleteConfirm = false;
        }
    }

    private static string FormatCoordinates(double? lat, double? lng)
    {
        if (lat is null || lng is null)
            return "unknown";

        return $"{lat.Value:0.00000}, {lng.Value:0.00000}";
    }
}
