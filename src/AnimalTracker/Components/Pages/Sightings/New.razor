@page "/sightings/new"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

@using AnimalTracker.Services
@using AnimalTracker.Components.UI
@using AnimalTracker.Data.Entities
@using AnimalTracker.Data
@using SixLabors.ImageSharp
@using SixLabors.ImageSharp.Metadata.Profiles.Exif
@inject SightingService Sightings
@inject SpeciesService Species
@inject AppSettingsService AppSettings
@inject LocationService Locations
@inject AnimalService Animals
@inject NavigationManager Nav
@inject ApplicationDbContext Db
@inject PhotoStorageService Storage
@inject IJSRuntime JS

<PageTitle>Add Sighting</PageTitle>

<UIPageHeader Title="Add sighting" Description="Log a wildlife observation with time, place, and species." />

<div class="mb-4">
    <span class="inline-flex items-center rounded-full border border-slate-200/90 bg-slate-50 px-3 py-1 text-xs font-medium text-slate-700 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200">
        Species region: @(string.IsNullOrWhiteSpace(activeSpeciesRegionName) ? "Not selected" : activeSpeciesRegionName)
    </span>
</div>

<UICard>
    <EditForm Model="model" OnValidSubmit="SaveAsync" class="space-y-6">
        <DataAnnotationsValidator />

        <div class="grid min-w-0 grid-cols-1 gap-6 sm:grid-cols-2 sm:gap-8">
            <UIField Label="When" For="occurredAt">
                <div class="min-w-0">
                    <span class="mb-1 block text-xs font-medium text-slate-500 dark:text-slate-400">Date</span>
                    <UIDatePicker id="occurredAt" @bind-Value="model.OccurredAtLocalDate" />
                    <ValidationMessage For="() => model.OccurredAtLocalDate" />
                </div>
            </UIField>

            <UIField Label="Time" For="occurredHour" Hint="24-hour clock using the same dropdown styling as Species and Location (no OS time picker).">
                <div class="grid min-w-0 grid-cols-2 gap-3 sm:gap-4">
                    <div class="min-w-0">
                        <span class="mb-1 block text-xs font-medium text-slate-500 dark:text-slate-400">Hour</span>
                        <select id="occurredHour" class="w-full min-w-0 px-3 py-2.5" @bind="hourPart" @bind:after="SyncModelTimeFromParts">
                            @for (var h = 0; h < 24; h++)
                            {
                                <option value="@h">@h.ToString("00")</option>
                            }
                        </select>
                    </div>
                    <div class="min-w-0">
                        <span class="mb-1 block text-xs font-medium text-slate-500 dark:text-slate-400">Minute</span>
                        <select id="occurredMinute" class="w-full min-w-0 px-3 py-2.5" @bind="minutePart" @bind:after="SyncModelTimeFromParts">
                            @for (var m = 0; m < 60; m++)
                            {
                                <option value="@m">@m.ToString("00")</option>
                            }
                        </select>
                    </div>
                </div>
            </UIField>
        </div>

        <div class="grid min-w-0 grid-cols-1 gap-6 sm:grid-cols-2 sm:gap-8">
            <UIField Label="Species" For="species">
                <select id="species" class="w-full min-w-0 px-3 py-2.5" @bind="model.SpeciesId">
                    <option value="">Select…</option>
                    @foreach (var s in species)
                    {
                        <option value="@s.Id">@s.Name</option>
                    }
                </select>
                @if (species.Count == 0)
                {
                    <p class="mt-2 text-xs text-slate-500 dark:text-slate-400">Select a species region in Settings to load this list.</p>
                }
                <div class="mt-2">
                    <UIButton Href="/species" target="_blank" rel="noreferrer noopener" Variant="UiButtonVariant.Outline" Size="UiButtonSize.Sm">
                        Lookup species
                    </UIButton>
                </div>
                <ValidationMessage For="() => model.SpeciesId" />
            </UIField>

            <UIField Label="Location" For="location">
                <InputText id="location"
                           list="location-options"
                           class="w-full min-w-0 rounded-xl border border-slate-200/90 bg-white px-3 py-2.5 text-sm shadow-sm transition duration-200 ease-in-out hover:border-slate-300 hover:shadow-sm focus:border-slate-300 focus:outline-none focus:ring-4 focus:ring-slate-200/70 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-50 dark:hover:border-slate-600 dark:focus:ring-slate-800/80"
                           placeholder="Default or type a new location"
                           autocomplete="off"
                           @bind-Value="model.LocationName" />
                <datalist id="location-options">
                    @foreach (var l in locations)
                    {
                        <option value="@l.Name"></option>
                    }
                </datalist>
                <div class="mt-2 flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                    <p class="text-xs text-slate-500 dark:text-slate-400">Optional. Type a name and click Add to create it now.</p>
                    <UIButton Type="button" Variant="UiButtonVariant.Outline" Size="UiButtonSize.Sm" @onclick="AddLocationAsync">Add location</UIButton>
                </div>
                @if (!string.IsNullOrWhiteSpace(locationInlineError))
                {
                    <p class="mt-2 text-sm text-red-700 dark:text-red-300">@locationInlineError</p>
                }
            </UIField>
        </div>

        <div class="grid min-w-0 grid-cols-1 gap-6 sm:grid-cols-2 sm:gap-8">
            <UIField Label="Linked animal" For="animal">
                <select id="animal" class="w-full min-w-0 px-3 py-2.5" @bind="model.AnimalId">
                    <option value="">None (unknown)</option>
                    @foreach (var a in animals)
                    {
                        <option value="@a.Id">@GetAnimalLabel(a)</option>
                    }
                </select>
            </UIField>

            <UIField Label="Behavior" For="behavior">
                <select id="behavior" class="w-full min-w-0 px-3 py-2.5" @bind="model.Behavior">
                    <option value="">Not specified</option>
                    @foreach (var behavior in Enum.GetValues<SightingBehavior>())
                    {
                        <option value="@behavior">@behavior</option>
                    }
                </select>
            </UIField>
        </div>

        <div class="grid min-w-0 grid-cols-1 gap-6 sm:grid-cols-2 sm:gap-8">
            <UIField Label="Species confidence" For="speciesConfidence">
                <select id="speciesConfidence" class="w-full min-w-0 px-3 py-2.5" @bind="model.SpeciesConfidence">
                    <option value="">Not specified</option>
                    @foreach (var confidence in Enum.GetValues<SightingConfidence>())
                    {
                        <option value="@confidence">@confidence</option>
                    }
                </select>
            </UIField>

            <UIField Label="Individual confidence" For="individualConfidence">
                <select id="individualConfidence" class="w-full min-w-0 px-3 py-2.5" @bind="model.IndividualConfidence">
                    <option value="">Not specified</option>
                    @foreach (var confidence in Enum.GetValues<SightingConfidence>())
                    {
                        <option value="@confidence">@confidence</option>
                    }
                </select>
            </UIField>
        </div>

        <div class="grid min-w-0 grid-cols-1 gap-6 sm:grid-cols-2 sm:gap-8">
            <UIField Label="Latitude" For="latitude">
                <InputNumber id="latitude"
                             class="w-full min-w-0 rounded-xl border border-slate-200/90 bg-white px-3 py-2.5 text-sm shadow-sm transition duration-200 ease-in-out hover:border-slate-300 hover:shadow-sm focus:border-slate-300 focus:outline-none focus:ring-4 focus:ring-slate-200/70 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-50 dark:hover:border-slate-600 dark:focus:ring-slate-800/80"
                             @bind-Value="model.Latitude" />
                <ValidationMessage For="() => model.Latitude" />
            </UIField>
            <UIField Label="Longitude" For="longitude">
                <InputNumber id="longitude"
                             class="w-full min-w-0 rounded-xl border border-slate-200/90 bg-white px-3 py-2.5 text-sm shadow-sm transition duration-200 ease-in-out hover:border-slate-300 hover:shadow-sm focus:border-slate-300 focus:outline-none focus:ring-4 focus:ring-slate-200/70 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-50 dark:hover:border-slate-600 dark:focus:ring-slate-800/80"
                             @bind-Value="model.Longitude" />
                <ValidationMessage For="() => model.Longitude" />
            </UIField>
        </div>

        <div class="grid min-w-0 grid-cols-1 gap-6 sm:grid-cols-2 sm:gap-8">
            <UIField Label="GPS accuracy (m)" For="gpsAccuracy">
                <InputNumber id="gpsAccuracy"
                             class="w-full min-w-0 rounded-xl border border-slate-200/90 bg-white px-3 py-2.5 text-sm shadow-sm transition duration-200 ease-in-out hover:border-slate-300 hover:shadow-sm focus:border-slate-300 focus:outline-none focus:ring-4 focus:ring-slate-200/70 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-50 dark:hover:border-slate-600 dark:focus:ring-slate-800/80"
                             @bind-Value="model.LocationAccuracyMeters" />
                <ValidationMessage For="() => model.LocationAccuracyMeters" />
            </UIField>
        </div>
        <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
            <p class="text-xs text-slate-500 dark:text-slate-400">
                Coordinates auto-fill from photo EXIF first, then device GPS if needed.
            </p>
            <UIButton Type="button" Variant="UiButtonVariant.Outline" Size="UiButtonSize.Sm" @onclick="UseCurrentDeviceLocationAsync">Use device location</UIButton>
        </div>
        @if (!string.IsNullOrWhiteSpace(coordinateMessage))
        {
            <p class="text-sm text-slate-600 dark:text-slate-300">@coordinateMessage</p>
        }

        <UIField Label="Observed until" For="observedUntil" Hint="Optional end time if you watched this behavior over a period.">
            <InputDate id="observedUntil" TValue="DateTime?" Type="InputDateType.DateTimeLocal" class="w-full min-w-0 px-3 py-2.5" @bind-Value="model.ObservedUntilLocal" />
        </UIField>

        <UIField Label="Notes" For="notes">
            <InputTextArea id="notes" class="w-full min-w-0 px-3 py-2.5" @bind-Value="model.Notes" rows="4" />
        </UIField>

        <UIField Label="Photos" For="photos" Hint="Optional. Up to 25 MB each. Images are resized/compressed on upload for performance.">
            <InputFile OnChange="OnPhotosSelected" multiple accept="image/*"
                       class="block w-full cursor-pointer rounded-xl border border-dashed border-slate-200/90 bg-slate-50/50 px-4 py-6 text-sm text-slate-600 transition duration-200 file:mr-4 file:cursor-pointer file:rounded-lg file:border-0 file:bg-[var(--accent)] file:px-4 file:py-2 file:text-sm file:font-semibold file:text-white hover:border-slate-300 dark:border-slate-700 dark:bg-slate-950/50 dark:text-slate-300 dark:hover:border-slate-600" />
            @if (selectedPhotos.Count > 0)
            {
                <p class="mt-2 text-xs text-slate-500 dark:text-slate-400">@selectedPhotos.Count selected</p>
            }
            @if (!string.IsNullOrWhiteSpace(uploadError))
            {
                <p class="mt-3 text-sm text-red-700 dark:text-red-300">@uploadError</p>
            }
        </UIField>

        <div class="flex flex-col-reverse gap-3 pt-2 sm:flex-row sm:flex-wrap sm:justify-end sm:gap-3">
            <UIButton Href="/" Variant="UiButtonVariant.Outline" Class="w-full sm:w-auto">Cancel</UIButton>
            <UIButton Type="submit" Variant="UiButtonVariant.Primary" Class="w-full sm:w-auto">Save sighting</UIButton>
        </div>
    </EditForm>
</UICard>

@code {
    private List<Species> species = [];
    private List<Location> locations = [];
    private List<Animal> animals = [];

    private readonly Model model = new();
    private int hourPart;
    private int minutePart;
    private const long MaxPhotoUploadBytes = 25L * 1024L * 1024L;
    private readonly List<IBrowserFile> selectedPhotos = [];
    private string? uploadError;
    private string? locationInlineError;
    private string? coordinateMessage;
    private string? activeSpeciesRegionName;

    protected override async Task OnInitializedAsync()
    {
        var appSettings = await AppSettings.GetOrCreateAsync();
        activeSpeciesRegionName = appSettings.ActiveSpeciesRegionName;
        species = await Species.GetAllAsync();
        locations = await Locations.GetAllAsync();
        animals = await Animals.SearchAsync(query: null, speciesId: null);
        if (locations.Count == 0)
        {
            await Locations.GetOrCreateDefaultAsync();
            locations = await Locations.GetAllAsync();
        }

        LoadTimePartsFromModel();
    }

    private void LoadTimePartsFromModel()
    {
        if (!TimeOnly.TryParse(model.OccurredAtLocalTime, out var t))
            t = TimeOnly.FromDateTime(DateTime.Now);
        hourPart = t.Hour;
        minutePart = t.Minute;
    }

    private void SyncModelTimeFromParts() =>
        model.OccurredAtLocalTime = $"{hourPart:D2}:{minutePart:D2}";

    private async Task OnPhotosSelected(InputFileChangeEventArgs e)
    {
        uploadError = null;
        selectedPhotos.Clear();
        selectedPhotos.AddRange(e.GetMultipleFiles());

        // Prefer image EXIF GPS; if missing, fall back to device geolocation.
        await TryAutoFillCoordinatesAsync();
    }

    private async Task SaveAsync()
    {
        uploadError = null;
        locationInlineError = null;
        var locationId = await ResolveLocationIdAsync();
        var occurredAtUtc = model.GetOccurredAtUtc();
        var created = await Sightings.CreateAsync(
            occurredAtUtc: occurredAtUtc,
            speciesId: model.SpeciesId!.Value,
            locationId: locationId,
            animalId: model.AnimalId,
            notes: model.Notes,
            observedUntilUtc: model.GetObservedUntilUtc(),
            latitude: model.Latitude,
            longitude: model.Longitude,
            locationAccuracyMeters: model.LocationAccuracyMeters,
            behavior: model.Behavior,
            speciesConfidence: model.SpeciesConfidence,
            individualConfidence: model.IndividualConfidence);

        if (selectedPhotos.Count > 0)
        {
            try
            {
                foreach (var file in selectedPhotos)
                {
                    var stored = await Storage.SaveSightingPhotoAsync(file);
                    Db.SightingPhotos.Add(new SightingPhoto
                    {
                        SightingId = created.Id,
                        StoredPath = stored.StoredRelativePath,
                        OriginalFileName = stored.OriginalFileName,
                        ContentType = stored.ContentType,
                        SizeBytes = stored.SizeBytes,
                        CreatedAtUtc = DateTime.UtcNow
                    });
                }
                await Db.SaveChangesAsync();
            }
            catch (Exception ex)
            {
                // Sighting is already created; keep user on the page with an error instead of navigating.
                uploadError = ex.Message;
                return;
            }
        }

        Nav.NavigateTo($"/sightings/{created.Id}");
    }

    private async Task AddLocationAsync()
    {
        locationInlineError = null;
        var locationName = (model.LocationName ?? "").Trim();
        if (string.IsNullOrWhiteSpace(locationName))
        {
            locationInlineError = "Enter a location name first.";
            return;
        }

        var existingLocation = locations.FirstOrDefault(x => string.Equals(x.Name, locationName, StringComparison.OrdinalIgnoreCase));
        if (existingLocation is not null)
        {
            model.LocationName = existingLocation.Name;
            return;
        }

        try
        {
            var createdLocation = await Locations.CreateAsync(locationName, notes: null);
            locations = locations.Append(createdLocation).OrderBy(x => x.Name).ToList();
            model.LocationName = createdLocation.Name;
        }
        catch (Exception ex)
        {
            locationInlineError = ex.Message;
        }
    }

    private async Task TryAutoFillCoordinatesAsync()
    {
        coordinateMessage = null;
        if (model.Latitude is not null && model.Longitude is not null)
        {
            coordinateMessage = "Keeping existing coordinates.";
            return;
        }

        if (await TryApplyCoordinatesFromPhotoExifAsync())
            return;

        await TryApplyDeviceCoordinatesAsync("Photo had no GPS metadata. Used device location.");
    }

    private async Task UseCurrentDeviceLocationAsync() =>
        await TryApplyDeviceCoordinatesAsync("Coordinates updated from device location.");

    private async Task<bool> TryApplyCoordinatesFromPhotoExifAsync()
    {
        foreach (var photo in selectedPhotos)
        {
            try
            {
                await using var stream = photo.OpenReadStream(MaxPhotoUploadBytes);
                var imageInfo = await Image.IdentifyAsync(stream);
                var exif = imageInfo?.Metadata?.ExifProfile;
                if (exif is null)
                    continue;

                if (!exif.TryGetValue(ExifTag.GPSLatitudeRef, out IExifValue<string>? latRefValue))
                    continue;
                if (!exif.TryGetValue(ExifTag.GPSLongitudeRef, out IExifValue<string>? lonRefValue))
                    continue;
                if (!exif.TryGetValue(ExifTag.GPSLatitude, out IExifValue<Rational[]>? latValue))
                    continue;
                if (!exif.TryGetValue(ExifTag.GPSLongitude, out IExifValue<Rational[]>? lonValue))
                    continue;

                var latRef = latRefValue.Value;
                var lonRef = lonRefValue.Value;
                var latRaw = latValue.Value;
                var lonRaw = lonValue.Value;
                if (!TryParseGpsCoordinate(latRaw, latRef, out var latitude))
                    continue;
                if (!TryParseGpsCoordinate(lonRaw, lonRef, out var longitude))
                    continue;

                model.Latitude = latitude;
                model.Longitude = longitude;
                coordinateMessage = $"Coordinates loaded from photo metadata ({photo.Name}).";
                return true;
            }
            catch
            {
                // Ignore metadata parsing failures and continue trying other photos.
            }
        }

        return false;
    }

    private async Task<bool> TryApplyDeviceCoordinatesAsync(string successMessage)
    {
        try
        {
            var position = await JS.InvokeAsync<GeoPosition>("animalTrackerGetCurrentPosition", 10000);
            model.Latitude = position.Latitude;
            model.Longitude = position.Longitude;
            if (position.Accuracy is > 0)
                model.LocationAccuracyMeters = position.Accuracy;
            coordinateMessage = successMessage;
            return true;
        }
        catch (Exception ex)
        {
            coordinateMessage = $"Could not get device location: {ex.Message}";
            return false;
        }
    }

    private static bool TryParseGpsCoordinate(object? rawValue, string? direction, out double coordinate)
    {
        coordinate = 0;
        if (!TryReadDms(rawValue, out var degrees, out var minutes, out var seconds))
            return false;

        coordinate = Math.Abs(degrees) + (minutes / 60d) + (seconds / 3600d);
        if (string.Equals(direction, "S", StringComparison.OrdinalIgnoreCase)
            || string.Equals(direction, "W", StringComparison.OrdinalIgnoreCase))
        {
            coordinate = -coordinate;
        }

        return true;
    }

    private static bool TryReadDms(object? rawValue, out double degrees, out double minutes, out double seconds)
    {
        degrees = 0;
        minutes = 0;
        seconds = 0;

        if (rawValue is not System.Collections.IEnumerable values)
            return false;

        var parts = new List<double>(3);
        foreach (var value in values)
        {
            if (!TryConvertExifPartToDouble(value, out var numeric))
                continue;

            parts.Add(numeric);
            if (parts.Count == 3)
                break;
        }

        if (parts.Count < 3)
            return false;

        degrees = parts[0];
        minutes = parts[1];
        seconds = parts[2];
        return true;
    }

    private static bool TryConvertExifPartToDouble(object? value, out double numeric)
    {
        numeric = 0;
        if (value is null)
            return false;

        if (value is Rational rational)
        {
            numeric = rational.Denominator == 0
                ? 0
                : (double)rational.Numerator / rational.Denominator;
            return true;
        }

        try
        {
            numeric = Convert.ToDouble(value, System.Globalization.CultureInfo.InvariantCulture);
            return true;
        }
        catch
        {
            return false;
        }
    }

    private async Task<int?> ResolveLocationIdAsync()
    {
        var locationName = (model.LocationName ?? "").Trim();
        if (string.IsNullOrWhiteSpace(locationName))
            return null;

        var existingLocation = locations.FirstOrDefault(x => string.Equals(x.Name, locationName, StringComparison.OrdinalIgnoreCase));
        if (existingLocation is not null)
            return existingLocation.Id;

        var createdLocation = await Locations.CreateAsync(locationName, notes: null);
        locations = locations.Append(createdLocation).OrderBy(x => x.Name).ToList();
        return createdLocation.Id;
    }

    private static string GetAnimalLabel(Animal a) =>
        !string.IsNullOrWhiteSpace(a.DisplayName) ? a.DisplayName : $"Animal #{a.Id} · {a.Species.Name}";

    private sealed class Model
    {
        [System.ComponentModel.DataAnnotations.Required]
        public int? SpeciesId { get; set; }

        [System.ComponentModel.DataAnnotations.StringLength(200)]
        public string? LocationName { get; set; }

        public int? AnimalId { get; set; }

        public SightingBehavior? Behavior { get; set; }
        public SightingConfidence? SpeciesConfidence { get; set; }
        public SightingConfidence? IndividualConfidence { get; set; }

        [System.ComponentModel.DataAnnotations.Range(-90, 90)]
        public double? Latitude { get; set; }

        [System.ComponentModel.DataAnnotations.Range(-180, 180)]
        public double? Longitude { get; set; }

        [System.ComponentModel.DataAnnotations.Range(0.1, 100000)]
        public double? LocationAccuracyMeters { get; set; }

        [System.ComponentModel.DataAnnotations.Required]
        public DateTime OccurredAtLocalDate { get; set; } = DateTime.Now.Date;

        public string OccurredAtLocalTime { get; set; } = DateTime.Now.ToString("HH:mm");

        public string? Notes { get; set; }

        public DateTime? ObservedUntilLocal { get; set; }

        public DateTime GetOccurredAtUtc()
        {
            if (!TimeOnly.TryParse(OccurredAtLocalTime, out var t))
                t = new TimeOnly(12, 0);

            var local = new DateTime(
                OccurredAtLocalDate.Year,
                OccurredAtLocalDate.Month,
                OccurredAtLocalDate.Day,
                t.Hour,
                t.Minute,
                0,
                DateTimeKind.Local);

            return local.ToUniversalTime();
        }

        public DateTime? GetObservedUntilUtc()
        {
            if (ObservedUntilLocal is null)
                return null;

            var local = DateTime.SpecifyKind(ObservedUntilLocal.Value, DateTimeKind.Local);
            return local.ToUniversalTime();
        }
    }

    private sealed class GeoPosition
    {
        public double Latitude { get; set; }
        public double Longitude { get; set; }
        public double? Accuracy { get; set; }
    }
}
