@page "/sightings/{Id:int}/edit"
@rendermode InteractiveServer
@implements IDisposable

@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

@using AnimalTracker.Components.UI
@using AnimalTracker.Services
@using AnimalTracker.Data.Entities
@using AnimalTracker.Data
@inject SightingService Sightings
@inject SpeciesService Species
@inject LocationService Locations
@inject AnimalService Animals
@inject NavigationManager Nav
@inject ApplicationDbContext Db
@inject PhotoStorageService Storage
@inject AnimalTracker.State.UserPreferencesState Prefs

<PageTitle>Edit sighting</PageTitle>

<style>
    .photo-confirm {
        border-radius: 12px;
        padding: 10px;
        border: 1px solid #e2e8f0;
        background: #fff;
        box-shadow: 0 1px 3px rgba(0,0,0,.06);
    }
    html.dark .photo-confirm {
        border-color: #334155;
        background: #1e293b;
    }

    .photo-confirm-title {
        margin: 0 0 8px;
        font-size: 12px;
        font-weight: 600;
        text-align: center;
        color: #475569;
    }
    html.dark .photo-confirm-title {
        color: #94a3b8;
    }

    .photo-confirm-cancel {
        flex: 1;
        padding: 6px 0;
        font-size: 12px;
        font-weight: 600;
        border-radius: 8px;
        border: 1px solid #cbd5e1;
        background: #fff;
        color: #334155;
        cursor: pointer;
    }
    html.dark .photo-confirm-cancel {
        border-color: #475569;
        background: #0f172a;
        color: #e2e8f0;
    }

    .photo-confirm-delete {
        flex: 1;
        padding: 6px 0;
        font-size: 12px;
        font-weight: 600;
        border-radius: 8px;
        border: 0;
        background: #dc2626;
        color: #fff;
        cursor: pointer;
    }
    .photo-confirm-delete:hover {
        background: #b91c1c;
    }
</style>

@if (loading)
{
    <p class="text-sm text-slate-600 dark:text-slate-400">Loading…</p>
}
else if (sighting is null)
{
    <UIAlert Variant="UiAlertVariant.Neutral">Sighting not found.</UIAlert>
}
else
{
    <UIPageHeader Title="Edit sighting" Description="Fix time, species, location, notes, or link an animal." />

    @if (!string.IsNullOrWhiteSpace(error))
    {
        <UIAlert Variant="UiAlertVariant.Danger" Class="mb-8">@error</UIAlert>
    }

    <UICard>
        <EditForm Model="model" OnValidSubmit="SaveAsync" class="space-y-6">
            <DataAnnotationsValidator />

            <div class="grid min-w-0 grid-cols-1 gap-6 sm:grid-cols-2 sm:gap-8">
                <UIField Label="When" For="occurredAt">
                    <div class="min-w-0">
                        <span class="mb-1 block text-xs font-medium text-slate-500 dark:text-slate-400">Date</span>
                        <UIDatePicker id="occurredAt" @bind-Value="model.OccurredAtLocalDate" />
                        <ValidationMessage For="() => model.OccurredAtLocalDate" />
                    </div>
                </UIField>

                <UIField Label="Time" For="occurredHour" Hint="24-hour clock using the same dropdown styling as Species and Location.">
                    <div class="grid min-w-0 grid-cols-2 gap-3 sm:gap-4">
                        <div class="min-w-0">
                            <span class="mb-1 block text-xs font-medium text-slate-500 dark:text-slate-400">Hour</span>
                            <select id="occurredHour" class="w-full min-w-0 px-3 py-2.5" @bind="hourPart" @bind:after="SyncModelTimeFromParts">
                                @for (var h = 0; h < 24; h++)
                                {
                                    <option value="@h">@h.ToString("00")</option>
                                }
                            </select>
                        </div>
                        <div class="min-w-0">
                            <span class="mb-1 block text-xs font-medium text-slate-500 dark:text-slate-400">Minute</span>
                            <select id="occurredMinute" class="w-full min-w-0 px-3 py-2.5" @bind="minutePart" @bind:after="SyncModelTimeFromParts">
                                @for (var m = 0; m < 60; m++)
                                {
                                    <option value="@m">@m.ToString("00")</option>
                                }
                            </select>
                        </div>
                    </div>
                </UIField>
            </div>

            <div class="grid min-w-0 grid-cols-1 gap-6 sm:grid-cols-2 sm:gap-8">
                <UIField Label="Species" For="species">
                    <InputText id="species"
                               list="species-options"
                               class="w-full min-w-0 rounded-xl border border-slate-200/90 bg-white px-3 py-2.5 text-sm shadow-sm transition duration-200 ease-in-out hover:border-slate-300 hover:shadow-sm focus:border-slate-300 focus:outline-none focus:ring-4 focus:ring-slate-200/70 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-50 dark:hover:border-slate-600 dark:focus:ring-slate-800/80"
                               placeholder="Select or type a new species"
                               autocomplete="off"
                               @bind-Value="model.SpeciesName" />
                    <datalist id="species-options">
                        @foreach (var s in species)
                        {
                            <option value="@s.Name"></option>
                        }
                    </datalist>
                    <div class="mt-2 flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                        <p class="text-xs text-slate-500 dark:text-slate-400">Type a name and click Add to create it now.</p>
                        <UIButton Type="button" Variant="UiButtonVariant.Outline" Size="UiButtonSize.Sm" @onclick="AddSpeciesAsync">Add species</UIButton>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(speciesInlineError))
                    {
                        <p class="mt-2 text-sm text-red-700 dark:text-red-300">@speciesInlineError</p>
                    }
                    <ValidationMessage For="() => model.SpeciesName" />
                </UIField>

                <UIField Label="Location" For="location">
                    <InputText id="location"
                               list="location-options"
                               class="w-full min-w-0 rounded-xl border border-slate-200/90 bg-white px-3 py-2.5 text-sm shadow-sm transition duration-200 ease-in-out hover:border-slate-300 hover:shadow-sm focus:border-slate-300 focus:outline-none focus:ring-4 focus:ring-slate-200/70 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-50 dark:hover:border-slate-600 dark:focus:ring-slate-800/80"
                               placeholder="Default or type a new location"
                               autocomplete="off"
                               @bind-Value="model.LocationName" />
                    <datalist id="location-options">
                        @foreach (var l in locations)
                        {
                            <option value="@l.Name"></option>
                        }
                    </datalist>
                    <div class="mt-2 flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                        <p class="text-xs text-slate-500 dark:text-slate-400">Optional. Type a name and click Add to create it now.</p>
                        <UIButton Type="button" Variant="UiButtonVariant.Outline" Size="UiButtonSize.Sm" @onclick="AddLocationAsync">Add location</UIButton>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(locationInlineError))
                    {
                        <p class="mt-2 text-sm text-red-700 dark:text-red-300">@locationInlineError</p>
                    }
                </UIField>
            </div>

            <UIField Label="Linked animal" For="animal">
                <select id="animal" class="w-full min-w-0 px-3 py-2.5" @bind="model.AnimalId">
                    <option value="">None (unknown)</option>
                    @foreach (var a in animals)
                    {
                        <option value="@a.Id">@GetAnimalLabel(a)</option>
                    }
                </select>
            </UIField>

            <UIField Label="Notes" For="notes">
                <InputTextArea id="notes" class="w-full min-w-0 px-3 py-2.5" @bind-Value="model.Notes" rows="4" />
            </UIField>

            <UIField Label="Photos" For="photos" Hint="Add more photos any time. Up to 25 MB each. Images are resized/compressed on upload for performance.">
                <InputFile OnChange="UploadPhotosAsync" multiple accept="image/*"
                           class="block w-full cursor-pointer rounded-xl border border-dashed border-slate-200/90 bg-slate-50/50 px-4 py-6 text-sm text-slate-600 transition duration-200 file:mr-4 file:cursor-pointer file:rounded-lg file:border-0 file:bg-[var(--accent)] file:px-4 file:py-2 file:text-sm file:font-semibold file:text-white hover:border-slate-300 dark:border-slate-700 dark:bg-slate-950/50 dark:text-slate-300 dark:hover:border-slate-600" />
                @if (!string.IsNullOrWhiteSpace(uploadError))
                {
                    <p class="mt-3 text-sm text-red-700 dark:text-red-300">@uploadError</p>
                }
                @if (!string.IsNullOrWhiteSpace(deletePhotoError))
                {
                    <p class="mt-3 text-sm text-red-700 dark:text-red-300">@deletePhotoError</p>
                }

                @if (sighting.Photos.Count == 0)
                {
                    <p class="mt-4 text-sm text-slate-600 dark:text-slate-400">No photos yet.</p>
                }
                else
                {
                    <p class="mt-4 text-xs text-slate-500 dark:text-slate-400">
                        @sighting.Photos.Count photo(s) · Click a photo to preview it as the background.
                    </p>
                    <div class="mt-4 grid grid-cols-2 gap-4 md:grid-cols-4">
                        @foreach (var p in sighting.Photos)
                        {
                            <div class="flex flex-col gap-2">
                                <div class="relative overflow-hidden rounded-xl border border-slate-200/80 shadow-sm dark:border-slate-700">
                                    <button type="button"
                                            class="block w-full bg-transparent p-0 text-left"
                                            title="Use as background"
                                            @onclick="() => SetBackgroundPhoto(p.Id)">
                                        <img src="@($"/photos/{p.Id}")" alt="@p.OriginalFileName" class="h-32 w-full object-cover" />
                                    </button>
                                    <button type="button"
                                            style="position:absolute;top:6px;right:6px;z-index:10;display:flex;align-items:center;justify-content:center;width:30px;height:30px;border:0;border-radius:8px;background:rgba(15,23,42,.75);color:#fff;cursor:pointer;"
                                            title="Delete photo"
                                            aria-label="Delete photo"
                                            @onclick="() => AskDeletePhoto(p.Id)">
                                        <span aria-hidden="true" style="font-size:16px;line-height:1;">🗑</span>
                                    </button>
                                </div>

                                @if (confirmDeletePhotoId == p.Id)
                                {
                                    <div class="photo-confirm">
                                        <p class="photo-confirm-title">Delete this photo?</p>
                                        <div style="display:flex;gap:6px;">
                                            <button type="button" class="photo-confirm-cancel" @onclick="CancelDeletePhoto">
                                                Cancel
                                            </button>
                                            <button type="button" class="photo-confirm-delete" @onclick="() => ConfirmDeletePhotoAsync(p.Id)">
                                                Delete
                                            </button>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </UIField>

            <div class="flex flex-col-reverse gap-3 pt-2 sm:flex-row sm:flex-wrap sm:justify-end sm:gap-3">
                <UIButton Href="@($"/sightings/{Id}")" Variant="UiButtonVariant.Outline" Class="w-full sm:w-auto">Cancel</UIButton>
                <UIButton Type="submit" Variant="UiButtonVariant.Primary" Class="w-full sm:w-auto">Save changes</UIButton>
            </div>
        </EditForm>
    </UICard>
}

@code {
    [Parameter] public int Id { get; set; }

    private bool loading = true;
    private Sighting? sighting;
    private List<Species> species = [];
    private List<Location> locations = [];
    private List<Animal> animals = [];
    private string? error;
    private string? uploadError;
    private string? deletePhotoError;
    private string? speciesInlineError;
    private string? locationInlineError;
    private int? confirmDeletePhotoId;
    private IDisposable? backgroundScope;

    private readonly Model model = new();
    private int hourPart;
    private int minutePart;

    protected override async Task OnParametersSetAsync()
    {
        loading = true;
        error = null;
        uploadError = null;
        deletePhotoError = null;
        confirmDeletePhotoId = null;

        species = await Species.GetAllAsync();
        locations = await Locations.GetAllAsync();
        if (locations.Count == 0)
        {
            await Locations.GetOrCreateDefaultAsync();
            locations = await Locations.GetAllAsync();
        }
        animals = await Animals.SearchAsync(query: null, speciesId: null);

        sighting = await Sightings.GetAsync(Id);
        if (sighting is not null)
        {
            model.SpeciesName = species.FirstOrDefault(x => x.Id == sighting.SpeciesId)?.Name ?? sighting.Species.Name;
            model.LocationName = sighting.Location?.Name;
            model.AnimalId = sighting.AnimalId;
            model.Notes = sighting.Notes;

            var local = sighting.OccurredAtUtc.ToLocalTime();
            model.OccurredAtLocalDate = local.Date;
            model.OccurredAtLocalTime = local.ToString("HH:mm");

            LoadTimePartsFromModel();

            if (sighting.Photos.Count > 0)
                SetBackgroundPhoto(sighting.Photos[0].Id);
            else
                ClearBackgroundPhoto();
        }

        loading = false;
    }

    public void Dispose()
    {
        backgroundScope?.Dispose();
    }

    private string GetAnimalLabel(Animal a) =>
        !string.IsNullOrWhiteSpace(a.DisplayName) ? a.DisplayName : $"Animal #{a.Id} · {a.Species.Name}";

    private void LoadTimePartsFromModel()
    {
        if (!TimeOnly.TryParse(model.OccurredAtLocalTime, out var t))
            t = TimeOnly.FromDateTime(DateTime.Now);
        hourPart = t.Hour;
        minutePart = t.Minute;
    }

    private void SyncModelTimeFromParts() =>
        model.OccurredAtLocalTime = $"{hourPart:D2}:{minutePart:D2}";

    private async Task SaveAsync()
    {
        error = null;
        speciesInlineError = null;
        locationInlineError = null;
        try
        {
            var speciesId = await ResolveSpeciesIdAsync();
            var locationId = await ResolveLocationIdAsync();
            var occurredAtUtc = model.GetOccurredAtUtc();
            var updated = await Sightings.UpdateAsync(
                id: Id,
                occurredAtUtc: occurredAtUtc,
                speciesId: speciesId,
                locationId: locationId,
                animalId: model.AnimalId,
                notes: model.Notes);

            Nav.NavigateTo($"/sightings/{updated.Id}");
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private async Task AddSpeciesAsync()
    {
        speciesInlineError = null;
        var speciesName = (model.SpeciesName ?? "").Trim();
        if (string.IsNullOrWhiteSpace(speciesName))
        {
            speciesInlineError = "Enter a species name first.";
            return;
        }

        var existingSpecies = species.FirstOrDefault(x => string.Equals(x.Name, speciesName, StringComparison.OrdinalIgnoreCase));
        if (existingSpecies is not null)
        {
            model.SpeciesName = existingSpecies.Name;
            return;
        }

        try
        {
            var createdSpecies = await Species.CreateAsync(speciesName, description: null);
            species = species.Append(createdSpecies).OrderBy(x => x.Name).ToList();
            model.SpeciesName = createdSpecies.Name;
        }
        catch (Exception ex)
        {
            speciesInlineError = ex.Message;
        }
    }

    private async Task AddLocationAsync()
    {
        locationInlineError = null;
        var locationName = (model.LocationName ?? "").Trim();
        if (string.IsNullOrWhiteSpace(locationName))
        {
            locationInlineError = "Enter a location name first.";
            return;
        }

        var existingLocation = locations.FirstOrDefault(x => string.Equals(x.Name, locationName, StringComparison.OrdinalIgnoreCase));
        if (existingLocation is not null)
        {
            model.LocationName = existingLocation.Name;
            return;
        }

        try
        {
            var createdLocation = await Locations.CreateAsync(locationName, notes: null);
            locations = locations.Append(createdLocation).OrderBy(x => x.Name).ToList();
            model.LocationName = createdLocation.Name;
        }
        catch (Exception ex)
        {
            locationInlineError = ex.Message;
        }
    }

    private async Task<int> ResolveSpeciesIdAsync()
    {
        var speciesName = (model.SpeciesName ?? "").Trim();
        var existingSpecies = species.FirstOrDefault(x => string.Equals(x.Name, speciesName, StringComparison.OrdinalIgnoreCase));
        if (existingSpecies is not null)
            return existingSpecies.Id;

        var createdSpecies = await Species.CreateAsync(speciesName, description: null);
        species = species.Append(createdSpecies).OrderBy(x => x.Name).ToList();
        return createdSpecies.Id;
    }

    private async Task<int?> ResolveLocationIdAsync()
    {
        var locationName = (model.LocationName ?? "").Trim();
        if (string.IsNullOrWhiteSpace(locationName))
            return null;

        var existingLocation = locations.FirstOrDefault(x => string.Equals(x.Name, locationName, StringComparison.OrdinalIgnoreCase));
        if (existingLocation is not null)
            return existingLocation.Id;

        var createdLocation = await Locations.CreateAsync(locationName, notes: null);
        locations = locations.Append(createdLocation).OrderBy(x => x.Name).ToList();
        return createdLocation.Id;
    }

    private async Task UploadPhotosAsync(InputFileChangeEventArgs e)
    {
        uploadError = null;
        deletePhotoError = null;
        if (sighting is null)
            return;

        try
        {
            foreach (var file in e.GetMultipleFiles())
            {
                var stored = await Storage.SaveSightingPhotoAsync(file);
                Db.SightingPhotos.Add(new SightingPhoto
                {
                    SightingId = sighting.Id,
                    StoredPath = stored.StoredRelativePath,
                    OriginalFileName = stored.OriginalFileName,
                    ContentType = stored.ContentType,
                    SizeBytes = stored.SizeBytes,
                    CreatedAtUtc = DateTime.UtcNow
                });
            }

            await Db.SaveChangesAsync();
            sighting = await Sightings.GetAsync(Id);
        }
        catch (Exception ex)
        {
            uploadError = ex.Message;
        }
    }

    private void AskDeletePhoto(int photoId)
    {
        confirmDeletePhotoId = photoId;
        deletePhotoError = null;
    }

    private void CancelDeletePhoto() => confirmDeletePhotoId = null;

    private async Task ConfirmDeletePhotoAsync(int photoId)
    {
        confirmDeletePhotoId = null;
        deletePhotoError = null;
        try
        {
            await Sightings.DeletePhotoAsync(photoId);
            sighting = await Sightings.GetAsync(Id);

            // If we deleted the current background photo, fall back to first remaining or clear.
            if (sighting?.Photos.Count > 0)
                SetBackgroundPhoto(sighting.Photos[0].Id);
            else
                ClearBackgroundPhoto();
        }
        catch (Exception ex)
        {
            deletePhotoError = ex.Message;
        }
    }

    private void SetBackgroundPhoto(int photoId)
    {
        backgroundScope?.Dispose();
        backgroundScope = Prefs.UseTemporaryBackground($"/photos/{photoId}");
    }

    private void ClearBackgroundPhoto()
    {
        backgroundScope?.Dispose();
        backgroundScope = null;
    }

    private sealed class Model
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.RegularExpression(@".*\S.*", ErrorMessage = "Species is required.")]
        [System.ComponentModel.DataAnnotations.StringLength(200)]
        public string SpeciesName { get; set; } = "";

        [System.ComponentModel.DataAnnotations.StringLength(200)]
        public string? LocationName { get; set; }

        public int? AnimalId { get; set; }

        [System.ComponentModel.DataAnnotations.Required]
        public DateTime OccurredAtLocalDate { get; set; } = DateTime.Now.Date;

        public string OccurredAtLocalTime { get; set; } = DateTime.Now.ToString("HH:mm");

        public string? Notes { get; set; }

        public DateTime GetOccurredAtUtc()
        {
            if (!TimeOnly.TryParse(OccurredAtLocalTime, out var t))
                t = new TimeOnly(12, 0);

            var local = new DateTime(
                OccurredAtLocalDate.Year,
                OccurredAtLocalDate.Month,
                OccurredAtLocalDate.Day,
                t.Hour,
                t.Minute,
                0,
                DateTimeKind.Local);

            return local.ToUniversalTime();
        }
    }
}

