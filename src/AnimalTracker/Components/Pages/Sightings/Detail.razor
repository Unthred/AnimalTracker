@page "/sightings/{Id:int}"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

@using AnimalTracker.Services
@using AnimalTracker.Data.Entities
@using AnimalTracker.Data
@inject SightingService Sightings
@inject ApplicationDbContext Db
@inject PhotoStorageService Storage
@inject NavigationManager Nav

<PageTitle>Sighting</PageTitle>

@if (loading)
{
    <p class="text-sm text-slate-600 dark:text-slate-400">Loading…</p>
}
else if (sighting is null)
{
    <UIAlert Variant="UiAlertVariant.Neutral">Sighting not found.</UIAlert>
}
else
{
    <UIPageHeader Title="@sighting.Species.Name"
                  Description="@($"{sighting.OccurredAtUtc.ToLocalTime():f} · {sighting.Location.Name}")">
        <Actions>
            <UIButton Href="/" Variant="UiButtonVariant.Outline">Back to timeline</UIButton>
        </Actions>
    </UIPageHeader>

    @if (!string.IsNullOrWhiteSpace(deleteError))
    {
        <UIAlert Variant="UiAlertVariant.Danger" Class="mb-6">@deleteError</UIAlert>
    }

    @if (!string.IsNullOrWhiteSpace(sighting.Notes))
    {
        <UICard Class="mt-2">
            <h2 class="text-sm font-semibold text-slate-900 dark:text-slate-50">Notes</h2>
            <p class="mt-2 text-sm leading-relaxed text-slate-700 dark:text-slate-200">@sighting.Notes</p>
        </UICard>
    }

    <UICard Title="Photos" Class="@(!string.IsNullOrWhiteSpace(sighting.Notes) ? "mt-6" : "mt-2")">
        <InputFile OnChange="UploadAsync" multiple accept="image/*"
                   class="block w-full cursor-pointer rounded-xl border border-dashed border-slate-200/90 bg-slate-50/50 px-4 py-6 text-sm text-slate-600 transition duration-200 file:mr-4 file:cursor-pointer file:rounded-lg file:border-0 file:bg-[var(--accent)] file:px-4 file:py-2 file:text-sm file:font-semibold file:text-white hover:border-slate-300 dark:border-slate-700 dark:bg-slate-950/50 dark:text-slate-300 dark:hover:border-slate-600" />
        @if (!string.IsNullOrWhiteSpace(uploadError))
        {
            <p class="mt-3 text-sm text-red-700 dark:text-red-300">@uploadError</p>
        }
        @if (sighting.Photos.Count == 0)
        {
            <p class="mt-4 text-sm text-slate-600 dark:text-slate-400">No photos yet. Upload images above.</p>
        }
        else
        {
            <div class="mt-6 grid grid-cols-2 gap-4 md:grid-cols-4">
                @foreach (var p in sighting.Photos)
                {
                    <a href="@($"/photos/{p.Id}")" class="group block overflow-hidden rounded-xl border border-slate-200/80 shadow-sm transition duration-200 ease-in-out hover:border-slate-300 hover:shadow-md dark:border-slate-700 dark:hover:border-slate-600">
                        <img src="@($"/photos/{p.Id}")" alt="@p.OriginalFileName" class="h-32 w-full object-cover transition duration-200 group-hover:scale-[1.02]" />
                    </a>
                }
            </div>
        }
    </UICard>

    <UICard Title="Delete sighting" Class="mt-8">
        <p class="text-sm leading-relaxed text-slate-600 dark:text-slate-300">Deletes this sighting and all attached photos from storage.</p>
        @if (showDeleteConfirm)
        {
            <div class="mt-4 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
                <UIButton Variant="UiButtonVariant.Outline" Class="w-full sm:w-auto" @onclick="CancelDelete">Cancel</UIButton>
                <UIButton Variant="UiButtonVariant.Danger" Class="w-full sm:w-auto" @onclick="ConfirmDeleteAsync">Delete permanently</UIButton>
            </div>
        }
        else
        {
            <div class="mt-4">
                <UIButton Variant="UiButtonVariant.Outline" Class="border-red-200 text-red-800 hover:bg-red-50 dark:border-red-900/60 dark:text-red-200 dark:hover:bg-red-950/40" @onclick="() => showDeleteConfirm = true">Delete sighting…</UIButton>
            </div>
        }
    </UICard>
}

@code {
    [Parameter] public int Id { get; set; }

    private bool loading = true;
    private Sighting? sighting;
    private string? uploadError;
    private bool showDeleteConfirm;
    private string? deleteError;

    protected override async Task OnParametersSetAsync()
    {
        loading = true;
        showDeleteConfirm = false;
        deleteError = null;
        sighting = await Sightings.GetAsync(Id);
        loading = false;
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        deleteError = null;
    }

    private async Task ConfirmDeleteAsync()
    {
        deleteError = null;
        try
        {
            await Sightings.DeleteAsync(Id);
            Nav.NavigateTo("/");
        }
        catch (Exception ex)
        {
            deleteError = ex.Message;
            showDeleteConfirm = false;
        }
    }

    private async Task UploadAsync(InputFileChangeEventArgs e)
    {
        uploadError = null;
        if (sighting is null)
            return;

        try
        {
            foreach (var file in e.GetMultipleFiles())
            {
                var stored = await Storage.SaveAsync(file);

                Db.SightingPhotos.Add(new SightingPhoto
                {
                    SightingId = sighting.Id,
                    StoredPath = stored.StoredRelativePath,
                    OriginalFileName = stored.OriginalFileName,
                    ContentType = stored.ContentType,
                    SizeBytes = stored.SizeBytes,
                    CreatedAtUtc = DateTime.UtcNow
                });
            }

            await Db.SaveChangesAsync();
            sighting = await Sightings.GetAsync(Id);
        }
        catch (Exception ex)
        {
            uploadError = ex.Message;
        }
    }
}
