@page "/sightings/{Id:int}"
@rendermode InteractiveServer
@implements IDisposable

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Web
@attribute [Authorize]

@using AnimalTracker.Services
@using AnimalTracker.Data.Entities
@using AnimalTracker.Data
@inject SightingService Sightings
@inject ApplicationDbContext Db
@inject NavigationManager Nav
@inject AnimalTracker.State.UserPreferencesState Prefs

<PageTitle>Sighting</PageTitle>

@if (loading)
{
    <p class="text-sm text-slate-600 dark:text-slate-400">Loading…</p>
}
else if (sighting is null)
{
    <UIAlert Variant="UiAlertVariant.Neutral">Sighting not found.</UIAlert>
}
else
{
    <UIPageHeader Title="@sighting.Species.Name"
                  Description="@($"{sighting.OccurredAtUtc.ToLocalTime():f} · {sighting.Location.Name}")">
        <Actions>
            <UIButton Href="/" Variant="UiButtonVariant.Outline">Back to timeline</UIButton>
            <UIButton Href="@($"/sightings/{Id}/edit")" Variant="UiButtonVariant.Outline">Edit</UIButton>
        </Actions>
    </UIPageHeader>

    @if (!string.IsNullOrWhiteSpace(deleteError))
    {
        <UIAlert Variant="UiAlertVariant.Danger" Class="mb-6">@deleteError</UIAlert>
    }

    @if (!string.IsNullOrWhiteSpace(sighting.Notes))
    {
        <UICard Class="mt-2">
            <h2 class="text-sm font-semibold text-slate-900 dark:text-slate-50">Notes</h2>
            <p class="mt-2 text-sm leading-relaxed text-slate-700 dark:text-slate-200">@sighting.Notes</p>
        </UICard>
    }

    <UICard Title="Observation details" Class="@(!string.IsNullOrWhiteSpace(sighting.Notes) ? "mt-6" : "mt-2")">
        <dl class="grid grid-cols-1 gap-4 text-sm sm:grid-cols-2">
            <div>
                <dt class="text-slate-500 dark:text-slate-400">Behavior</dt>
                <dd class="mt-1 text-slate-900 dark:text-slate-50">@((sighting.Behavior?.ToString()) ?? "Not specified")</dd>
            </div>
            <div>
                <dt class="text-slate-500 dark:text-slate-400">Observed until</dt>
                <dd class="mt-1 text-slate-900 dark:text-slate-50">@((sighting.ObservedUntilUtc?.ToLocalTime().ToString("g")) ?? "Not specified")</dd>
            </div>
            <div>
                <dt class="text-slate-500 dark:text-slate-400">Species confidence</dt>
                <dd class="mt-1 text-slate-900 dark:text-slate-50">@((sighting.SpeciesConfidence?.ToString()) ?? "Not specified")</dd>
            </div>
            <div>
                <dt class="text-slate-500 dark:text-slate-400">Individual confidence</dt>
                <dd class="mt-1 text-slate-900 dark:text-slate-50">@((sighting.IndividualConfidence?.ToString()) ?? "Not specified")</dd>
            </div>
            <div class="sm:col-span-2">
                <dt class="text-slate-500 dark:text-slate-400">Coordinates</dt>
                <dd class="mt-1 text-slate-900 dark:text-slate-50">
                    @if (sighting.Latitude is not null && sighting.Longitude is not null)
                    {
                        <span>@sighting.Latitude.Value.ToString("0.000000"), @sighting.Longitude.Value.ToString("0.000000")</span>
                        @if (sighting.LocationAccuracyMeters is not null)
                        {
                            <span class="ml-2 text-slate-600 dark:text-slate-300">(accuracy ~@sighting.LocationAccuracyMeters.Value.ToString("0.0") m)</span>
                        }
                    }
                    else
                    {
                        <span>Not specified</span>
                    }
                </dd>
            </div>
        </dl>
    </UICard>

    <UICard Title="Photos" Class="mt-6">
        @if (sighting.Photos.Count == 0)
        {
            <p class="text-sm text-slate-600 dark:text-slate-400">No photos for this sighting.</p>
        }
        else
        {
            <p class="text-xs text-slate-500 dark:text-slate-400">Click a photo to use it as the page background, or choose View for a clean fullscreen preview.</p>
            <div class="mt-6 grid grid-cols-2 gap-4 md:grid-cols-4">
                @foreach (var item in sighting.Photos.Select((photo, index) => new { photo, index }))
                {
                    <div class="overflow-hidden rounded-xl border border-slate-200/80 bg-white/65 shadow-sm transition duration-200 ease-in-out hover:border-slate-300 hover:shadow-md dark:border-slate-700 dark:bg-slate-950/35 dark:hover:border-slate-600">
                        <button type="button"
                                title="Use as background"
                                @onclick="() => SetBackgroundPhoto(item.photo.Id)"
                                class="group block w-full bg-transparent p-0 text-left">
                            <img src="@($"/photos/{item.photo.Id}")"
                                 alt="@GetPhotoAlt(item.photo)"
                                 class="h-32 w-full object-cover transition duration-200 group-hover:scale-[1.02]" />
                        </button>
                        <div class="flex items-center justify-between gap-2 border-t border-slate-200/80 px-3 py-2 dark:border-slate-800/80">
                            <button type="button"
                                    class="rounded-lg px-2.5 py-1.5 text-xs font-medium text-slate-700 transition duration-200 hover:bg-slate-100 hover:text-slate-900 dark:text-slate-200 dark:hover:bg-slate-800 dark:hover:text-slate-50"
                                    @onclick="() => OpenPhotoViewer(item.index)">
                                View
                            </button>
                            <span class="text-[11px] font-medium uppercase tracking-[0.12em] @(selectedBackgroundPhotoId == item.photo.Id ? "text-[color:var(--accent)]" : "text-slate-400 dark:text-slate-500")">
                                @(selectedBackgroundPhotoId == item.photo.Id ? "Background active" : "Background")
                            </span>
                        </div>
                    </div>
                }
            </div>
        }
    </UICard>

    <UICard Title="Delete sighting" Class="mt-8">
        <p class="text-sm leading-relaxed text-slate-600 dark:text-slate-300">Deletes this sighting and all attached photos from storage.</p>
        @if (showDeleteConfirm)
        {
            <div class="mt-4 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
                <UIButton Variant="UiButtonVariant.Outline" Class="w-full sm:w-auto" @onclick="CancelDelete">Cancel</UIButton>
                <UIButton Variant="UiButtonVariant.Danger" Class="w-full sm:w-auto" @onclick="ConfirmDeleteAsync">Delete permanently</UIButton>
            </div>
        }
        else
        {
            <div class="mt-4">
                <UIButton Variant="UiButtonVariant.Outline" Class="border-red-200 text-red-800 hover:bg-red-50 dark:border-red-900/60 dark:text-red-200 dark:hover:bg-red-950/40" @onclick="() => showDeleteConfirm = true">Delete sighting…</UIButton>
            </div>
        }
    </UICard>

    @if (ActiveViewerPhoto is not null)
    {
        <section class="fixed inset-0 z-[1810] bg-slate-950"
                 role="dialog"
                 aria-modal="true"
                 aria-label="Photo viewer"
                 tabindex="0"
                 autofocus
                 @onkeydown="HandleViewerKeyDown"
                 @onclick="ClosePhotoViewer">
            <img src="@($"/photos/{ActiveViewerPhoto.Id}")"
                 alt="@GetPhotoAlt(ActiveViewerPhoto)"
                 class="h-screen w-screen object-contain" />
        </section>
    }
}

@code {
    [Parameter] public int Id { get; set; }

    private bool loading = true;
    private Sighting? sighting;
    private bool showDeleteConfirm;
    private string? deleteError;
    private IDisposable? backgroundScope;
    private int? selectedBackgroundPhotoId;
    private int activeViewerIndex = -1;

    private SightingPhoto? ActiveViewerPhoto =>
        sighting is not null && activeViewerIndex >= 0 && activeViewerIndex < sighting.Photos.Count
            ? sighting.Photos[activeViewerIndex]
            : null;

    protected override async Task OnParametersSetAsync()
    {
        loading = true;
        showDeleteConfirm = false;
        deleteError = null;
        activeViewerIndex = -1;
        selectedBackgroundPhotoId = null;
        sighting = await Sightings.GetAsync(Id);
        backgroundScope?.Dispose();
        backgroundScope = null;
        if (sighting?.Photos.Count > 0)
        {
            selectedBackgroundPhotoId = sighting.Photos[0].Id;
            backgroundScope = Prefs.UseTemporaryBackground($"/photos/{selectedBackgroundPhotoId}");
        }
        loading = false;
    }

    public void Dispose()
    {
        backgroundScope?.Dispose();
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        deleteError = null;
    }

    private async Task ConfirmDeleteAsync()
    {
        deleteError = null;
        try
        {
            await Sightings.DeleteAsync(Id);
            Nav.NavigateTo("/");
        }
        catch (Exception ex)
        {
            deleteError = ex.Message;
            showDeleteConfirm = false;
        }
    }

    private void SetBackgroundPhoto(int photoId)
    {
        backgroundScope?.Dispose();
        selectedBackgroundPhotoId = photoId;
        backgroundScope = Prefs.UseTemporaryBackground($"/photos/{photoId}");
    }

    private void OpenPhotoViewer(int index)
    {
        if (sighting is null || index < 0 || index >= sighting.Photos.Count)
            return;

        activeViewerIndex = index;
    }

    private void ClosePhotoViewer() =>
        activeViewerIndex = -1;

    private void ShowPreviousPhoto()
    {
        if (sighting is null || sighting.Photos.Count == 0)
            return;

        activeViewerIndex = activeViewerIndex <= 0
            ? sighting.Photos.Count - 1
            : activeViewerIndex - 1;
    }

    private void ShowNextPhoto()
    {
        if (sighting is null || sighting.Photos.Count == 0)
            return;

        activeViewerIndex = activeViewerIndex >= sighting.Photos.Count - 1
            ? 0
            : activeViewerIndex + 1;
    }

    private void HandleViewerKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Escape")
            ClosePhotoViewer();
    }

    private static string GetPhotoAlt(SightingPhoto photo) =>
        string.IsNullOrWhiteSpace(photo.OriginalFileName)
            ? "Sighting photo"
            : photo.OriginalFileName;

    // Photo upload moved to Add Sighting.
}
