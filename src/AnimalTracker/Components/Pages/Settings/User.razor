@page "/settings"
@rendermode InteractiveServer
@implements IDisposable

@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

@using AnimalTracker.Services
@using AnimalTracker.Components.UI
@using Microsoft.AspNetCore.Components.Forms
@inject UserSettingsService Settings
@inject AppSettingsService AppSettings
@inject AnimalTracker.State.UserPreferencesState Prefs
@inject AnimalTracker.State.UiProgressState UiProgress
@inject IJSRuntime JS

<PageTitle>Settings</PageTitle>

<UIPageHeader Title="Settings" Description="Locations, species catalog, and preferences for your account." />

@if (!string.IsNullOrWhiteSpace(message))
{
    <UIAlert Variant="@(message.StartsWith("Error", StringComparison.OrdinalIgnoreCase) ? UiAlertVariant.Danger : UiAlertVariant.Success)" Class="mb-8">
        @message
    </UIAlert>
}

@if (!string.IsNullOrWhiteSpace(bgMessage))
{
    <UIAlert Variant="@(bgMessage.StartsWith("Error", StringComparison.OrdinalIgnoreCase) ? UiAlertVariant.Danger : UiAlertVariant.Success)" Class="mb-8">
        @bgMessage
    </UIAlert>
}

<UICard Title="User preferences">
    <EditForm Model="model" class="space-y-8">
        <DataAnnotationsValidator />
        @if (!string.IsNullOrWhiteSpace(preferencesMessage))
        {
            <p class="text-sm text-slate-600 dark:text-slate-300">@preferencesMessage</p>
        }

        <div class="grid min-w-0 grid-cols-1 gap-8 md:grid-cols-2">
            <UIField Label="Highlight color" For="accent" Hint="Hex format like #22c55e">
                <div class="flex min-w-0 flex-wrap items-center gap-3 sm:gap-4">
                    <input id="accent" type="color" class="h-11 w-16 shrink-0 cursor-pointer rounded-xl border border-slate-200/90 bg-white p-1 shadow-sm dark:border-slate-700 dark:bg-slate-900"
                           @bind="model.AccentColorHex"
                           @bind:after="OnPreferencesChangedAsync" />
                    <input type="text"
                           class="min-w-0 flex-1 rounded-xl border border-slate-200/90 bg-white px-3 py-2.5 text-sm shadow-sm transition duration-200 ease-in-out hover:border-slate-300 hover:shadow-sm focus:border-slate-300 focus:outline-none focus:ring-4 focus:ring-slate-200/70 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-50 dark:hover:border-slate-600 dark:focus:ring-slate-800/80"
                           @bind="model.AccentColorHex"
                           @bind:after="OnPreferencesChangedAsync" />
                </div>
            </UIField>

            <UIField Label="Timeline page size" For="pageSize">
                <SearchableCombobox TValue="int"
                                    Id="pageSize"
                                    Items="@ComboboxOptionList.TimelinePageSizes"
                                    @bind-Value="model.TimelinePageSize"
                                    @bind-Value:after="OnPreferencesChangedAsync"
                                    Placeholder="Timeline page size"
                                    ChevronAriaLabel="Timeline page size options"
                                    NoResultsText="No options" />
            </UIField>
        </div>

        <UIField Label="Theme" For="themeMode" Hint="Choose Light, Dark, or follow your system setting.">
            <SearchableCombobox TValue="string"
                                Id="themeMode"
                                Items="@ComboboxOptionList.UserThemeModes"
                                Value="@model.ThemeMode"
                                ValueChanged="OnThemeModeValueChangedAsync"
                                Placeholder="Theme"
                                ChevronAriaLabel="Theme options"
                                NoResultsText="No options"
                                Class="max-w-xs" />
        </UIField>

        <UIField Label="Panel opacity" For="surfaceOpacity"
                 Hint="Controls how see-through the sidebar, main panel, and cards are in the active theme mode.">
            <div class="max-w-xl rounded-xl border border-slate-200/90 bg-white/70 px-4 py-3 shadow-sm dark:border-slate-700 dark:bg-slate-950/40">
                <div class="flex items-center justify-between gap-3">
                    <input id="surfaceOpacity"
                           type="range"
                           min="35"
                           max="100"
                           step="1"
                           class="h-2 w-full cursor-pointer accent-[var(--accent)]"
                           @bind="ActiveSurfaceOpacityPercent"
                           @bind:event="oninput"
                           @bind:after="OnPreferencesChangedAsync" />
                    <span class="min-w-12 text-right text-sm font-semibold text-slate-700 dark:text-slate-200">@ActiveSurfaceOpacityPercent%</span>
                </div>
            </div>
        </UIField>

        <UIField Label="Compact layout" For="compact"
                 Hint="Saves automatically: less padding in the main column and inside cards, slightly smaller page titles, and denser rows on Timeline and Animals.">
            <label for="compact"
                   class="flex min-h-[2.75rem] w-full max-w-xl cursor-pointer items-center gap-3 rounded-xl border border-slate-200/90 bg-white px-4 py-2.5 shadow-sm transition duration-200 ease-in-out hover:border-slate-300/90 dark:border-slate-700 dark:bg-slate-950/40 dark:hover:border-slate-600">
                <InputCheckbox id="compact" class="checkbox-soft size-[1.125rem] shrink-0"
                               @bind-Value="model.CompactMode"
                               @bind-Value:after="OnPreferencesChangedAsync" />
                <span class="select-none text-sm font-medium text-slate-800 dark:text-slate-100">Tighter spacing across the app</span>
            </label>
        </UIField>
    </EditForm>
</UICard>

<UICard Title="Background image" Class="mt-8">
    <p class="text-sm leading-relaxed text-slate-600 dark:text-slate-300">Optional wallpaper behind the app (JPEG, PNG, GIF, or WebP, up to 15 MB). Images are resized/compressed on upload for performance.</p>
    <div class="mt-4 flex min-w-0 flex-col gap-4 sm:flex-row sm:flex-wrap sm:items-center">
        <InputFile OnChange="UploadBackgroundAsync" accept="image/jpeg,image/png,image/gif,image/webp,.jpg,.jpeg,.png,.gif,.webp"
                   class="block w-full min-w-0 cursor-pointer rounded-xl border border-dashed border-slate-200/90 bg-slate-50/50 px-4 py-3 text-sm text-slate-600 shadow-sm transition duration-200 ease-in-out hover:border-slate-300 hover:bg-slate-50 dark:border-slate-700 dark:bg-slate-950/50 dark:text-slate-300 dark:hover:border-slate-600 dark:hover:bg-slate-950/60 file:mr-4 file:cursor-pointer file:rounded-lg file:border-0 file:bg-[var(--accent)] file:px-4 file:py-2 file:text-sm file:font-semibold file:text-white file:shadow-sm file:transition file:duration-200 hover:file:brightness-[0.96]" />
        @if (hasBackground)
        {
            <UIButton Variant="UiButtonVariant.Outline" @onclick="ClearBackgroundAsync">Remove background</UIButton>
        }
    </div>
    @if (hasBackground)
    {
        <div class="mt-4 overflow-hidden rounded-xl border border-slate-200/80 dark:border-slate-800/80">
            <img src="@($"/user/background-image?t={Prefs.UiStamp}")" alt="Current background preview" class="h-32 w-full object-cover" />
        </div>
    }
</UICard>

<UICard Title="Locations" Class="mt-8">
    <p class="text-sm leading-relaxed text-slate-600 dark:text-slate-300">Where sightings occur. You must keep at least one location; sightings using a removed location are moved to another of yours.</p>

    <div class="mt-6 flex flex-col gap-6 md:flex-row md:items-end">
        <UIField Label="New location name" For="name" Class="min-w-0 flex-1">
            <input id="name" type="text" class="w-full px-3 py-2.5" @bind="newLocationName" />
        </UIField>
        <UIButton Variant="UiButtonVariant.Primary" Class="shrink-0" @onclick="CreateLocationAsync">Add location</UIButton>
    </div>

    <div class="mt-8">
        @if (locationsLoading)
        {
            <p class="text-sm text-slate-600 dark:text-slate-400">Loading…</p>
        }
        else if (locations.Count == 0)
        {
            <p class="text-sm text-slate-700 dark:text-slate-200">No locations yet.</p>
        }
        else
        {
            <ul class="divide-y divide-slate-200/80 overflow-hidden rounded-xl border border-slate-200/80 dark:divide-slate-800/80 dark:border-slate-800/80">
                @foreach (var l in locations)
                {
                    <li class="flex flex-col gap-3 bg-slate-50/30 px-4 py-4 transition duration-200 hover:bg-slate-50/80 dark:bg-transparent dark:hover:bg-slate-800/40 sm:flex-row sm:items-center sm:justify-between">
                        <div class="min-w-0">
                            <div class="text-sm font-semibold text-slate-900 dark:text-slate-50">@l.Name</div>
                            @if (!string.IsNullOrWhiteSpace(l.Notes))
                            {
                                <div class="mt-1 text-sm leading-relaxed text-slate-600 dark:text-slate-300">@l.Notes</div>
                            }
                        </div>
                        @if (locations.Count > 1)
                        {
                            <UIButton Variant="UiButtonVariant.Danger" Size="UiButtonSize.Sm" Class="w-full shrink-0 sm:w-auto" @onclick="() => DeleteLocationAsync(l.Id)">Delete</UIButton>
                        }
                    </li>
                }
            </ul>
        }
    </div>
</UICard>

<UICard Title="Species catalog" Class="mt-8">
    <p class="text-sm leading-relaxed text-slate-600 dark:text-slate-300">Choose your region first, then sync species for that region. Cached regions are reused until you re-sync.</p>
    <p class="mt-2 text-xs text-slate-500 dark:text-slate-400">Taxa scope: Animals only.</p>

    <div class="mt-6 space-y-4">
        <div class="grid min-w-0 grid-cols-1 gap-4 sm:grid-cols-[1fr_auto] sm:items-end">
            <UIField Label="Search region" For="regionQuery">
                <input id="regionQuery"
                       class="w-full min-w-0 rounded-xl border border-slate-200/90 bg-white px-3 py-2.5 text-sm shadow-sm transition duration-200 ease-in-out hover:border-slate-300 hover:shadow-sm focus:border-slate-300 focus:outline-none focus:ring-4 focus:ring-slate-200/70 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-50 dark:hover:border-slate-600 dark:focus:ring-slate-800/80"
                       placeholder="e.g. Glasgow, Scotland, UK"
                       @bind="regionQuery"
                       @bind:event="oninput" />
            </UIField>
            <UIButton Variant="UiButtonVariant.Outline" Class="w-full sm:w-auto" @onclick="SearchRegionsAsync">Find regions</UIButton>
        </div>

        @if (regionResults.Count > 0)
        {
            <div class="grid min-w-0 grid-cols-1 gap-4 sm:grid-cols-[1fr_auto] sm:items-end">
                <UIField Label="Matching regions" For="regionSelect">
                    <select id="regionSelect"
                            class="w-full min-w-0 rounded-xl border border-slate-200/90 bg-white px-3 py-2.5 text-sm shadow-sm transition duration-200 ease-in-out hover:border-slate-300 hover:shadow-sm focus:border-slate-300 focus:outline-none focus:ring-4 focus:ring-slate-200/70 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-50 dark:hover:border-slate-600 dark:focus:ring-slate-800/80"
                            @bind="selectedRegionKey">
                        @foreach (var region in regionResults)
                        {
                            <option value="@region.RegionKey">@region.RegionName</option>
                        }
                    </select>
                </UIField>
                <UIButton Variant="UiButtonVariant.Primary" Class="w-full sm:w-auto" @onclick="SelectRegionAsync">Use region</UIButton>
            </div>
        }

        <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
            <div class="text-xs text-slate-500 dark:text-slate-400">
                Active region: @(string.IsNullOrWhiteSpace(activeSpeciesRegionName) ? "Not selected" : activeSpeciesRegionName)
            </div>
            <UIButton Variant="UiButtonVariant.Primary" Class="w-full shrink-0 sm:w-auto" Disabled="@(!hasActiveSpeciesRegion)" @onclick="SyncSpeciesCatalogAsync">Sync selected region</UIButton>
            <UIButton Variant="UiButtonVariant.Outline" Class="w-full shrink-0 sm:w-auto" Disabled="@(!hasActiveSpeciesRegion)" @onclick="ResyncSpeciesCatalogAsync">Re-sync selected region</UIButton>
        </div>

        @if (!hasActiveSpeciesRegion)
        {
            <p class="text-xs text-slate-500 dark:text-slate-400">Species lists stay empty until a region is selected.</p>
        }

        <div class="pt-1">
            <UIButton Href="/species" Variant="UiButtonVariant.Outline" Size="UiButtonSize.Sm">Open species lookup</UIButton>
        </div>
    </div>
</UICard>

@code {
    private string? message;
    private string? bgMessage;
    private string? preferencesMessage;
    private readonly Model model = new();

    [Inject] private LocationService LocationService { get; set; } = default!;
    [Inject] private SpeciesCatalogSyncService SpeciesCatalogSyncService { get; set; } = default!;

    private bool locationsLoading = true;
    private List<AnimalTracker.Data.Entities.Location> locations = [];
    private string newLocationName = "";
    private string regionQuery = "";
    private List<SpeciesRegionOption> regionResults = [];
    private string? selectedRegionKey;
    private string? selectedRegionName;
    private bool hasActiveSpeciesRegion;
    private string? activeSpeciesRegionName;

    private bool hasBackground;
    private CancellationTokenSource? preferencesSaveCts;
    private int preferencesSaveVersion;
    private bool isDarkModeActive;

    private int ActiveSurfaceOpacityPercent
    {
        get => isDarkModeActive ? model.DarkSurfaceOpacityPercent : model.SurfaceOpacityPercent;
        set
        {
            if (isDarkModeActive)
                model.DarkSurfaceOpacityPercent = value;
            else
                model.SurfaceOpacityPercent = value;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await ReloadSettingsModelAsync();
        await ReloadAppSettingsModelAsync();
        await ReloadLocationsAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var changed = await RefreshEffectiveThemeModeAsync();
        if (changed)
            await InvokeAsync(StateHasChanged);
    }

    private async Task ReloadSettingsModelAsync()
    {
        var s = await Settings.GetOrCreateAsync();
        Prefs.Apply(s);
        model.AccentColorHex = s.AccentColorHex;
        model.CompactMode = s.CompactMode;
        model.TimelinePageSize = s.TimelinePageSize;
        model.ThemeMode = NormalizeThemeMode(s.ThemeMode);
        model.SurfaceOpacityPercent = s.SurfaceOpacityPercent is < 35 or > 100 ? 93 : s.SurfaceOpacityPercent;
        model.DarkSurfaceOpacityPercent = s.DarkSurfaceOpacityPercent is < 35 or > 100 ? 50 : s.DarkSurfaceOpacityPercent;
        hasBackground = !string.IsNullOrWhiteSpace(s.BackgroundImageRelativePath);
    }

    private async Task ReloadLocationsAsync()
    {
        locationsLoading = true;
        locations = await LocationService.GetAllAsync();
        if (locations.Count == 0)
        {
            await LocationService.GetOrCreateDefaultAsync();
            locations = await LocationService.GetAllAsync();
        }
        locationsLoading = false;
    }

    private async Task ReloadAppSettingsModelAsync()
    {
        var app = await AppSettings.GetOrCreateAsync();
        selectedRegionKey = app.ActiveSpeciesRegionKey;
        selectedRegionName = app.ActiveSpeciesRegionName;
        activeSpeciesRegionName = app.ActiveSpeciesRegionName;
        hasActiveSpeciesRegion = !string.IsNullOrWhiteSpace(app.ActiveSpeciesRegionKey);
    }

    private async Task OnThemeModeValueChangedAsync(string value)
    {
        model.ThemeMode = NormalizeThemeMode(value);
        Prefs.SetThemeMode(model.ThemeMode);

        try
        {
            isDarkModeActive = await JS.InvokeAsync<bool>("animalTrackerResolveDark", model.ThemeMode);
            await JS.InvokeVoidAsync("animalTrackerSetTheme", model.ThemeMode);
        }
        catch
        {
            isDarkModeActive = string.Equals(model.ThemeMode, "dark", StringComparison.OrdinalIgnoreCase);
        }
        await SavePreferencesImmediateAsync();
    }

    private Task OnPreferencesChangedAsync() =>
        QueuePreferencesSaveAsync();

    private async Task<bool> RefreshEffectiveThemeModeAsync()
    {
        bool resolved;
        try
        {
            resolved = await JS.InvokeAsync<bool>("animalTrackerIsDarkActive");
        }
        catch
        {
            resolved = string.Equals(model.ThemeMode, "dark", StringComparison.OrdinalIgnoreCase);
        }

        if (resolved == isDarkModeActive)
            return false;

        isDarkModeActive = resolved;
        return true;
    }

    private Task QueuePreferencesSaveAsync()
    {
        CancelPendingPreferencesSave();
        preferencesSaveCts = new CancellationTokenSource();
        var token = preferencesSaveCts.Token;
        var version = ++preferencesSaveVersion;

        preferencesMessage = "Saving…";
        _ = SavePreferencesQueuedAsync(version, token);
        return Task.CompletedTask;
    }

    private async Task SavePreferencesImmediateAsync()
    {
        CancelPendingPreferencesSave();
        preferencesMessage = "Saving…";
        var version = ++preferencesSaveVersion;
        try
        {
            var saved = await Settings.UpdateAsync(
                model.AccentColorHex,
                model.CompactMode,
                model.TimelinePageSize,
                model.ThemeMode,
                model.SurfaceOpacityPercent,
                model.DarkSurfaceOpacityPercent);

            if (version != preferencesSaveVersion)
                return;

            model.AccentColorHex = saved.AccentColorHex;
            model.CompactMode = saved.CompactMode;
            model.TimelinePageSize = saved.TimelinePageSize;
            model.ThemeMode = NormalizeThemeMode(saved.ThemeMode);
            model.SurfaceOpacityPercent = saved.SurfaceOpacityPercent;
            model.DarkSurfaceOpacityPercent = saved.DarkSurfaceOpacityPercent;
            Prefs.Apply(saved);
            hasBackground = !string.IsNullOrWhiteSpace(saved.BackgroundImageRelativePath);
            preferencesMessage = "Saved.";
        }
        catch (Exception ex)
        {
            if (version == preferencesSaveVersion)
                preferencesMessage = $"Error: {ex.Message}";
        }
    }

    private async Task SavePreferencesQueuedAsync(int version, CancellationToken cancellationToken)
    {
        try
        {
            await Task.Delay(250, cancellationToken);
            var saved = await Settings.UpdateAsync(
                model.AccentColorHex,
                model.CompactMode,
                model.TimelinePageSize,
                model.ThemeMode,
                model.SurfaceOpacityPercent,
                model.DarkSurfaceOpacityPercent,
                cancellationToken);

            if (cancellationToken.IsCancellationRequested || version != preferencesSaveVersion)
                return;

            model.AccentColorHex = saved.AccentColorHex;
            model.CompactMode = saved.CompactMode;
            model.TimelinePageSize = saved.TimelinePageSize;
            model.ThemeMode = NormalizeThemeMode(saved.ThemeMode);
            model.SurfaceOpacityPercent = saved.SurfaceOpacityPercent;
            model.DarkSurfaceOpacityPercent = saved.DarkSurfaceOpacityPercent;
            Prefs.Apply(saved);
            hasBackground = !string.IsNullOrWhiteSpace(saved.BackgroundImageRelativePath);
            preferencesMessage = "Saved.";
        }
        catch (OperationCanceledException)
        {
            return;
        }
        catch (Exception ex)
        {
            if (version == preferencesSaveVersion)
                preferencesMessage = $"Error: {ex.Message}";
        }
        finally
        {
            if (version == preferencesSaveVersion)
                await InvokeAsync(StateHasChanged);
        }
    }

    private async Task UploadBackgroundAsync(InputFileChangeEventArgs e)
    {
        bgMessage = null;
        try
        {
            var file = e.File;
            if (file is null)
                return;

            // Upload is persisted immediately so the wallpaper can apply without requiring "Save preferences".
            var saved = await Settings.SetBackgroundImageAsync(file);
            Prefs.Apply(saved);
            hasBackground = true;
            bgMessage = "Background image updated.";
        }
        catch (ArgumentException ex) when (ex.ParamName == "file")
        {
            // User-friendly upload failures (size/type/empty)
            bgMessage = $"Error: {ex.Message}";
        }
        catch (Exception ex)
        {
            bgMessage = $"Error: {ex.Message}";
        }
    }

    private async Task ClearBackgroundAsync()
    {
        bgMessage = null;
        try
        {
            var saved = await Settings.ClearBackgroundImageAsync();
            Prefs.Apply(saved);
            hasBackground = false;
            bgMessage = "Background removed.";
        }
        catch (Exception ex)
        {
            bgMessage = $"Error: {ex.Message}";
        }
    }

    private async Task CreateLocationAsync()
    {
        if (string.IsNullOrWhiteSpace(newLocationName))
            return;

        await LocationService.CreateAsync(newLocationName, notes: null);
        newLocationName = "";
        await ReloadLocationsAsync();
    }

    private async Task DeleteLocationAsync(int id)
    {
        message = null;
        try
        {
            await LocationService.DeleteAsync(id);
            await ReloadLocationsAsync();
            message = "Location deleted. Any sightings that used it were moved to another location.";
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
        }
    }

    private async Task SyncSpeciesCatalogAsync()
    {
        message = null;
        using var progress = UiProgress.Begin("Syncing species catalog");
        try
        {
            var result = await SpeciesCatalogSyncService.SyncActiveRegionAsync(forceRefresh: false);
            if (result is null)
            {
                message = "Select a region first.";
                return;
            }

            message = result.UsedCache
                ? $"Using cached species for {result.RegionName}. Click re-sync to refresh."
                : $"Species synced for {result.RegionName} ({result.UpdatedCount} updates).";
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
        }
    }

    private async Task ResyncSpeciesCatalogAsync()
    {
        message = null;
        using var progress = UiProgress.Begin("Re-syncing species catalog");
        try
        {
            var result = await SpeciesCatalogSyncService.SyncActiveRegionAsync(forceRefresh: true);
            if (result is null)
            {
                message = "Select a region first.";
                return;
            }

            message = $"Region re-synced for {result.RegionName} ({result.UpdatedCount} updates).";
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
        }
    }

    private async Task SearchRegionsAsync()
    {
        message = null;
        using var progress = UiProgress.Begin("Searching regions");
        regionResults = await SpeciesCatalogSyncService.SearchRegionsAsync(regionQuery);
        if (regionResults.Count == 0)
        {
            selectedRegionKey = null;
            selectedRegionName = null;
            message = "No matching regions found.";
            return;
        }

        selectedRegionKey = regionResults[0].RegionKey;
        selectedRegionName = regionResults[0].RegionName;
    }

    private async Task SelectRegionAsync()
    {
        if (string.IsNullOrWhiteSpace(selectedRegionKey))
        {
            message = "Pick a region first.";
            return;
        }

        var region = regionResults.FirstOrDefault(x => x.RegionKey == selectedRegionKey);
        if (region is null)
        {
            message = "Selected region is no longer in the result list. Search again.";
            return;
        }

        using var progress = UiProgress.Begin("Applying region");
        await AppSettings.UpdateActiveSpeciesRegionAsync(region.RegionKey, region.RegionName);
        await ReloadAppSettingsModelAsync();
        message = $"Active species region set to {region.RegionName}.";
    }

    private sealed class Model
    {
        [System.ComponentModel.DataAnnotations.Required]
        public string AccentColorHex { get; set; } = "#0f172a";

        public bool CompactMode { get; set; }

        public int TimelinePageSize { get; set; } = 50;

        [System.ComponentModel.DataAnnotations.Required]
        public string ThemeMode { get; set; } = "system";

        [System.ComponentModel.DataAnnotations.Range(35, 100)]
        public int SurfaceOpacityPercent { get; set; } = 93;

        [System.ComponentModel.DataAnnotations.Range(35, 100)]
        public int DarkSurfaceOpacityPercent { get; set; } = 50;
    }

    private static string NormalizeThemeMode(string? value)
    {
        var normalized = (value ?? string.Empty).Trim().ToLowerInvariant();
        return normalized is "light" or "dark" ? normalized : "system";
    }

    public void Dispose()
    {
        CancelPendingPreferencesSave();
    }

    private void CancelPendingPreferencesSave()
    {
        preferencesSaveCts?.Cancel();
        preferencesSaveCts?.Dispose();
        preferencesSaveCts = null;
    }
}
