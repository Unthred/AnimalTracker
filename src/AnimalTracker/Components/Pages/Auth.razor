@page "/auth"

@using Microsoft.AspNetCore.Authorization

@attribute [Authorize]

<PageTitle>Auth</PageTitle>

<UIPageHeader Title="Authenticated" Description="You are signed in to AnimalTracker." />

<UICard>
    <AuthorizeView>
        <Authorized>
            <p class="text-sm text-slate-700 dark:text-slate-200">Signed in as <span class="font-semibold text-slate-900 dark:text-slate-50">@context.User.Identity?.Name</span>.</p>
        </Authorized>
    </AuthorizeView>
</UICard>
