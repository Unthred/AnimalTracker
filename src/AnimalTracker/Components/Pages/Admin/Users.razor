@page "/admin/users"
@page "/admin"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = AnimalTracker.Services.AdminUserService.AdminRoleName)]

@using AnimalTracker.Services
@using Microsoft.AspNetCore.Components.Forms
@inject AdminUserService AdminUsers
@inject AppSettingsService AppSettings

<PageTitle>Admin</PageTitle>

<UIPageHeader Title="Admin" Description="Manage users plus default login/register image and theme." />

@if (!string.IsNullOrWhiteSpace(message))
{
    <UIAlert Variant="@(message.StartsWith("Error", StringComparison.OrdinalIgnoreCase) ? UiAlertVariant.Danger : UiAlertVariant.Success)" Class="mb-6">
        @message
    </UIAlert>
}

<UICard Title="All users" BodyPadding="false">
    @if (loading)
    {
        <div class="p-6 text-sm text-slate-600 dark:text-slate-400">Loading…</div>
    }
    else
    {
        <ul class="divide-y divide-slate-200/80 dark:divide-slate-800/80">
            @foreach (var u in users)
            {
                <li class="flex flex-col gap-3 px-4 py-4 sm:flex-row sm:items-center sm:justify-between sm:px-6">
                    <div class="min-w-0">
                        <div class="truncate text-sm font-semibold text-slate-900 dark:text-slate-50">@u.Email</div>
                        <div class="mt-1 text-xs text-slate-500 dark:text-slate-400">
                            @if (u.IsAdmin)
                            {
                                <span class="mr-2 inline-flex items-center rounded-full bg-slate-100 px-2 py-0.5 font-medium text-slate-800 dark:bg-slate-800 dark:text-slate-100">Admin</span>
                            }
                            <span class="mr-2">Confirmed: @(u.EmailConfirmed ? "Yes" : "No")</span>
                            <span>Locked: @(u.IsLockedOut ? "Yes" : "No")</span>
                        </div>
                    </div>

                    <div class="flex flex-col gap-2 sm:flex-row sm:flex-wrap sm:justify-end">
                        @if (u.IsLockedOut)
                        {
                            <UIButton Variant="UiButtonVariant.Outline" Size="UiButtonSize.Sm" Class="w-full sm:w-auto" @onclick="() => UnlockAsync(u.Id)">Unlock</UIButton>
                        }
                        else
                        {
                            <UIButton Variant="UiButtonVariant.Outline" Size="UiButtonSize.Sm" Class="w-full sm:w-auto" @onclick="() => LockAsync(u.Id)">Lock</UIButton>
                        }

                        <UIButton Variant="UiButtonVariant.Outline" Size="UiButtonSize.Sm" Class="w-full sm:w-auto" @onclick="() => ResetPasswordAsync(u.Id)">Reset password</UIButton>

                        <UIButton Variant="UiButtonVariant.Danger" Size="UiButtonSize.Sm" Class="w-full sm:w-auto" Disabled="@(u.IsAdmin)" title="@(u.IsAdmin ? "Don't delete admin users." : "")"
                                  @onclick="() => DeleteAsync(u.Id)">Delete</UIButton>
                    </div>
                </li>
            }
        </ul>
    }
</UICard>

<UICard Title="App defaults" Class="mt-8">
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-2">
        <div>
            <EditForm Model="model" OnValidSubmit="SaveThemeAsync" class="space-y-5">
                <UIField Label="Default theme" For="themeMode" Hint="Used for login/register and as initial preference for new user accounts.">
                    <select id="themeMode" class="w-full max-w-xs min-w-0 px-3 py-2.5" @bind="model.DefaultThemeMode">
                        <option value="system">Follow system</option>
                        <option value="light">Light</option>
                        <option value="dark">Dark</option>
                    </select>
                </UIField>
                <div class="flex justify-stretch border-t border-slate-200/80 pt-5 dark:border-slate-800/80 sm:justify-end">
                    <UIButton Type="submit" Variant="UiButtonVariant.Primary" Class="w-full sm:w-auto">Save theme</UIButton>
                </div>
            </EditForm>
        </div>

        <div>
            <UIField Label="Default login/register image" For="authImage" Hint="JPEG, PNG, GIF, or WebP. Maximum 15 MB.">
                <InputFile id="authImage" OnChange="UploadAuthImageAsync" accept="image/jpeg,image/png,image/gif,image/webp,.jpg,.jpeg,.png,.gif,.webp"
                           class="block w-full min-w-0 cursor-pointer rounded-xl border border-dashed border-slate-200/90 bg-slate-50/50 px-4 py-3 text-sm text-slate-600 shadow-sm transition duration-200 ease-in-out hover:border-slate-300 hover:bg-slate-50 dark:border-slate-700 dark:bg-slate-950/50 dark:text-slate-300 dark:hover:border-slate-600 dark:hover:bg-slate-950/60 file:mr-4 file:cursor-pointer file:rounded-lg file:border-0 file:bg-[var(--accent)] file:px-4 file:py-2 file:text-sm file:font-semibold file:text-white file:shadow-sm file:transition file:duration-200 hover:file:brightness-[0.96]" />
            </UIField>
            @if (hasAuthImage)
            {
                <div class="mt-4 flex justify-end">
                    <UIButton Variant="UiButtonVariant.Outline" @onclick="ClearAuthImageAsync">Remove image</UIButton>
                </div>
                <div class="mt-4 overflow-hidden rounded-xl border border-slate-200/80 dark:border-slate-800/80">
                    <img src="@($"/app/default-auth-image?t={authImageStamp}")" alt="Default login/register image preview" class="h-40 w-full object-cover sm:h-56" />
                </div>
            }
        </div>
    </div>
</UICard>

@code {
    private bool loading = true;
    private string? message;
    private List<AdminUserRow> users = [];
    private bool hasAuthImage;
    private long authImageStamp;
    private readonly Model model = new();

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        loading = true;
        users = await AdminUsers.ListUsersAsync();
        var defaults = await AppSettings.GetOrCreateAsync();
        model.DefaultThemeMode = defaults.DefaultThemeMode;
        hasAuthImage = !string.IsNullOrWhiteSpace(defaults.DefaultAuthImageRelativePath);
        authImageStamp = defaults.UpdatedAtUtc.Ticks;
        loading = false;
    }

    private async Task LockAsync(string userId)
    {
        message = null;
        try
        {
            await AdminUsers.LockUserAsync(userId);
            await ReloadAsync();
            message = "User locked.";
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
        }
    }

    private async Task UnlockAsync(string userId)
    {
        message = null;
        try
        {
            await AdminUsers.UnlockUserAsync(userId);
            await ReloadAsync();
            message = "User unlocked.";
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
        }
    }

    private async Task ResetPasswordAsync(string userId)
    {
        message = null;
        try
        {
            var pw = await AdminUsers.ResetPasswordAsync(userId);
            await ReloadAsync();
            message = $"Temporary password: {pw}";
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
        }
    }

    private async Task DeleteAsync(string userId)
    {
        message = null;
        try
        {
            await AdminUsers.DeleteUserAsync(userId);
            await ReloadAsync();
            message = "User deleted.";
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
        }
    }

    private async Task SaveThemeAsync()
    {
        message = null;
        try
        {
            var saved = await AppSettings.UpdateThemeModeAsync(model.DefaultThemeMode);
            model.DefaultThemeMode = saved.DefaultThemeMode;
            message = "Default theme updated.";
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
        }
    }

    private async Task UploadAuthImageAsync(InputFileChangeEventArgs e)
    {
        message = null;
        try
        {
            var file = e.File;
            if (file is null)
                return;

            var saved = await AppSettings.SetDefaultAuthImageAsync(file);
            hasAuthImage = !string.IsNullOrWhiteSpace(saved.DefaultAuthImageRelativePath);
            authImageStamp = saved.UpdatedAtUtc.Ticks;
            message = "Default login/register image updated.";
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
        }
    }

    private async Task ClearAuthImageAsync()
    {
        message = null;
        try
        {
            var saved = await AppSettings.ClearDefaultAuthImageAsync();
            hasAuthImage = !string.IsNullOrWhiteSpace(saved.DefaultAuthImageRelativePath);
            authImageStamp = saved.UpdatedAtUtc.Ticks;
            message = "Default login/register image removed.";
        }
        catch (Exception ex)
        {
            message = $"Error: {ex.Message}";
        }
    }

    private sealed class Model
    {
        [System.ComponentModel.DataAnnotations.Required]
        public string DefaultThemeMode { get; set; } = "system";
    }
}

